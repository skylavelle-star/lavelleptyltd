# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_ID=

# Site URL (used for canonical URLs and OG metadata)
PUBLIC_SITE_URL=https://lavelleptyltd.com.au

# Lemon Squeezy checkout URLs (format: https://{store}.lemonsqueezy.com/checkout/buy/{variant_id})
# When set, product pages show a Buy Now button. When unset, pages render a
# notify-me Web3Forms fallback. Set each variable only once the matching
# Lemon Squeezy variant has been created in the dashboard.

# Live packs (Tier 1)
PUBLIC_LS_STEERING_COMMITTEE_PACK=
PUBLIC_LS_PROJECT_RECOVERY_PACK=
PUBLIC_LS_BUSINESS_CASE_PACK=
PUBLIC_LS_PROCUREMENT_PACK=

# Stage packs (currently stubs — set once LS variants exist)
PUBLIC_LS_PROJECT_SETUP_PACK=
PUBLIC_LS_DISCOVERY_PACK=
PUBLIC_LS_REQUIREMENTS_DESIGN_PACK=
PUBLIC_LS_FINANCIAL_CONTROL_PACK=
PUBLIC_LS_TESTING_PACK=
PUBLIC_LS_CUTOVER_PACK=
PUBLIC_LS_TRAINING_CHANGE_PACK=

# Flagship — Complete Practitioner Library (single named user)
PUBLIC_LS_COMPLETE_LIBRARY=

# Tier bundles + consulting-led recovery bundle
PUBLIC_LS_TIER_3_LIGHT=
PUBLIC_LS_TIER_2_STANDARD=
PUBLIC_LS_TIER_1_MAJOR=
PUBLIC_LS_PROJECT_RECOVERY_BUNDLE=

# Vercel deploy hook — used by `npm run refresh` to force a CDN purge between deploys.
# Create in Vercel project settings → Git → Deploy Hooks. Marked Sensitive in Vercel,
# which means `vercel env pull` writes it back as an empty string. After each pull,
# paste the hook URL into .env.local by hand.
VERCEL_DEPLOY_HOOK_URL=
