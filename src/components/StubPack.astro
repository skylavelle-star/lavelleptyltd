---
interface Props {
  packName: string;
  packSlug: string;
  frameworkStage: string;
  frameworkGate: string;
  tagline?: string;
  subhead: string;
  artefacts: string[];
}

import { site } from "../config/site";

const {
  packName,
  packSlug,
  frameworkStage,
  frameworkGate,
  tagline,
  subhead,
  artefacts,
} = Astro.props;

const eyebrow = `${packName} · ${frameworkStage}`;
const formId = `notify-${packSlug}`;
---

<section class="subhero">
  <div class="wrap">
    <div class="subhero__crumb">
      <a href="/">Home</a> &nbsp;/&nbsp;
      <a href="/templates">Templates</a> &nbsp;/&nbsp;
      <span>{packName}</span>
    </div>
    <div class="eyebrow">{eyebrow}</div>
    <h1 style="margin-top:1rem;">
      {
        tagline ? (
          <Fragment set:html={tagline} />
        ) : (
          <em>Tagline pending.</em>
        )
      }
    </h1>
    <p class="subhero__lead">{subhead}</p>
  </div>
</section>

<section>
  <div class="wrap" style="max-width:64rem;">
    <h2 class="section__title">What is included</h2>
    <ul class="stub-list">
      {artefacts.map((a) => <li>{a}</li>)}
    </ul>

    <div class="stub-callout">
      <div class="eyebrow">In production</div>
      <p>
        This pack is being finalised. Use the notify form below — or talk to
        Sky directly if you have an immediate need.
      </p>
      <form data-notify-form={formId} class="stub-form" novalidate>
        <input type="hidden" name="access_key" value={site.web3formsKey} />
        <input
          type="hidden"
          name="subject"
          value={`Interest: ${packName} — lavelleptyltd.com.au`}
        />
        <input
          type="hidden"
          name="from_name"
          value="Lavelle Pty Ltd Templates"
        />
        <input
          type="hidden"
          name="message"
          value={`Interested in the ${packName} when available.`}
        />
        <input
          type="checkbox"
          name="botcheck"
          class="stub-form__bot"
          tabindex="-1"
          autocomplete="off"
        />
        <label class="visually-hidden" for={`${formId}-email`}>Your email</label>
        <input
          id={`${formId}-email`}
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          autocomplete="email"
        />
        <button type="submit" class="btn btn--primary">
          Notify me <span class="btn__arrow">→</span>
        </button>
        <p
          id={`notify-success-${formId}`}
          class="stub-form__success"
          hidden
        >
          Done — we will email you when it ships.
        </p>
      </form>
    </div>

    <div class="stub-framework">
      <strong>Framework anchor:</strong> {frameworkStage}, exiting through
      <strong>{frameworkGate}</strong>.
      <a href="/framework">See the framework →</a>
    </div>
  </div>
</section>

<style>
  .stub-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    border-top: 1px solid var(--rule);
  }
  .stub-list li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule);
    color: var(--ink-soft);
  }
  .stub-callout {
    padding: 1.75rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--ochre);
    margin-bottom: 2rem;
  }
  .stub-callout p {
    color: var(--ink-soft);
    margin: 0.5rem 0 1rem;
  }
  .stub-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    max-width: 28rem;
  }
  .stub-form input[type="email"] {
    flex: 1 1 14rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    background: var(--bone);
    font-family: inherit;
    font-size: var(--body-sm);
  }
  .stub-form__bot {
    display: none;
  }
  .stub-form__success {
    font-size: var(--body-sm);
    color: var(--ochre);
    width: 100%;
  }
  .stub-form__success[hidden] {
    display: none;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }
  .stub-framework {
    padding: 1.25rem 1.5rem;
    background: var(--bone);
    border: 1px solid var(--rule);
    font-size: var(--body-sm);
    color: var(--ink-soft);
  }
  .stub-framework a {
    color: var(--ochre);
    margin-left: 0.5rem;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLFormElement>("[data-notify-form]")
    .forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const id = form.dataset.notifyForm!;
        const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
        const botcheck =
          form.querySelector<HTMLInputElement>('[name="botcheck"]');
        if (botcheck?.checked) return;
        if (btn) {
          btn.disabled = true;
          btn.textContent = "Sending…";
        }
        let ok = false;
        try {
          const res = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(
              Object.fromEntries(new FormData(form).entries()),
            ),
          });
          const data = (await res.json().catch(() => ({}))) as {
            success?: boolean;
          };
          ok = data.success === true;
        } catch {
          /* silent */
        }
        if (ok) {
          form.querySelectorAll("input, button, label").forEach((el) => {
            (el as HTMLElement).hidden = true;
          });
          const success = document.getElementById(`notify-success-${id}`);
          if (success) success.hidden = false;
        } else if (btn) {
          btn.disabled = false;
          btn.innerHTML = 'Notify me <span class="btn__arrow">→</span>';
        }
      });
    });
</script>
