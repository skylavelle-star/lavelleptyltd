---
interface Props {
  title: string;
  description?: string;
  href?: string;
  id?: string;
}

const { title, description, href, id } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  id={id}
  class:list={[
    'flex items-start gap-3 p-5 rounded-lg border border-slate-200 bg-white transition-all',
    href && 'hover:border-navy-300 hover:shadow-sm group',
  ]}
>
  <div class="w-1.5 h-1.5 rounded-full bg-navy-600 shrink-0 mt-2" aria-hidden="true"></div>
  <div>
    <span class:list={['text-sm font-medium text-slate-800 leading-snug', href && 'group-hover:text-navy-700 transition-colors']}>
      {title}
    </span>
    {description && <p class="text-xs text-slate-500 mt-1 leading-relaxed">{description}</p>}
  </div>
</Tag>
