---
// Renders a single block of structured data (JSON-LD). Pass any schema.org
// object as `data`. Valid in <head> or <body> per Google's guidance.
interface Props {
  data: Record<string, unknown>;
}
const { data } = Astro.props;
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
