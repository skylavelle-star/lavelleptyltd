---
interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="flex gap-6 p-6 rounded-lg border border-slate-200 bg-white hover:border-navy-300 hover:shadow-sm transition-all">
  <div class="shrink-0">
    <span class="flex items-center justify-center w-10 h-10 rounded-full bg-navy-950 text-white text-sm font-bold">
      {number}
    </span>
  </div>
  <div>
    <h3 class="text-base font-semibold text-slate-900 mb-2">{title}</h3>
    <p class="text-sm text-slate-600 leading-relaxed">{description}</p>
  </div>
</div>
