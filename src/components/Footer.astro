---
import { site } from '../config/site';

const currentYear = new Date().getFullYear();

const footerLinks = {
  'PMO Resources': [
    { label: 'PMO Resources', href: '/pmo-resources' },
    { label: 'Free Tools', href: '/free-tools' },
    { label: 'Templates', href: '/templates' },
    { label: 'Delivery Framework', href: '/delivery-framework' },
    { label: 'Free Project Recovery Checklist', href: '/free-tools/project-recovery-checklist' },
  ],
  Consulting: [
    { label: 'Senior Project Management', href: '/consulting' },
    { label: 'Project Recovery', href: '/consulting#project-recovery' },
    { label: 'Business Case Development', href: '/consulting#business-case' },
    { label: 'Procurement and RFP', href: '/consulting#procurement' },
    { label: 'Delivery Assurance', href: '/consulting#delivery-assurance' },
  ],
  Company: [
    { label: 'About', href: '/about' },
    { label: 'Digital Assets', href: '/digital-assets' },
    { label: 'Contact', href: '/contact' },
    { label: 'Sky Lavelle (Principal Consultant)', href: site.skyLavelleUrl, external: true },
  ],
};
---

<footer class="bg-slate-900 text-slate-300">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="lg:col-span-1">
        <a href="/" class="text-lg font-bold text-white hover:text-slate-200 transition-colors tracking-tight">
          Lavelle Pty Ltd
        </a>
        <p class="mt-4 text-sm text-slate-400 leading-relaxed">
          Senior project delivery consulting, practical PMO resources and digital asset development.
        </p>
        <p class="mt-3 text-sm text-slate-500">
          Australian company. ABN available on request.
        </p>
        <div class="mt-6">
          <a
            href="/contact"
            class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-navy-700 hover:bg-navy-600 rounded-md transition-colors"
          >
            Engage Lavelle Pty Ltd
          </a>
        </div>
      </div>

      {
        Object.entries(footerLinks).map(([heading, links]) => (
          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
              {heading}
            </h3>
            <ul class="space-y-2">
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...('external' in link && link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    class="text-sm text-slate-400 hover:text-white transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">
        &copy; {currentYear} Lavelle Pty Ltd. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a
          href={site.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-300 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href={`mailto:${site.email}`} class="text-sm text-slate-500 hover:text-slate-300 transition-colors">
          {site.email}
        </a>
      </div>
    </div>
  </div>
</footer>
