---
import { site } from "../config/site";
import JsonLd from "./JsonLd.astro";

interface IncludedItem {
  title: string;
  desc: string;
}
interface FAQ {
  q: string;
  a: string;
}
interface HowToStep {
  title: string;
  desc: string;
}
interface RelatedPack {
  name: string;
  href: string;
  price: string;
  blurb: string;
}
interface Stat {
  num: string;
  label: string;
}
interface FrameworkAnchor {
  stage: string;
  gate: string;
}
interface Props {
  packName: string;
  packSlug: string;
  price: string;
  checkoutUrl?: string;
  gaLabel: string;
  stats: Stat[];
  problemStatement: string[];
  audience: string[];
  included: IncludedItem[];
  howToUse: HowToStep[];
  faqs: FAQ[];
  roiBlock?: string;
  relatedPacks?: RelatedPack[];
  relatedConsultingHref?: string;
  relatedConsultingLabel?: string;
  extraSidecard?: { heading: string; text: string; href: string; cta: string };
  framework?: FrameworkAnchor;
}

const {
  packName,
  packSlug,
  price,
  checkoutUrl,
  gaLabel,
  stats,
  problemStatement,
  audience,
  included,
  howToUse,
  faqs,
  roiBlock,
  relatedPacks = [],
  relatedConsultingHref,
  relatedConsultingLabel,
  extraSidecard,
  framework,
} = Astro.props;

const sections = [
  { id: "why", label: "Why this pack exists" },
  { id: "audience", label: "Who it is for" },
  { id: "included", label: "What is included" },
  { id: "how", label: "How to use it" },
  { id: "format", label: "Format and delivery" },
  { id: "faq", label: "FAQ" },
];

const pageUrl = new URL(Astro.url.pathname, site.url).toString();
const stripHtml = (s: string) => s.replace(/<[^>]*>/g, "").trim();

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: packName,
  description: problemStatement[0] ? stripHtml(problemStatement[0]) : packName,
  brand: { "@type": "Brand", name: site.name },
  category: "Project management templates",
  url: pageUrl,
  offers: {
    "@type": "Offer",
    price: price.replace(/[^0-9.]/g, ""),
    priceCurrency: "AUD",
    url: pageUrl,
    availability: checkoutUrl
      ? "https://schema.org/InStock"
      : "https://schema.org/PreOrder",
    seller: { "@id": `${site.url}/#organization` },
  },
};

const faqSchema =
  faqs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((f) => ({
          "@type": "Question",
          name: stripHtml(f.q),
          acceptedAnswer: { "@type": "Answer", text: stripHtml(f.a) },
        })),
      }
    : null;
---

<JsonLd data={productSchema} />
{faqSchema && <JsonLd data={faqSchema} />}

<!-- AT-A-GLANCE STAT STRIP -->
<section class="pack-stats">
  <div class="wrap">
    <div class="pack-stats__grid">
      {
        stats.map((s) => (
          <div class="pack-stats__item">
            <div class="pack-stats__num">{s.num}</div>
            <div class="pack-stats__label">{s.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- PURCHASE / REGISTER ROW -->
<section class="pack-buy">
  <div class="wrap">
    <div class="pack-buy__inner">
      {
        checkoutUrl ? (
          <>
            <div class="pack-buy__price-block">
              <div class="eyebrow">One-time purchase</div>
              <div class="pack-buy__price-row">
                <span class="pack-buy__price">${price}</span>
                <span class="pack-buy__sub">single user · AUD</span>
              </div>
              <p class="pack-buy__note">
                Delivered as a single download via Lemon Squeezy. Editable Word
                and Excel files. Yours to use across as many of your own
                engagements as you need.
              </p>
            </div>
            <a
              href={checkoutUrl}
              class="lemonsqueezy-button btn btn--primary pack-buy__cta"
              data-ga-event="product_buy_click"
              data-ga-label={gaLabel}
            >
              Buy now <span class="btn__arrow">→</span>
            </a>
          </>
        ) : (
          <>
            <div class="pack-buy__price-block">
              <div class="eyebrow">In final review</div>
              <h3 class="pack-buy__heading">
                Be the first to know when {packName} ships.
              </h3>
              <p class="pack-buy__note">
                This pack is in final production. Drop your email and we will
                send you a link the moment it goes live - no marketing list, no
                follow-up sequences.
              </p>
            </div>
            <form
              data-notify-form={`notify-${packSlug}`}
              class="pack-buy__form"
              novalidate
            >
              <input type="hidden" name="access_key" value={site.web3formsKey} />
              <input
                type="hidden"
                name="subject"
                value={`Interest: ${packName} - lavelleptyltd.com.au`}
              />
              <input
                type="hidden"
                name="from_name"
                value="Lavelle Pty Ltd Resources"
              />
              <input
                type="hidden"
                name="message"
                value={`Interested in the ${packName} when available.`}
              />
              <input
                type="checkbox"
                name="botcheck"
                class="pack-buy__bot"
                tabindex="-1"
                autocomplete="off"
              />
              <label class="visually-hidden" for={`notify-${packSlug}-email`}>
                Your email
              </label>
              <input
                id={`notify-${packSlug}-email`}
                type="email"
                name="email"
                required
                placeholder="your@email.com"
                autocomplete="email"
              />
              <button type="submit" class="btn btn--primary">
                Notify me <span class="btn__arrow">→</span>
              </button>
              <p
                id={`notify-success-notify-${packSlug}`}
                class="pack-buy__success"
                hidden
              >
                Done - we will email you the moment it ships.
              </p>
            </form>
          </>
        )
      }
    </div>
  </div>
</section>

<!-- MAIN CONTENT: STICKY TOC + PROSE + SIDECARD -->
<section class="pack-body">
  <div class="wrap">
    <div class="pack-body__grid">
      <!-- TOC -->
      <aside class="pack-toc" aria-label="On this page">
        <div class="eyebrow">On this page</div>
        <ol class="pack-toc__list">
          {
            sections.map((s, i) => (
              <li>
                <a href={`#${s.id}`}>
                  <span class="pack-toc__num">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span>{s.label}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </aside>

      <!-- PROSE -->
      <div class="pack-prose">
        <section id="why" class="pack-section">
          <div class="eyebrow">Why this pack exists</div>
          <h2 class="pack-section__title">
            The pattern this pack <em>was built for.</em>
          </h2>
          {problemStatement.map((para) => <p>{para}</p>)}
        </section>

        <section id="audience" class="pack-section">
          <div class="eyebrow">Who it is for</div>
          <h2 class="pack-section__title">
            Built for the people who will <em>actually use it.</em>
          </h2>
          <ul class="pack-audience">
            {
              audience.map((line, i) => (
                <li>
                  <span class="pack-audience__num">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span>{line}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section id="included" class="pack-section">
          <div class="eyebrow">What is included</div>
          <h2 class="pack-section__title">
            Every artefact you need. <em>Nothing you don't.</em>
          </h2>
          <div class="pack-included">
            {
              included.map((item, i) => (
                <article class="pack-included__card">
                  <div class="pack-included__num">
                    {String(i + 1).padStart(2, "0")}
                  </div>
                  <h3>{item.title}</h3>
                  <p>{item.desc}</p>
                </article>
              ))
            }
          </div>
        </section>

        <section id="how" class="pack-section">
          <div class="eyebrow">How to use it</div>
          <h2 class="pack-section__title">
            A sequence that <em>holds up under pressure.</em>
          </h2>
          <ol class="pack-howto">
            {
              howToUse.map((step, i) => (
                <li class="pack-howto__step">
                  <div class="pack-howto__num">
                    {String(i + 1).padStart(2, "0")}
                  </div>
                  <div>
                    <h3>{step.title}</h3>
                    <p>{step.desc}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </section>

        <section id="format" class="pack-section">
          <div class="eyebrow">Format and delivery</div>
          <h2 class="pack-section__title">
            Standard formats. <em>No setup required.</em>
          </h2>
          <div class="pack-format">
            <div class="pack-format__item">
              <div class="pack-format__label">File types</div>
              <div class="pack-format__value">
                Microsoft Word (.docx) and Excel (.xlsx)
              </div>
            </div>
            <div class="pack-format__item">
              <div class="pack-format__label">Editing</div>
              <div class="pack-format__value">
                Fully editable. Works in Google Docs and Google Sheets, though
                some conditional formatting may not carry across.
              </div>
            </div>
            <div class="pack-format__item">
              <div class="pack-format__label">Language</div>
              <div class="pack-format__value">
                Australian English. Delivery-neutral. No assumed methodology.
              </div>
            </div>
            <div class="pack-format__item">
              <div class="pack-format__label">Delivery</div>
              <div class="pack-format__value">
                Single download via Lemon Squeezy, immediately after purchase.
              </div>
            </div>
          </div>
        </section>

        <section id="faq" class="pack-section">
          <div class="eyebrow">Frequently asked</div>
          <h2 class="pack-section__title">
            Questions worth <em>asking up front.</em>
          </h2>
          <div class="pack-faq">
            {
              faqs.map((item) => (
                <details class="pack-faq__item">
                  <summary>{item.q}</summary>
                  <p set:html={item.a} />
                </details>
              ))
            }
          </div>
        </section>

        {
          roiBlock && (
            <aside class="pack-roi" aria-label="What this saves you">
              <div class="eyebrow">What this saves you</div>
              <p>{roiBlock}</p>
            </aside>
          )
        }

        {
          checkoutUrl && (
            <div class="pack-prose__cta">
              <a
                href={checkoutUrl}
                class="lemonsqueezy-button btn btn--primary"
                data-ga-event="product_buy_click"
                data-ga-label={gaLabel}
              >
                Buy {packName} for ${price} <span class="btn__arrow">→</span>
              </a>
            </div>
          )
        }
      </div>

      <!-- SIDECARD -->
      <aside class="pack-aside">
        <div class="pack-aside__card">
          {
            checkoutUrl ? (
              <>
                <h4>Purchase summary</h4>
                <div class="pack-aside__price">
                  ${price}
                  <span class="pack-aside__sub">single user · AUD</span>
                </div>
                <a
                  href={checkoutUrl}
                  class="lemonsqueezy-button btn btn--primary pack-aside__btn"
                  data-ga-event="product_buy_click"
                  data-ga-label={gaLabel}
                >
                  Buy now <span class="btn__arrow">→</span>
                </a>
                <ul class="pack-aside__list">
                  <li>{included.length} editable artefacts</li>
                  <li>Word and Excel format</li>
                  <li>Australian English</li>
                  <li>Instant delivery via Lemon Squeezy</li>
                </ul>
              </>
            ) : (
              <>
                <h4>Coming online</h4>
                <p class="pack-aside__note">
                  {packName} is in final production. Use the notify form above -
                  or speak to Sky directly if you have an immediate need.
                </p>
                <a href="/contact" class="btn btn--primary pack-aside__btn">
                  Talk to Sky <span class="btn__arrow">→</span>
                </a>
              </>
            )
          }
        </div>

        {
          framework && (
            <div class="pack-aside__block">
              <h4>Framework anchor</h4>
              <p class="pack-aside__note">
                This pack supports the <strong>{framework.stage}</strong> stage
                of the Lavelle Delivery Framework, exiting through{" "}
                <strong>{framework.gate}</strong>.
              </p>
              <a href="/framework" class="cap__link">
                See the framework <span>→</span>
              </a>
            </div>
          )
        }

        {
          relatedConsultingHref && relatedConsultingLabel && (
            <div class="pack-aside__block">
              <h4>Need it done with you?</h4>
              <p class="pack-aside__note">
                If you need an experienced practitioner alongside the pack, Sky
                takes a limited number of engagements each quarter.
              </p>
              <a href={relatedConsultingHref} class="cap__link">
                {relatedConsultingLabel} <span>→</span>
              </a>
            </div>
          )
        }

        {
          extraSidecard && (
            <div class="pack-aside__block">
              <h4>{extraSidecard.heading}</h4>
              <p class="pack-aside__note">{extraSidecard.text}</p>
              <a href={extraSidecard.href} class="cap__link">
                {extraSidecard.cta} <span>→</span>
              </a>
            </div>
          )
        }
      </aside>
    </div>
  </div>
</section>

<!-- RELATED PACKS -->
{
  relatedPacks.length > 0 && (
    <section class="pack-related">
      <div class="wrap">
        <header class="section__head">
          <div>
            <div class="eyebrow">Sister packs</div>
            <h2 class="section__title" style="margin-top:1.25rem;">
              The other pieces of <em>the delivery system.</em>
            </h2>
          </div>
          <p class="lead">
            Each Lavelle pack is built to stand alone. Together they cover the
            governance, recovery, investment and procurement work that complex
            delivery actually demands.
          </p>
        </header>
        <div class="pack-related__grid">
          {relatedPacks.map((p) => (
            <a href={p.href} class="pack-related__card">
              <div class="pack-related__head">
                <h3>{p.name}</h3>
                <span class="pack-related__price">${p.price}</span>
              </div>
              <p>{p.blurb}</p>
              <span class="pack-related__cta">
                View pack <span class="btn__arrow">→</span>
              </span>
            </a>
          ))}
        </div>
        <div class="pack-related__bundle">
          <div>
            <div class="eyebrow">Tier-based bundles</div>
            <p>
              The right bundle depends on the complexity of your work. Score
              the project with the Tailoring Calculator, then choose from Tier
              3 Light, Tier 2 Standard or Tier 1 Major.
            </p>
          </div>
          <a href="/bundles" class="btn btn--ghost">
            See the bundles <span class="btn__arrow">→</span>
          </a>
        </div>
      </div>
    </section>
  )
}

<!-- ENGAGE STRIP -->
<section class="engage">
  <div class="wrap">
    <div class="engage__grid">
      <div>
        <div class="eyebrow">Engage Lavelle</div>
        <h2 style="margin-top:1.25rem;">
          Templates handle the structure.<br />
          <em>The hard conversations are still yours.</em>
        </h2>
        <p class="lead" style="margin-top:1.5rem;">
          If you are in the middle of a recovery, a contested business case or a
          procurement that has to land - and you would like a senior pair of eyes
          alongside the pack - start with a thirty-minute call.
        </p>
        <div class="hero__ctas" style="margin-top:2.5rem;">
          <a href="/contact" class="btn btn--primary">
            Book a call with Sky <span class="btn__arrow">→</span>
          </a>
        </div>
      </div>
      <ul class="engage__list">
        <li>
          <a href="/resources"
            ><span>All template packs</span><span>→</span></a
          >
        </li>
        <li>
          <a href="/free-tools"
            ><span>Free tools and checklists</span><span>→</span></a
          >
        </li>
        <li>
          <a href="/consulting"
            ><span>Consulting and advisory</span><span>→</span></a
          >
        </li>
        <li>
          <a href="/articles"
            ><span>Field notes and articles</span><span>→</span></a
          >
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  /* ============ AT-A-GLANCE STATS ============ */
  .pack-stats {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    padding: clamp(2rem, 4vw, 3rem) 0;
  }
  .pack-stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  @media (min-width: 760px) {
    .pack-stats__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .pack-stats__item {
    border-left: 1px solid var(--rule);
    padding-left: 1.25rem;
  }
  .pack-stats__num {
    font-family: "Fraunces", serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 300;
    color: var(--ochre);
    line-height: 1;
    font-variation-settings: "opsz" 144;
    margin-bottom: 0.5rem;
  }
  .pack-stats__label {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  /* ============ PURCHASE ROW ============ */
  .pack-buy {
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    background: var(--bone);
  }
  .pack-buy__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    background: var(--paper);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--ochre);
  }
  @media (min-width: 880px) {
    .pack-buy__inner {
      grid-template-columns: 1.4fr auto;
      gap: 3rem;
    }
  }
  .pack-buy__price-block {
    max-width: 56ch;
  }
  .pack-buy__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin: 0.75rem 0 1rem;
  }
  .pack-buy__price {
    font-family: "Fraunces", serif;
    font-size: clamp(2.5rem, 5vw, 3.25rem);
    font-weight: 300;
    color: var(--ink);
    line-height: 1;
    font-variation-settings: "opsz" 144;
  }
  .pack-buy__sub {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
  }
  .pack-buy__note {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    max-width: 52ch;
    margin-top: 0.5rem;
  }
  .pack-buy__heading {
    font-family: "Fraunces", serif;
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    font-weight: 500;
    line-height: 1.15;
    margin: 0.75rem 0 0.75rem;
    max-width: 24ch;
  }
  .pack-buy__cta {
    align-self: center;
    justify-self: start;
  }
  .pack-buy__form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-self: center;
    min-width: 0;
    width: 100%;
    max-width: 26rem;
  }
  .pack-buy__form input[type="email"] {
    flex: 1 1 14rem;
    min-width: 0;
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    background: var(--bone);
    font-family: inherit;
    font-size: var(--body-sm);
  }
  .pack-buy__form input[type="email"]:focus {
    outline: none;
    border-color: var(--ochre);
  }
  .pack-buy__form .btn {
    padding: 0.85rem 1.25rem;
  }
  .pack-buy__bot {
    display: none;
  }
  .pack-buy__success {
    font-size: var(--body-sm);
    color: var(--ochre);
    width: 100%;
  }
  .pack-buy__success[hidden] {
    display: none;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* ============ MAIN BODY ============ */
  .pack-body {
    padding: clamp(3.5rem, 7vw, 6rem) 0;
  }
  .pack-body__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 980px) {
    .pack-body__grid {
      grid-template-columns: 0.7fr 2fr 1fr;
      gap: 3.5rem;
    }
  }

  /* TOC */
  .pack-toc {
    align-self: start;
    position: static;
    border-top: 1px solid var(--rule);
    padding-top: 1.25rem;
  }
  @media (min-width: 980px) {
    .pack-toc {
      position: sticky;
      top: 100px;
    }
  }
  .pack-toc .eyebrow {
    margin-bottom: 1rem;
  }
  .pack-toc__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 0;
    margin: 0;
  }
  .pack-toc__list a {
    display: flex;
    gap: 0.85rem;
    padding: 0.5rem 0;
    font-size: var(--body-sm);
    color: var(--ink-soft);
    border-top: 1px solid transparent;
    border-bottom: 1px solid var(--rule);
    transition: color 0.2s;
  }
  .pack-toc__list a:hover {
    color: var(--ochre);
  }
  .pack-toc__num {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-size: 0.8rem;
    color: var(--ochre);
    flex-shrink: 0;
  }

  /* PROSE */
  .pack-prose {
    min-width: 0;
  }
  .pack-section {
    border-top: 1px solid var(--rule);
    padding-top: clamp(2.5rem, 4vw, 3.5rem);
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
  }
  .pack-section:first-child {
    border-top: none;
    margin-top: 0;
    padding-top: 0;
  }
  .pack-section .eyebrow {
    margin-bottom: 1rem;
  }
  .pack-section__title {
    font-family: "Fraunces", serif;
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.012em;
    margin: 0 0 1.5rem;
    max-width: 22ch;
  }
  .pack-section__title em {
    color: var(--ochre);
    font-style: italic;
    font-weight: 300;
  }
  .pack-section p {
    color: var(--ink-soft);
    max-width: 60ch;
    margin-bottom: 1.25rem;
    line-height: 1.65;
  }

  /* AUDIENCE LIST */
  .pack-audience {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--rule);
  }
  .pack-audience li {
