---
interface IncludedItem {
  title: string;
  desc: string;
}
interface FAQ {
  q: string;
  a: string;
}

interface Props {
  price: string;
  checkoutUrl?: string;
  gaLabel: string;
  audience: string[];
  helpsWith: string[];
  included: IncludedItem[];
  howToUse: string;
  faqs: FAQ[];
  relatedConsultingHref?: string;
  relatedConsultingLabel?: string;
  extraSidecard?: { heading: string; text: string; href: string; cta: string };
}

const {
  price,
  checkoutUrl,
  gaLabel,
  audience,
  helpsWith,
  included,
  howToUse,
  faqs,
  relatedConsultingHref,
  relatedConsultingLabel,
  extraSidecard,
} = Astro.props;
---

<section>
  <div class="wrap">
    <div class="split">
      <div class="prose">
        {
          checkoutUrl ? (
            <div class="pack-price-row">
              <div>
                <span class="pack-price">${price}</span>
                <span class="pack-price-sub">single user · AUD</span>
              </div>
              <a
                href={checkoutUrl}
                class="lemonsqueezy-button btn btn--primary"
                data-ga-event="product_buy_click"
                data-ga-label={gaLabel}
              >
                Buy now <span class="btn__arrow">→</span>
              </a>
            </div>
          ) : (
            <div class="pack-coming">
              Coming soon —
              <a href="/contact" class="pack-coming__link">
                register your interest
              </a>
            </div>
          )
        }

        <h2>Who it is for</h2>
        <ul>
          {audience.map((line) => <li>{line}</li>)}
        </ul>

        <h2>What it helps with</h2>
        {helpsWith.map((para) => <p>{para}</p>)}

        <h2>What is included</h2>
        <div class="included-grid">
          {
            included.map((item) => (
              <div class="included">
                <h3>{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            ))
          }
        </div>

        <h2>How to use it</h2>
        <p>{howToUse}</p>

        <h2>Frequently asked questions</h2>
        <div class="faq-list">
          {
            faqs.map((item) => (
              <details class="faq">
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))
          }
        </div>

        <h2>Format and delivery</h2>
        <p>
          Microsoft Word templates (.docx) and Excel workbooks (.xlsx). All
          documents are fully editable. Delivered via Lemon Squeezy after
          purchase.
        </p>

        {
          checkoutUrl && (
            <div style="margin-top:2.5rem;">
              <a
                href={checkoutUrl}
                class="lemonsqueezy-button btn btn--primary"
                data-ga-event="product_buy_click"
                data-ga-label={gaLabel}
              >
                Buy now <span class="btn__arrow">→</span>
              </a>
            </div>
          )
        }
      </div>

      <aside class="sidecard">
        {
          checkoutUrl ? (
            <>
              <h4>One-time purchase</h4>
              <div class="pack-price" style="margin-bottom:1rem;">
                ${price} <span class="pack-price-sub">single user · AUD</span>
              </div>
              <a
                href={checkoutUrl}
                class="lemonsqueezy-button btn btn--primary"
                data-ga-event="product_buy_click"
                data-ga-label={gaLabel}
                style="margin-bottom:1.5rem;"
              >
                Buy now <span class="btn__arrow">→</span>
              </a>
              <ul>
                <li>Microsoft Word + Excel format</li>
                <li>Fully editable templates</li>
                <li>Australian English</li>
                <li>Delivered via Lemon Squeezy</li>
              </ul>
            </>
          ) : (
            <>
              <h4>Coming soon</h4>
              <p style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1.5rem;">
                Register your interest to be notified on launch.
              </p>
              <a href="/contact" class="btn btn--primary">
                Register interest <span class="btn__arrow">→</span>
              </a>
            </>
          )
        }

        {
          relatedConsultingHref && relatedConsultingLabel && (
            <>
              <h4 style="margin-top:2rem;">Advisory option</h4>
              <a href={relatedConsultingHref} class="cap__link">
                {relatedConsultingLabel} <span>→</span>
              </a>
            </>
          )
        }

        {
          extraSidecard && (
            <>
              <h4 style="margin-top:2rem;">{extraSidecard.heading}</h4>
              <p style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1rem;">
                {extraSidecard.text}
              </p>
              <a href={extraSidecard.href} class="cap__link">
                {extraSidecard.cta} <span>→</span>
              </a>
            </>
          )
        }
      </aside>
    </div>
  </div>
</section>

<style>
  .pack-price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1rem;
  }
  .pack-price {
    font-family: "Fraunces", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
  }
  .pack-price-sub {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    margin-left: 0.4rem;
  }
  .pack-coming {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-size: var(--body-sm);
    color: var(--ink-soft);
    margin-bottom: 1rem;
  }
  .pack-coming__link {
    color: var(--ochre);
    text-decoration: underline;
    margin-left: 0.4rem;
  }
  .included-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    margin: 1rem 0 2rem;
  }
  .included {
    background: var(--bone);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--ochre);
    padding: 1rem 1.25rem;
  }
  .included h3 {
    font-family: "Fraunces", serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }
  .included p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: none;
    margin-bottom: 0;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1rem 0 2rem;
  }
  .faq {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 1rem 1.25rem;
  }
  .faq summary {
    font-family: "Fraunces", serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq summary::before {
    content: "+";
    display: inline-block;
    color: var(--ochre);
    font-weight: 400;
    margin-right: 0.75rem;
    transition: transform 0.2s;
  }
  .faq[open] summary::before {
    content: "−";
  }
  .faq p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    margin-top: 0.75rem;
    max-width: none;
  }
</style>
