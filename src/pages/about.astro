---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import aboutImage from "../assets/images/about.jpg";
import engageImage from "../assets/images/engage-boardroom.jpg";
---

<BaseLayout
  title="About - Lavelle Pty Ltd"
  description="Lavelle Pty Ltd is an Australian company owned and directed by Sky Lavelle, providing senior project management consulting, PMO resource development and digital asset activities."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>About</span>
      </div>
      <h1>An Australian company. <em>Senior delivery, by default.</em></h1>
      <p class="subhero__lead">
        Lavelle Pty Ltd is an Australian company providing senior project
        delivery consulting, practical PMO resources and digital asset
        development.
      </p>
    </div>
  </section>

  <figure class="image-band">
    <Image
      src={aboutImage}
      alt="A team gathered around a meeting table with laptops while a presenter explains a programme at a screen - the working rhythm Lavelle establishes on engagement"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      loading="lazy"
      class="image-band__img"
    />
  </figure>

  <section>
    <div class="wrap">
      <div class="prose">
        <p>
          Lavelle Pty Ltd is an Australian company owned and directed by Sky
          Lavelle.
        </p>
        <p>
          Sky is both a director and employee of the company, providing senior
          project management and consulting services through Lavelle Pty Ltd
          while also leading the company's PMO resource development and digital
          asset activities.
        </p>
        <p>
          The company's work is grounded in practical delivery experience,
          commercial discipline and a focus on building useful systems that can
          scale over time.
        </p>
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Operating model</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            How we <em>operate.</em>
          </h2>
        </div>
        <p class="lead">
          Lavelle Pty Ltd combines hands-on delivery experience with digital
          asset development. Consulting work provides real-world delivery
          insight, while the digital asset portfolio and PMO resources turn that
          knowledge into reusable systems, content, tools and commercial
          products. This operating model allows the company to serve clients
          directly while also building long-term owned assets.
        </p>
      </header>

      <div class="capabilities">
        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
          </div>
          <div class="cap__num">01 / Advisory</div>
          <h3 class="cap__title">Senior Consulting</h3>
          <p class="cap__desc">
            Senior project management and consulting services through Sky
            Lavelle for complex technology, digital transformation, procurement,
            governance and business change engagements.
          </p>
          <a href="/consulting" class="cap__link"
            >View consulting <span>→</span></a
          >
        </article>
        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
          </div>
          <div class="cap__num">02 / Resources</div>
          <h3 class="cap__title">Resources</h3>
          <p class="cap__desc">
            Practical PMO resources - templates, artefacts and structured packs
            - for project managers, delivery leads and organisations that need
            stronger project control.
          </p>
          <a href="/resources" class="cap__link"
            >Browse templates <span>→</span></a
          >
        </article>
        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.84L11.18 12a2 2 0 0 0 1.66 0l8.58-4.08a1 1 0 0 0 0-1.84Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
          </div>
          <div class="cap__num">03 / Portfolio</div>
          <h3 class="cap__title">Digital Assets</h3>
          <p class="cap__desc">
            A growing portfolio of digital assets built around useful content,
            searchable information, commercial intent and repeatable systems.
          </p>
          <a href="/digital-assets" class="cap__link"
            >Learn more <span>→</span></a
          >
        </article>
      </div>
    </div>
  </section>

  <section class="engage engage--imaged">
    <figure class="engage__bg" aria-hidden="true">
      <Image
        src={engageImage}
        alt=""
        widths={[960, 1440, 1920, 2400]}
        sizes="100vw"
        loading="lazy"
        decoding="async"
        class="engage__bg-img"
      />
    </figure>
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Work with us</div>
          <h2 style="margin-top:1.25rem;">Engage <em>Lavelle Pty Ltd.</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            For consulting, PMO resources, delivery support or digital asset
            enquiries, use the contact form to send an enquiry.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Contact Lavelle Pty Ltd <span class="btn__arrow">→</span>
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li>
            <a href="/consulting">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
              </span>
              <span>Consulting services</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/resources">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
              </span>
              <span>Resources</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/case-studies">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/></svg>
              </span>
              <span>Case studies</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/digital-assets">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.84L11.18 12a2 2 0 0 0 1.66 0l8.58-4.08a1 1 0 0 0 0-1.84Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
              </span>
              <span>Digital asset portfolio</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
