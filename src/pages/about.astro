---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Lavelle Pty Ltd"
  description="Lavelle Pty Ltd is an Australian company owned and directed by Sky Lavelle, providing senior project management consulting, PMO resource development and digital asset activities."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>About</span>
      </div>
      <h1>An Australian company. <em>Senior delivery, by default.</em></h1>
      <p class="subhero__lead">
        Lavelle Pty Ltd is an Australian company providing senior project delivery consulting, practical PMO resources and digital asset development.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="prose">
        <p>
          Lavelle Pty Ltd is an Australian company owned and directed by Sky Lavelle.
        </p>
        <p>
          Sky is both a director and employee of the company, providing senior project management and consulting services through Lavelle Pty Ltd while also leading the company's PMO resource development and digital asset activities.
        </p>
        <p>
          The company's work is grounded in practical delivery experience, commercial discipline and a focus on building useful systems that can scale over time.
        </p>
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Operating model</div>
          <h2 class="section__title" style="margin-top:1.25rem;">How we <em>operate.</em></h2>
        </div>
        <p class="lead">
          Lavelle Pty Ltd combines hands-on delivery experience with digital asset development. Consulting work provides real-world delivery insight, while the digital asset portfolio and PMO resources turn that knowledge into reusable systems, content, tools and commercial products. This operating model allows the company to serve clients directly while also building long-term owned assets.
        </p>
      </header>

      <div class="capabilities">
        <article class="cap">
          <div class="cap__num">01 / Advisory</div>
          <h3 class="cap__title">Senior Consulting</h3>
          <p class="cap__desc">
            Senior project management and consulting services through Sky Lavelle for complex technology, digital transformation, procurement, governance and business change engagements.
          </p>
          <a href="/consulting" class="cap__link">View consulting <span>→</span></a>
        </article>
        <article class="cap">
          <div class="cap__num">02 / Resources</div>
          <h3 class="cap__title">PMO Resources</h3>
          <p class="cap__desc">
            Practical PMO resources — templates, artefacts and structured packs — for project managers, delivery leads and organisations that need stronger project control.
          </p>
          <a href="/pmo-resources" class="cap__link">Browse resources <span>→</span></a>
        </article>
        <article class="cap">
          <div class="cap__num">03 / Portfolio</div>
          <h3 class="cap__title">Digital Assets</h3>
          <p class="cap__desc">
            A growing portfolio of digital assets built around useful content, searchable information, commercial intent and repeatable systems.
          </p>
          <a href="/digital-assets" class="cap__link">Learn more <span>→</span></a>
        </article>
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Work with us</div>
          <h2 style="margin-top:1.25rem;">Engage <em>Lavelle Pty Ltd.</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            For consulting, PMO resources, delivery support or digital asset enquiries, use the contact form to send an enquiry.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/engage" class="btn btn--primary">
              Contact Lavelle Pty Ltd <span class="btn__arrow">→</span>
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li><a href="/consulting"><span>Consulting services</span><span>→</span></a></li>
          <li><a href="/pmo-resources"><span>PMO Resources</span><span>→</span></a></li>
          <li><a href="/case-studies"><span>Case studies</span><span>→</span></a></li>
          <li><a href="/digital-assets"><span>Digital asset portfolio</span><span>→</span></a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
