---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PackPage from "../../components/PackPage.astro";
import { products } from "../../config/site";

const pack = products.projectRecoveryPack;
const checkoutUrl = pack.checkoutUrl || undefined;

const audience = [
  "Senior project managers who have taken over a stalled or failing program",
  "Program managers who need to present an honest recovery assessment to their executive",
  "PMO leads conducting a program health review",
  "External reviewers asked to assess a troubled technology program",
];

const problemStatement = [
  "Programs do not fail suddenly. They accumulate governance debt, missed commitments and eroded stakeholder confidence over months. By the time a program is formally in trouble, the underlying causes are usually several months old.",
  "This pack gives you the structure to do an honest diagnostic, communicate the findings clearly and present a recovery roadmap that a sceptical executive or steering committee will accept.",
];

const included = [
  {
    title: "Project Health Diagnostic",
    desc: "A structured assessment covering delivery confidence, governance health, stakeholder alignment, financial position and vendor performance.",
  },
  {
    title: "Recovery Assessment Workbook",
    desc: "A working document for recording findings, evidence and preliminary recommendations during the diagnostic phase.",
  },
  {
    title: "Stakeholder Reset Plan",
    desc: "Templates and guidance for resetting stakeholder expectations with precision and without destroying confidence.",
  },
  {
    title: "Exception Report - Executive Reset",
    desc: "A template for the first Project Board (steering committee) meeting after a recovery intervention. Covers current state, recovery approach and decisions required.",
  },
  {
    title: "Exception Plan - Re-baselined Roadmap",
    desc: "The PRINCE2 Exception Plan - a structured template for presenting a recovery plan with credible milestones, dependencies and success criteria.",
  },
  {
    title: "Vendor Remediation Plan",
    desc: "A structured approach to documenting vendor performance issues and the agreed remediation actions.",
  },
  {
    title: "Risk Register Re-baselining Workbook",
    desc: "A workbook for rebuilding the PRINCE2 Risk Register from scratch after a recovery assessment.",
  },
  {
    title: "30 / 60 / 90 Day Recovery Plan",
    desc: "A structured planning template for the immediate, short-term and medium-term recovery phases.",
  },
  {
    title: "Project Board Recovery Pack",
    desc: "A complete reporting reset for the Project Board (steering committee), including revised Highlight Report template and updated tolerance thresholds.",
  },
];

const howToUse = [
  {
    title: "Start with the health diagnostic",
    desc: "Work through each dimension, document the findings honestly and use the output to prepare the stakeholder reset plan.",
  },
  {
    title: "Present the reset before the roadmap",
    desc: "Do not present the recovery roadmap until stakeholders have a shared understanding of the current state. Reset first; replan second.",
  },
];

const stats = [
  { num: `${included.length}`, label: "Artefacts included" },
  { num: `$${pack.price}`, label: "Single-user · AUD" },
  { num: "Word + Excel", label: "Editable, all formats" },
  { num: "G2-G5", label: "Reapplied across stabilisation" },
];

const faqs = [
  {
    q: "What format are the templates in?",
    a: "Microsoft Word (.docx) and Excel (.xlsx). All documents are fully editable and work in Google Docs and Google Sheets, though some conditional formatting may not carry across.",
  },
  {
    q: "Do I use all 9 documents at once?",
    a: "No. Start with the health diagnostic and recovery assessment workbook. The remaining documents are deployed progressively as you move through the stakeholder reset, replanning and governance stages.",
  },
  {
    q: "Is this for a first-time recovery manager?",
    a: "It is designed for experienced project managers who understand program governance. The pack provides structure and artefacts, not a substitute for delivery experience.",
  },
  {
    q: "Can I use it for a non-technology program?",
    a: "Yes. The pack uses delivery-neutral language and works across technology, business change, infrastructure and regulatory programs.",
  },
  {
    q: "Can I share this with my team?",
    a: "Your purchase gives you a single-user licence. For multi-seat access across a team or practice, see the <a href=\"/resources/complete-practitioner-library\">Complete Practitioner Library</a> - a named-user licence that covers every pack, every bundle and twelve months of artefact updates.",
  },
  {
    q: "What if I need expert support during a recovery?",
    a: "Lavelle Pty Ltd provides project recovery consulting and senior delivery advisory. See the consulting page or contact us directly.",
  },
];
---

<BaseLayout
  title="Project Recovery Pack - Lavelle Pty Ltd"
  description="A practical template pack for project managers and delivery leads who need to regain control of a project, clarify the recovery path and give sponsors confidence in the plan."
>
  {
    checkoutUrl && (
      <script src="https://assets.lemonsqueezy.com/lemon.js" defer />
    )
  }

  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/resources">Resources</a> &nbsp;/&nbsp;
        <span>Project Recovery Pack</span>
      </div>
      <div class="eyebrow">Project Recovery Pack</div>
      <h1 style="margin-top:1rem;">
        For programs <em>in trouble.</em>
      </h1>
      <p class="subhero__lead">
        A practical template pack for project managers and delivery leads who
        need to regain control of a project, clarify the recovery path and give
        sponsors confidence in the plan.
      </p>
    </div>
  </section>

  <PackPage
    packName="Project Recovery Pack"
    packSlug="project-recovery-pack"
    price={pack.price}
    checkoutUrl={checkoutUrl}
    gaLabel="Project Recovery Pack"
    stats={stats}
    audience={audience}
    problemStatement={problemStatement}
    included={included}
    howToUse={howToUse}
    faqs={faqs}
    roiBlock="About two and a half days of senior PM work - $3,750 of bespoke artefact development at $1,500/day contractor rates. Pack: $1,247. ROI: ~3×. The opinionated thinking and the framework lineage are the part you can't outsource."
    relatedConsultingHref="/consulting#recovery"
    relatedConsultingLabel="View recovery consulting"
    framework={{
      stage: "Spans the framework (consulting offer, not a stage)",
      gate: "Reapplied across G2-G5 during stabilisation",
    }}
    extraSidecard={{
      heading: "Start with the free checklist",
      text: "The free Project Recovery Checklist is a good starting point before committing to the full pack.",
      href: "/free-tools/project-recovery-checklist",
      cta: "View free checklist",
    }}
  />
</BaseLayout>
