---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Checklist on its way — Lavelle Pty Ltd"
  description="Your free Project Recovery Checklist is on its way to your inbox."
>
  <section style="padding: clamp(5rem, 10vw, 8rem) 0;">
    <div class="wrap" style="max-width:640px; text-align:center;">
      <div class="eyebrow" style="display:inline-block;">Checklist on its way</div>
      <h1 style="font-size:var(--display-md); font-weight:400; margin:1.5rem 0 1rem;">
        Thank you. <em>Check your inbox.</em>
      </h1>
      <p class="lead" style="margin: 0 auto 2.5rem;">
        The Project Recovery Checklist is heading to your inbox. Check your spam folder if it doesn't arrive within a few minutes.
      </p>
      <div class="hero__ctas" style="justify-content:center;">
        <a href="/free-tools/project-recovery-checklist" class="btn btn--primary">
          View the checklist online <span class="btn__arrow">→</span>
        </a>
        <a href="/pmo-resources" class="btn btn--ghost">Browse PMO Resources</a>
      </div>
    </div>
  </section>
</BaseLayout>
