---
import BaseLayout from '../../layouts/BaseLayout.astro';

const coverage = [
  { area: 'Scope', detail: 'Is scope documented, agreed and baselined? Are change requests being managed?' },
  { area: 'Governance', detail: 'Is the project authority structure clear? Are steering committee roles defined?' },
  { area: 'Schedule', detail: 'Is there a current, realistic delivery roadmap? Are dependencies tracked?' },
  { area: 'Risks', detail: 'Is there a current risk register? Are high risks escalated and being managed?' },
  { area: 'Issues', detail: 'Are issues logged and owned? Are blockers being escalated appropriately?' },
  { area: 'Decisions', detail: 'Is there a decision log? Are pending decisions clearly documented and escalated?' },
  { area: 'Financials', detail: 'Is spend tracked against budget? Is the financial forecast up to date?' },
  { area: 'Stakeholder alignment', detail: 'Are sponsor and key stakeholders aligned on current state and recovery path?' },
];

const audience = [
  'Senior project managers who have taken over a stalled or failing program',
  'Program managers preparing an honest assessment for their executive sponsor',
  'PMO leads conducting a program health review',
  'Delivery leaders who need to identify the gaps before starting a recovery',
];
---

<BaseLayout
  title="Free Project Recovery Checklist — Lavelle Pty Ltd"
  description="A structured checklist for identifying whether a project has the basic controls needed to recover delivery confidence."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/free-tools">Free Tools</a> &nbsp;/&nbsp; <span>Project Recovery Checklist</span>
      </div>
      <h1>The Project Recovery Checklist. <em>Free.</em></h1>
      <p class="subhero__lead">
        A structured checklist for identifying whether a project has the basic controls needed to recover delivery confidence. Covers scope, governance, schedule, risks, issues, decisions, financials and stakeholder alignment.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="split">
        <div class="prose">
          <p>
            The Project Recovery Checklist helps identify whether a project has the basic controls needed to recover delivery confidence, including scope, governance, schedule, risks, issues, decisions, financials and stakeholder alignment.
          </p>

          <h2 style="margin-top:2.5rem;">What the checklist covers</h2>

          <div class="coverage-grid">
            {coverage.map((item) => (
              <div class="coverage-card">
                <h3>{item.area}</h3>
                <p>{item.detail}</p>
              </div>
            ))}
          </div>

          <h2 style="margin-top:2.5rem;">Who it is for</h2>
          <ul>
            {audience.map((line) => <li>{line}</li>)}
          </ul>

          <div class="cta-card">
            <div class="eyebrow">Request the checklist</div>
            <h3 style="font-family:'Fraunces',serif; font-size:1.5rem; font-weight:500; margin:1rem 0 0.75rem;">
              Send me the checklist
            </h3>
            <p style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1.5rem;">
              Use the contact form to request the checklist. Select "PMO Resources" as the enquiry type and mention the Project Recovery Checklist.
            </p>
            <a href="/engage" class="btn btn--primary" data-ga-event="free_tool_request" data-ga-label="Project Recovery Checklist">
              Request the checklist <span class="btn__arrow">→</span>
            </a>
          </div>
        </div>

        <aside class="sidecard">
          <h4>Free resource</h4>
          <p style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1.5rem;">
            This checklist is available free of charge from Lavelle Pty Ltd.
          </p>
          <a href="/engage" class="btn btn--primary" data-ga-event="free_tool_request">
            Request the checklist
          </a>
          <h4 style="margin-top:2rem;">Need more?</h4>
          <p style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1rem;">
            The Project Recovery Pack includes the full set of artefacts for a structured recovery.
          </p>
          <a href="/templates/project-recovery-pack" class="cap__link">View Project Recovery Pack <span>→</span></a>
          <h4 style="margin-top:2rem;">All free tools</h4>
          <a href="/free-tools" class="cap__link">Browse free resources <span>→</span></a>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .coverage-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 600px) {
    .coverage-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .coverage-card {
    background: var(--bone);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--ochre);
    padding: 1rem 1.25rem;
  }
  .coverage-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.4rem;
    color: var(--ink);
  }
  .coverage-card p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: none;
  }
  .cta-card {
    background: var(--ink);
    color: var(--bone);
    padding: 2rem;
    margin-top: 2.5rem;
  }
  .cta-card .eyebrow {
    color: var(--ochre);
    border-color: var(--ochre);
  }
  .cta-card .btn--primary {
    background: var(--ochre);
    color: var(--bone);
  }
  .cta-card .btn--primary:hover {
    background: var(--bone);
    color: var(--ink);
  }
</style>
