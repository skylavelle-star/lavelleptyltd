---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../config/site";

const coverage = [
  {
    area: "Scope",
    detail:
      "Is scope documented, agreed and baselined? Are change requests being managed?",
  },
  {
    area: "Governance",
    detail:
      "Is the project authority structure clear? Are steering committee roles defined?",
  },
  {
    area: "Schedule",
    detail:
      "Is there a current, realistic delivery roadmap? Are dependencies tracked?",
  },
  {
    area: "Risks",
    detail:
      "Is there a current risk register? Are high risks escalated and being managed?",
  },
  {
    area: "Issues",
    detail:
      "Are issues logged and owned? Are blockers being escalated appropriately?",
  },
  {
    area: "Decisions",
    detail:
      "Is there a decision log? Are pending decisions clearly documented and escalated?",
  },
  {
    area: "Financials",
    detail:
      "Is spend tracked against budget? Is the financial forecast up to date?",
  },
  {
    area: "Stakeholder alignment",
    detail:
      "Are sponsor and key stakeholders aligned on current state and recovery path?",
  },
];

const audience = [
  "Senior project managers who have taken over a stalled or failing program",
  "Program managers preparing an honest assessment for their executive sponsor",
  "PMO leads conducting a program health review",
  "Delivery leaders who need to identify the gaps before starting a recovery",
];
---

<BaseLayout
  title="Free Project Recovery Checklist - Lavelle Pty Ltd"
  description="A structured checklist for identifying whether a project has the basic controls needed to recover delivery confidence."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/free-tools">Free Tools</a> &nbsp;/&nbsp;
        <span>Project Recovery Checklist</span>
      </div>
      <h1>The Project Recovery Checklist. <em>Free.</em></h1>
      <p class="subhero__lead">
        A structured checklist for identifying whether a project has the basic
        controls needed to recover delivery confidence. Covers scope,
        governance, schedule, risks, issues, decisions, financials and
        stakeholder alignment.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="split">
        <div class="prose">
          <p>
            The Project Recovery Checklist helps identify whether a project has
            the basic controls needed to recover delivery confidence, including
            scope, governance, schedule, risks, issues, decisions, financials
            and stakeholder alignment.
          </p>

          <h2 style="margin-top:2.5rem;">What the checklist covers</h2>

          <div class="coverage-grid">
            {
              coverage.map((item) => (
                <div class="coverage-card">
                  <h3>{item.area}</h3>
                  <p>{item.detail}</p>
                </div>
              ))
            }
          </div>

          <h2 style="margin-top:2.5rem;">Who it is for</h2>
          <ul>
            {audience.map((line) => <li>{line}</li>)}
          </ul>

          <div class="cta-card">
            <div class="eyebrow">Request the checklist</div>
            <h3
              style="font-family:'Fraunces',serif; font-size:1.5rem; font-weight:500; margin:1rem 0 0.75rem;"
            >
              Send me the checklist
            </h3>
            <p
              style="font-size:var(--body-sm); color:rgba(244,239,230,0.78); margin-bottom:1.5rem;"
            >
              Enter your name and work email. We'll send the PDF and one email a
              fortnight with new field notes. Unsubscribe anytime.
            </p>
            <form
              id="recovery-form"
              action="https://api.web3forms.com/submit"
              method="POST"
              novalidate
            >
              <input
                type="hidden"
                name="access_key"
                value={site.web3formsKey}
              />
              <input
                type="hidden"
                name="subject"
                value="Project Recovery Checklist request - lavelleptyltd.com.au"
              />
              <input
                type="hidden"
                name="from_name"
                value="Lavelle Pty Ltd Free Tools"
              />
              <input
                type="checkbox"
                name="botcheck"
                style="display:none;"
                tabindex="-1"
                autocomplete="off"
              />
              <label
                for="recovery-name"
                style="display:block; font-size:var(--micro); letter-spacing:0.15em; text-transform:uppercase; color:rgba(244,239,230,0.7); margin-bottom:0.5rem;"
              >
                First name
              </label>
              <input
                id="recovery-name"
                name="name"
                type="text"
                required
                autocomplete="given-name"
                placeholder="Your name"
                style="width:100%; padding:0.75rem 0.9rem; border:1px solid rgba(244,239,230,0.3); background:transparent; color:var(--bone); font-family:inherit; font-size:var(--body-sm); margin-bottom:1rem;"
              />
              <label
                for="recovery-email"
                style="display:block; font-size:var(--micro); letter-spacing:0.15em; text-transform:uppercase; color:rgba(244,239,230,0.7); margin-bottom:0.5rem;"
              >
                Work email
              </label>
              <input
                id="recovery-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="you@organisation.gov.au"
                style="width:100%; padding:0.75rem 0.9rem; border:1px solid rgba(244,239,230,0.3); background:transparent; color:var(--bone); font-family:inherit; font-size:var(--body-sm); margin-bottom:1.25rem;"
              />
              <button
                id="recovery-submit"
                type="submit"
                class="btn btn--primary"
                data-ga-event="free_tool_request"
                data-ga-label="Project Recovery Checklist"
              >
                Send me the checklist <span class="btn__arrow">→</span>
              </button>
            </form>
            <p
              id="recovery-success"
              hidden
              style="font-size:var(--body-sm); color:rgba(244,239,230,0.85); margin-top:1rem;"
            >
              Thanks - the checklist is on the way. If it doesn't land in a few
              minutes, check your spam folder.
            </p>
          </div>
        </div>

        <aside class="sidecard">
          <h4>Free resource</h4>
          <p
            style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1.5rem;"
          >
            This checklist is available free of charge from Lavelle Pty Ltd.
            Fill in the form opposite and we'll email it to you.
          </p>
          <h4 style="margin-top:2rem;">Need more?</h4>
          <p
            style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1rem;"
          >
            The Project Recovery Pack includes the full set of artefacts for a
            structured recovery.
          </p>
          <a href="/templates/project-recovery-pack" class="cap__link"
            >View Project Recovery Pack <span>→</span></a
          >
          <h4 style="margin-top:2rem;">All free tools</h4>
          <a href="/free-tools" class="cap__link"
            >Browse free resources <span>→</span></a
          >
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .coverage-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 600px) {
    .coverage-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .coverage-card {
    background: var(--bone);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--ochre);
    padding: 1rem 1.25rem;
  }
  .coverage-card h3 {
    font-family: "Fraunces", serif;
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.4rem;
    color: var(--ink);
  }
  .coverage-card p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: none;
  }
  .cta-card {
    background: var(--ink);
    color: var(--bone);
    padding: 2rem;
    margin-top: 2.5rem;
  }
  .cta-card .eyebrow {
    color: var(--ochre);
    border-color: var(--ochre);
  }
  .cta-card .btn--primary {
    background: var(--ochre);
    color: var(--bone);
  }
  .cta-card .btn--primary:hover {
    background: var(--bone);
    color: var(--ink);
  }
</style>

<script>
  const form = document.getElementById(
    "recovery-form",
  ) as HTMLFormElement | null;
  const success = document.getElementById("recovery-success");
  const submitBtn = document.getElementById(
    "recovery-submit",
  ) as HTMLButtonElement | null;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const botcheck =
        form.querySelector<HTMLInputElement>('[name="botcheck"]');
      if (botcheck?.checked) return;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending…";
      }
      let ok = false;
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(
            Object.fromEntries(new FormData(form).entries()),
          ),
        });
        const data = (await res.json().catch(() => ({}))) as {
          success?: boolean;
        };
        ok = data.success === true;
      } catch {
        /* silent */
      }
      if (ok) {
        form.hidden = true;
        if (success) success.hidden = false;
      } else if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML =
          'Send me the checklist <span class="btn__arrow">→</span>';
      }
    });
  }
</script>
