---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import engageImage from "../assets/images/engage-boardroom.jpg";
import { site } from "../config/site";

// TODO: Framework One-Page asset not yet uploaded.
// Replace this placeholder with the real PDF path once it exists in /public.
const frameworkOnePageHref = "/downloads/framework-one-page.pdf";

const supplementary = [
  {
    title: "Project Recovery Checklist",
    status: "available" as const,
    short:
      "One-page checklist for taking over a project that needs stabilising. Free PDF.",
    detail:
      "Covers scope, governance, schedule, risks, issues, decisions, financials and stakeholder alignment.",
    href: "/free-tools/project-recovery-checklist",
    notifyId: null,
  },
  {
    title: "Highlight Report Template",
    status: "coming" as const,
    short:
      "Editable PRINCE2 Highlight Report template with RAG ratings and standard sections. Free download.",
    detail:
      "Covers delivery status, RAID summary, financials, decisions required and next actions.",
    href: null,
    notifyId: "notify-sc-status-report",
    subject:
      "Interest: Highlight Report Template - lavelleptyltd.com.au",
    message:
      "Interested in the Highlight Report Template when available.",
  },
  {
    title: "Business Case One-Pager",
    status: "coming" as const,
    short:
      "Single-page business case framework for early-stage proposals. Free download.",
    detail:
      "Covers problem statement, options summary, expected benefits, indicative cost and recommended next step.",
    href: null,
    notifyId: "notify-bc-one-pager",
    subject: "Interest: Business Case One-Pager - lavelleptyltd.com.au",
    message: "Interested in the Business Case One-Pager when available.",
  },
];
---

<BaseLayout
  title="Free Tools - Lavelle Pty Ltd"
  description="Free practitioner tools from Lavelle Pty Ltd. The ungated Framework One-Page, the email-gated Project Tailoring Calculator and supplementary downloads for delivery leads."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Free Tools</span>
      </div>
      <div class="eyebrow">Free tools</div>
      <h1 style="margin-top:1rem;">
        Two lead tools. <em>Plus supplementary downloads.</em>
      </h1>
      <p class="subhero__lead">
        The Framework One-Page (ungated) explains how the Lavelle Delivery
        Framework names stages, gates and paths. The Project Tailoring
        Calculator (email-gated) scores a project and routes you to the
        matching bundle. Other downloads sit below.
      </p>
    </div>
  </section>

  <!-- FRAMEWORK ONE-PAGE: UNGATED -->
  <section id="framework-one-page">
    <div class="wrap" style="max-width:64rem;">
      <header class="section__head">
        <div>
          <div class="eyebrow">Ungated · free</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            The Framework <em>One-Page.</em>
          </h2>
        </div>
        <p class="lead">
          The single-slide visual version of the Lavelle Delivery Framework.
          Seven stages, six gates, three paths - on one page. No email
          required.
        </p>
      </header>

      <div class="onepage-card">
        <div>
          <h3>Framework One-Page</h3>
          <p>
            What the framework names. How the stages connect to the gates.
            Where the three paths (predictive, iterative, hybrid) sit. The
            single page you can pin to the wall behind the SteerCo.
          </p>
        </div>
        <a
          href={frameworkOnePageHref}
          class="btn btn--primary"
          data-ga-event="free_tool_click"
          data-ga-label="Framework One-Page"
        >
          Download One-Page <span class="btn__arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- TAILORING CALCULATOR: EMAIL-GATED -->
  <section id="tailoring-calculator" style="background:var(--paper);">
    <div class="wrap" style="max-width:64rem;">
      <header class="section__head">
        <div>
          <div class="eyebrow">Email-gated · primary lead magnet</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            The Project Tailoring <em>Calculator.</em>
          </h2>
        </div>
        <p class="lead">
          Score your project across complexity, scrutiny, financial scale and
          stakeholder load. The calculator returns a tier (Light, Standard or
          Major) and routes you to the matching bundle. Email required.
        </p>
      </header>

      <form
        id="tailoring-calculator-form"
        class="calc-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
      >
        <input type="hidden" name="access_key" value={site.web3formsKey} />
        <input
          type="hidden"
          name="subject"
          value="Tailoring Calculator request - lavelleptyltd.com.au"
        />
        <input
          type="hidden"
          name="from_name"
          value="Lavelle Pty Ltd Tailoring Calculator"
        />
        <input
          type="checkbox"
          name="botcheck"
          class="calc-form__bot"
          tabindex="-1"
          autocomplete="off"
        />

        <div class="calc-form__row">
          <label for="calc-email">Your email</label>
          <input
            id="calc-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="your@email.com"
          />
        </div>

        <div class="calc-form__note">
          <strong>Note:</strong> the in-page scoring logic is being finalised.
          Submit your email below and we will send you the calculator
          workbook plus a recommendation based on the four answers above.
          <span class="todo">(TODO: replace with in-page scoring + bundle routing.)</span>
        </div>

        <button type="submit" class="btn btn--primary calc-form__submit">
          Send me the calculator <span class="btn__arrow">→</span>
        </button>

        <p id="calc-form-success" class="calc-form__success" hidden>
          Done - we will email you the calculator and a tier recommendation
          within one business day.
        </p>
      </form>

      <div class="calc-form__bundles">
        <p>While you wait, you can see the three tiered bundles directly:</p>
        <div class="calc-form__bundle-links">
          <a href="/bundles/tier-3-light">Tier 3 Light (score 7-14)</a>
          <a href="/bundles/tier-2-standard">Tier 2 Standard (score 15-24)</a>
          <a href="/bundles/tier-1-major">Tier 1 Major (score 25-35)</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SUPPLEMENTARY DOWNLOADS -->
  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Supplementary downloads</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Other practical <em>tools.</em>
          </h2>
        </div>
        <p class="lead">
          Stand-alone resources that sit outside the Framework One-Page and
          Tailoring Calculator. Free where available; the rest pair with a
          notify-me form, so you hear about them the moment they ship.
        </p>
      </header>

      <div class="tool-grid">
        {
          supplementary.map((tool) => (
            <article class="tool-card">
              <div class="tool-card__head">
                <h3>{tool.title}</h3>
                <span class={`tool-tag tool-tag--${tool.status}`}>
                  {tool.status === "available" ? "Free" : "In development"}
                </span>
              </div>
              <p class="tool-card__short">{tool.short}</p>
              <p class="tool-card__detail">{tool.detail}</p>
              {tool.status === "available" && tool.href ? (
                <a
                  href={tool.href}
                  class="btn btn--primary"
                  style="margin-top:auto;"
                  data-ga-event="free_tool_click"
                  data-ga-label={tool.title}
                >
                  Get the checklist <span class="btn__arrow">→</span>
                </a>
              ) : (
                <form
                  data-notify-form={tool.notifyId}
                  class="tool-notify"
                  novalidate
                >
                  <input
                    type="hidden"
                    name="access_key"
                    value={site.web3formsKey}
                  />
                  <input type="hidden" name="subject" value={tool.subject} />
                  <input
                    type="hidden"
                    name="from_name"
                    value="Lavelle Pty Ltd Free Tools"
                  />
                  <input type="hidden" name="message" value={tool.message} />
                  <input
                    type="checkbox"
                    name="botcheck"
                    class="hidden-bot"
                    tabindex="-1"
                    autocomplete="off"
                  />
                  <label for={`${tool.notifyId}-email`}>
                    Get notified when it ships
                  </label>
                  <div class="tool-notify__row">
                    <input
                      id={`${tool.notifyId}-email`}
                      type="email"
                      name="email"
                      required
                      placeholder="your@email.com"
                      autocomplete="email"
                    />
                    <button type="submit" class="btn btn--ghost">
                      Notify me
                    </button>
                  </div>
                  <p
                    id={`notify-success-${tool.notifyId}`}
                    class="tool-notify__success"
                    hidden
                  >
                    Done - we will email you when it ships.
                  </p>
                </form>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="engage engage--imaged">
    <figure class="engage__bg" aria-hidden="true">
      <Image
        src={engageImage}
        alt=""
        widths={[960, 1440, 1920, 2400]}
        sizes="100vw"
        loading="lazy"
        decoding="async"
        class="engage__bg-img"
      />
    </figure>
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Need more structure?</div>
          <h2 style="margin-top:1.25rem;">
            When the free tools <em>aren't enough.</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            The paid stage-based packs and tier-based bundles include the
            full artefact set, working documents and structured guidance.
            Consulting picks up where templates leave off.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/templates" class="btn btn--primary">
              Browse Templates <span class="btn__arrow">→</span>
            </a>
            <a href="/consulting" class="btn btn--ghost">
              See consulting
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .onepage-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--bone);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--ochre);
    align-items: center;
  }
  @media (min-width: 760px) {
    .onepage-card {
      grid-template-columns: 1fr auto;
      gap: 2rem;
    }
  }
  .onepage-card h3 {
    font-family: "Fraunces", serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.5rem;
  }
  .onepage-card p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
    max-width: 56ch;
  }

  .calc-form {
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2.5rem;
    background: var(--bone);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--ochre);
  }
  .calc-form__row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .calc-form label {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 500;
  }
  .calc-form input {
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-family: inherit;
    font-size: var(--body-sm);
    color: var(--ink);
  }
  .calc-form input:focus {
    outline: none;
    border-color: var(--ochre);
  }
  .calc-form__bot {
    display: none;
  }
  .calc-form__note {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.6;
    padding: 1rem 1.25rem;
    background: var(--paper);
    border: 1px solid var(--rule);
  }
  .calc-form__note .todo {
    display: block;
    margin-top: 0.5rem;
    color: var(--ochre);
    font-style: italic;
  }
  .calc-form__submit {
    align-self: flex-start;
  }
  .calc-form__success {
    font-size: var(--body-sm);
    color: var(--ochre);
    margin: 0;
  }
  .calc-form__success[hidden] {
    display: none;
  }
  .calc-form__bundles {
    margin-top: 2rem;
    font-size: var(--body-sm);
    color: var(--ink-soft);
  }
  .calc-form__bundle-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .calc-form__bundle-links a {
    color: var(--ochre);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 760px) {
    .tool-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .tool-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tool-card {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: all 0.25s;
  }
  .tool-card:hover {
    border-color: var(--ink);
  }
  .tool-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .tool-card__head h3 {
    font-family: "Fraunces", serif;
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
  }
  .tool-tag {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .tool-tag--available {
    color: var(--ochre);
    border: 1px solid var(--ochre);
  }
  .tool-tag--coming {
    color: var(--sage);
    border: 1px solid var(--rule);
  }
  .tool-card__short {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: none;
  }
  .tool-card__detail {
    font-size: var(--micro);
    color: var(--sage);
    line-height: 1.55;
    flex-grow: 1;
    max-width: none;
  }
  .tool-notify {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tool-notify label {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 500;
  }
  .tool-notify__row {
    display: flex;
    gap: 0.5rem;
  }
  .tool-notify input[type="email"] {
    flex: 1;
    min-width: 0;
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--rule);
    background: var(--bone);
    font-family: inherit;
    font-size: var(--body-sm);
  }
  .tool-notify input[type="email"]:focus {
    outline: none;
    border-color: var(--ochre);
  }
  .tool-notify .btn {
    padding: 0.55rem 1rem;
    font-size: var(--micro);
  }
  .tool-notify__success {
    font-size: var(--body-sm);
    color: var(--ochre);
  }
  .tool-notify__success[hidden] {
    display: none;
  }
  .hidden-bot {
    display: none;
  }
</style>

<script>
  // Tailoring Calculator form (gated)
  const calcForm = document.getElementById(
    "tailoring-calculator-form",
  ) as HTMLFormElement | null;
  if (calcForm) {
    calcForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!calcForm.checkValidity()) {
        calcForm.reportValidity();
        return;
      }
      const botcheck =
        calcForm.querySelector<HTMLInputElement>('[name="botcheck"]');
      if (botcheck?.checked) return;
      const submit = calcForm.querySelector<HTMLButtonElement>(
        ".calc-form__submit",
      );
      if (submit) {
        submit.disabled = true;
        submit.textContent = "Sending…";
      }
      let ok = false;
      try {
        const res = await fetch(calcForm.action, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(
            Object.fromEntries(new FormData(calcForm).entries()),
          ),
        });
        const data = (await res.json().catch(() => ({}))) as {
          success?: boolean;
        };
        ok = data.success === true;
      } catch {
        /* silent */
      }
      if (ok) {
        calcForm
          .querySelectorAll<HTMLElement>("input, button, label, .calc-form__note")
          .forEach((el) => {
            el.hidden = true;
          });
        const success = document.getElementById("calc-form-success");
        if (success) success.hidden = false;
      } else if (submit) {
        submit.disabled = false;
        submit.innerHTML =
          'Send me the calculator <span class="btn__arrow">→</span>';
      }
    });
  }

  // Supplementary notify forms
  document
    .querySelectorAll<HTMLFormElement>("[data-notify-form]")
    .forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const id = form.dataset.notifyForm!;
        const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
        const botcheck =
          form.querySelector<HTMLInputElement>('[name="botcheck"]');
        if (botcheck?.checked) return;
        if (btn) {
          btn.disabled = true;
          btn.textContent = "Sending…";
        }
        let ok = false;
        try {
          const res = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(
              Object.fromEntries(new FormData(form).entries()),
            ),
          });
          const data = (await res.json().catch(() => ({}))) as {
            success?: boolean;
          };
          ok = data.success === true;
        } catch {
          /* silent */
        }
        if (ok) {
          form
            .querySelectorAll("input, button, label, .tool-notify__row")
            .forEach((el) => {
              (el as HTMLElement).hidden = true;
            });
          const success = document.getElementById(`notify-success-${id}`);
          if (success) success.hidden = false;
        } else if (btn) {
          btn.disabled = false;
          btn.textContent = "Notify me";
        }
      });
    });
</script>
