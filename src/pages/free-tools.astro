---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const tools = [
  {
    title: 'Project Recovery Checklist',
    status: 'available' as const,
    short: 'One-page checklist for taking over a project that needs stabilising. Free PDF.',
    detail: 'Covers scope, governance, schedule, risks, issues, decisions, financials and stakeholder alignment.',
    href: '/free-tools/project-recovery-checklist',
    notifyId: null,
  },
  {
    title: 'Steering Committee Status Report Template',
    status: 'coming' as const,
    short: 'Editable status report template with RAG ratings and standard sections. Free download.',
    detail: 'Covers delivery status, RAID summary, financials, decisions required and next actions.',
    href: null,
    notifyId: 'notify-sc-status-report',
    subject: 'Interest: Steering Committee Status Report Template - lavelleptyltd.com.au',
    message: 'Interested in the Steering Committee Status Report Template when available.',
  },
  {
    title: 'Business Case One-Pager',
    status: 'coming' as const,
    short: 'Single-page business case framework for early-stage proposals. Free download.',
    detail: 'Covers problem statement, options summary, expected benefits, indicative cost and recommended next step.',
    href: null,
    notifyId: 'notify-bc-one-pager',
    subject: 'Interest: Business Case One-Pager - lavelleptyltd.com.au',
    message: 'Interested in the Business Case One-Pager when available.',
  },
];
---

<BaseLayout
  title="Free PMO Tools — Lavelle Pty Ltd"
  description="Free PMO tools, checklists and project delivery resources from Lavelle Pty Ltd. Practical tools for project managers and delivery leads."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Free Tools</span>
      </div>
      <h1>Free, practical tools. <em>For delivery leads.</em></h1>
      <p class="subhero__lead">
        Each tool stands alone, requires only your email and links to the relevant paid resource for teams that need a deeper structure.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Available</div>
          <h2 class="section__title" style="margin-top:1.25rem;">Free <em>resources.</em></h2>
        </div>
        <p class="lead">
          Tools that live alongside the paid PMO Resource packs. Use them on their own, or as the starter version of the more comprehensive packs.
        </p>
      </header>

      <div class="tool-grid">
        {tools.map((tool) => (
          <article class="tool-card">
            <div class="tool-card__head">
              <h3>{tool.title}</h3>
              <span class={`tool-tag tool-tag--${tool.status}`}>
                {tool.status === 'available' ? 'Free' : 'In development'}
              </span>
            </div>
            <p class="tool-card__short">{tool.short}</p>
            <p class="tool-card__detail">{tool.detail}</p>
            {tool.status === 'available' && tool.href ? (
              <a href={tool.href} class="btn btn--primary" style="margin-top:auto;" data-ga-event="free_tool_click" data-ga-label={tool.title}>
                Get the checklist <span class="btn__arrow">→</span>
              </a>
            ) : (
              <form data-notify-form={tool.notifyId} class="tool-notify" novalidate>
                <input type="hidden" name="access_key" value={site.web3formsKey} />
                <input type="hidden" name="subject" value={tool.subject} />
                <input type="hidden" name="from_name" value="Lavelle Pty Ltd Free Tools" />
                <input type="hidden" name="message" value={tool.message} />
                <input type="checkbox" name="botcheck" class="hidden-bot" tabindex="-1" autocomplete="off" />
                <label for={`${tool.notifyId}-email`}>Get notified when it ships</label>
                <div class="tool-notify__row">
                  <input id={`${tool.notifyId}-email`} type="email" name="email" required placeholder="your@email.com" autocomplete="email" />
                  <button type="submit" class="btn btn--ghost">Notify me</button>
                </div>
                <p id={`notify-success-${tool.notifyId}`} class="tool-notify__success" hidden>
                  Done — we will email you when it ships.
                </p>
              </form>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">More than a checklist?</div>
          <h2 style="margin-top:1.25rem;">When the checklist <em>isn't enough.</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            Lavelle Pty Ltd template packs include the full artefacts, working documents and structured guidance for each delivery challenge.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/pmo-resources" class="btn btn--primary">View PMO Resources <span class="btn__arrow">→</span></a>
            <a href="/consulting" class="btn" style="background:transparent; color:var(--bone); border:1px solid var(--bone);">View consulting</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tool-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 760px) {
    .tool-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .tool-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tool-card {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: all 0.25s;
  }
  .tool-card:hover {
    border-color: var(--ink);
  }
  .tool-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .tool-card__head h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
  }
  .tool-tag {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .tool-tag--available {
    color: var(--ochre);
    border: 1px solid var(--ochre);
  }
  .tool-tag--coming {
    color: var(--sage);
    border: 1px solid var(--rule);
  }
  .tool-card__short {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: none;
  }
  .tool-card__detail {
    font-size: var(--micro);
    color: var(--sage);
    line-height: 1.55;
    flex-grow: 1;
    max-width: none;
  }
  .tool-notify {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tool-notify label {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 500;
  }
  .tool-notify__row {
    display: flex;
    gap: 0.5rem;
  }
  .tool-notify input[type="email"] {
    flex: 1;
    min-width: 0;
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--rule);
    background: var(--bone);
    font-family: inherit;
    font-size: var(--body-sm);
  }
  .tool-notify input[type="email"]:focus {
    outline: none;
    border-color: var(--ochre);
  }
  .tool-notify .btn {
    padding: 0.55rem 1rem;
    font-size: var(--micro);
  }
  .tool-notify__success {
    font-size: var(--body-sm);
    color: var(--ochre);
  }
  .tool-notify__success[hidden] {
    display: none;
  }
  .hidden-bot {
    display: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-notify-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const id = form.dataset.notifyForm!;
      const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
      const botcheck = form.querySelector<HTMLInputElement>('[name="botcheck"]');
      if (botcheck?.checked) return;
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Sending…';
      }
      let ok = false;
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form).entries())),
        });
        const data = (await res.json().catch(() => ({}))) as { success?: boolean };
        ok = data.success === true;
      } catch {
        /* silent */
      }
      if (ok) {
        form.querySelectorAll('input, button, label, .tool-notify__row').forEach((el) => {
          (el as HTMLElement).hidden = true;
        });
        const success = document.getElementById(`notify-success-${id}`);
        if (success) success.hidden = false;
      } else if (btn) {
        btn.disabled = false;
        btn.textContent = 'Notify me';
      }
    });
  });
</script>
