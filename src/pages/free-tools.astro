---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Free PMO Tools | Lavelle Pty Ltd"
  description="Free PMO tools, checklists and project delivery resources from Lavelle Pty Ltd. Practical tools for project managers and delivery leads."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Free Tools</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Free, practical tools for project managers and delivery leads. Each tool stands alone, requires only your email and links to the relevant paid resource for teams that need a deeper structure.
        </p>
      </div>
    </div>
  </section>

  <!-- FREE TOOLS LIST -->
  <section class="section">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-600 uppercase tracking-wider mb-3">Available Now</p>
        <h2 class="text-2xl text-slate-900">Free Resources</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Project Recovery Checklist -->
        <div class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white hover:border-navy-400 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-slate-900">Project Recovery Checklist</h3>
            <span class="shrink-0 inline-flex items-center px-2.5 py-1 text-xs font-medium text-emerald-700 bg-emerald-50 border border-emerald-200 rounded">
              Free
            </span>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-2">
            One-page checklist for taking over a project that needs stabilising. Free PDF.
          </p>
          <p class="text-xs text-slate-500 mb-5">
            Covers scope, governance, schedule, risks, issues, decisions, financials and stakeholder alignment.
          </p>
          <a
            href="/free-tools/project-recovery-checklist"
            class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-navy-700 hover:bg-navy-800 rounded-md transition-colors"
            data-ga-event="free_tool_click"
            data-ga-label="Project Recovery Checklist"
          >
            Get the Checklist
            <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Steering Committee Status Report Template -->
        <div class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white transition-all">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-slate-900">Steering Committee Status Report Template</h3>
            <span class="shrink-0 inline-flex items-center px-2.5 py-1 text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200 rounded">
              In development
            </span>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-2">
            Editable status report template with RAG ratings and standard sections. Free download.
          </p>
          <p class="text-xs text-slate-500 mb-5">
            Covers delivery status, RAID summary, financials, decisions required and next actions.
          </p>
          <form data-notify-form="notify-sc-status-report" novalidate class="space-y-2">
            <input type="hidden" name="access_key" value="21e468ca-496b-45eb-8313-d1b7d5d229c9" />
            <input type="hidden" name="subject" value="Interest: Steering Committee Status Report Template - lavelleptyltd.com.au" />
            <input type="hidden" name="from_name" value="Lavelle Pty Ltd Free Tools" />
            <input type="hidden" name="message" value="Interested in the Steering Committee Status Report Template when available." />
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
            <label for="sc-notify-email" class="block text-xs font-medium text-slate-700">Get notified when it ships</label>
            <div class="flex gap-2">
              <input
                id="sc-notify-email"
                type="email"
                name="email"
                required
                placeholder="your@email.com"
                autocomplete="email"
                class="flex-1 min-w-0 px-3 py-2 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent"
              />
              <button type="submit" class="shrink-0 px-3 py-2 text-sm font-medium text-white bg-navy-600 hover:bg-navy-700 rounded-md transition-colors">
                Notify me
              </button>
            </div>
          </form>
          <p id="notify-success-notify-sc-status-report" class="hidden text-sm text-emerald-700 font-medium mt-2">
            Done - we will email you when it ships.
          </p>
        </div>

        <!-- Business Case One-Pager -->
        <div class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white transition-all">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-slate-900">Business Case One-Pager</h3>
            <span class="shrink-0 inline-flex items-center px-2.5 py-1 text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200 rounded">
              In development
            </span>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-2">
            Single-page business case framework for early-stage proposals. Free download.
          </p>
          <p class="text-xs text-slate-500 mb-5">
            Covers problem statement, options summary, expected benefits, indicative cost and recommended next step.
          </p>
          <form data-notify-form="notify-bc-one-pager" novalidate class="space-y-2">
            <input type="hidden" name="access_key" value="21e468ca-496b-45eb-8313-d1b7d5d229c9" />
            <input type="hidden" name="subject" value="Interest: Business Case One-Pager - lavelleptyltd.com.au" />
            <input type="hidden" name="from_name" value="Lavelle Pty Ltd Free Tools" />
            <input type="hidden" name="message" value="Interested in the Business Case One-Pager when available." />
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
            <label for="bc-notify-email" class="block text-xs font-medium text-slate-700">Get notified when it ships</label>
            <div class="flex gap-2">
              <input
                id="bc-notify-email"
                type="email"
                name="email"
                required
                placeholder="your@email.com"
                autocomplete="email"
                class="flex-1 min-w-0 px-3 py-2 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent"
              />
              <button type="submit" class="shrink-0 px-3 py-2 text-sm font-medium text-white bg-navy-600 hover:bg-navy-700 rounded-md transition-colors">
                Notify me
              </button>
            </div>
          </form>
          <p id="notify-success-notify-bc-one-pager" class="hidden text-sm text-emerald-700 font-medium mt-2">
            Done - we will email you when it ships.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- TEMPLATES CTA -->
  <section style="background-color: #f3f4f6;" class="py-16 lg:py-24">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl text-slate-900 mb-3">Need More Than a Checklist?</h2>
        <p class="text-slate-600 leading-relaxed mb-6">
          Lavelle Pty Ltd template packs include the full artefacts, working documents and structured guidance for each delivery challenge.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/pmo-resources"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
          >
            View PMO Resources
          </a>
          <a
            href="/consulting"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 hover:border-slate-400 rounded-md transition-colors"
          >
            View Consulting Services
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-notify-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }
      const id = form.dataset.notifyForm!;
      const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
      const botcheck = form.querySelector<HTMLInputElement>('[name="botcheck"]');
      if (botcheck?.checked) return;
      if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }
      let ok = false;
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form).entries())),
        });
        const data = await res.json().catch(() => ({})) as { success?: boolean };
        ok = data.success === true;
      } catch { /* silent */ }
      if (ok) {
        form.classList.add('hidden');
        document.getElementById(`notify-success-${id}`)?.classList.remove('hidden');
      } else {
        if (btn) { btn.disabled = false; btn.textContent = 'Notify me'; }
      }
    });
  });
</script>
