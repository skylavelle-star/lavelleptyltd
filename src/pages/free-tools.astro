---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Free PMO Tools | Lavelle Pty Ltd"
  description="Free PMO tools, checklists and project delivery resources from Lavelle Pty Ltd. Practical tools for project managers and delivery leads."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Free Tools</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Free, practical tools for project managers and delivery leads. Each tool stands alone, requires only your email and links to the relevant paid resource for teams that need a deeper structure.
        </p>
      </div>
    </div>
  </section>

  <!-- FREE TOOLS LIST -->
  <section class="section">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-600 uppercase tracking-wider mb-3">Available Now</p>
        <h2 class="text-2xl text-slate-900">Free Resources</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Project Recovery Checklist -->
        <div class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white hover:border-navy-400 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-slate-900">Project Recovery Checklist</h3>
            <span class="shrink-0 inline-flex items-center px-2.5 py-1 text-xs font-medium text-emerald-700 bg-emerald-50 border border-emerald-200 rounded">
              Free
            </span>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-2">
            One-page checklist for taking over a project that needs stabilising. Free PDF.
          </p>
          <p class="text-xs text-slate-500 mb-5">
            Covers scope, governance, schedule, risks, issues, decisions, financials and stakeholder alignment.
          </p>
          <a
            href="/free-tools/project-recovery-checklist"
            class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-navy-700 hover:bg-navy-800 rounded-md transition-colors"
            data-ga-event="free_tool_click"
            data-ga-label="Project Recovery Checklist"
          >
            Get the Checklist
            <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Steering Committee Status Report Template -->
        <div class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white transition-all">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-slate-900">Steering Committee Status Report Template</h3>
            <span class="shrink-0 inline-flex items-center px-2.5 py-1 text-xs font-medium text-slate-500 bg-slate-100 border border-slate-200 rounded">
              Coming Soon
            </span>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-2">
            Editable status report template with RAG ratings and standard sections. Free download.
          </p>
          <p class="text-xs text-slate-500 mb-5">
            Covers delivery status, RAID summary, financials, decisions required and next actions.
          </p>
          <button
            type="button"
            data-notify-toggle="notify-sc-status-report"
            class="inline-flex items-center px-4 py-2 text-sm font-medium text-navy-600 border border-navy-300 hover:bg-navy-50 rounded-md transition-colors"
            aria-expanded="false"
            aria-controls="notify-panel-notify-sc-status-report"
          >
            Notify me when available
          </button>
          <div id="notify-panel-notify-sc-status-report" class="hidden mt-4 pt-4 border-t border-slate-100">
            <p class="text-xs font-medium text-slate-700 mb-2">Get notified when this becomes available.</p>
            <form data-notify-form="notify-sc-status-report" novalidate class="space-y-2">
              <input type="hidden" name="access_key" value="dc7b04fa-6e86-415e-8d01-1fe332b4bf21" />
              <input type="hidden" name="subject" value="Notify me: Steering Committee Status Report Template" />
              <input type="hidden" name="from_name" value="Lavelle Pty Ltd - Free Tools Notify Me" />
              <input type="hidden" name="message" value="Please notify me when the Steering Committee Status Report Template becomes available." />
              <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
              <div class="flex gap-2">
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="your@email.com"
                  class="flex-1 min-w-0 px-3 py-2 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent"
                />
                <button
                  type="submit"
                  class="shrink-0 px-3 py-2 text-sm font-medium text-white bg-navy-600 hover:bg-navy-700 rounded-md transition-colors"
                >
                  Notify me
                </button>
              </div>
              <p class="text-xs text-slate-400">No spam. Unsubscribe anytime.</p>
            </form>
            <p id="notify-success-notify-sc-status-report" class="hidden text-sm text-emerald-700 font-medium">
              You're on the list. We'll notify you when this becomes available.
            </p>
          </div>
        </div>

        <!-- Business Case One-Pager -->
        <div class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white transition-all">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-slate-900">Business Case One-Pager</h3>
            <span class="shrink-0 inline-flex items-center px-2.5 py-1 text-xs font-medium text-slate-500 bg-slate-100 border border-slate-200 rounded">
              Coming Soon
            </span>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-2">
            Single-page business case framework for early-stage proposals. Free download.
          </p>
          <p class="text-xs text-slate-500 mb-5">
            Covers problem statement, options summary, expected benefits, indicative cost and recommended next step.
          </p>
          <button
            type="button"
            data-notify-toggle="notify-bc-one-pager"
            class="inline-flex items-center px-4 py-2 text-sm font-medium text-navy-600 border border-navy-300 hover:bg-navy-50 rounded-md transition-colors"
            aria-expanded="false"
            aria-controls="notify-panel-notify-bc-one-pager"
          >
            Notify me when available
          </button>
          <div id="notify-panel-notify-bc-one-pager" class="hidden mt-4 pt-4 border-t border-slate-100">
            <p class="text-xs font-medium text-slate-700 mb-2">Get notified when this becomes available.</p>
            <form data-notify-form="notify-bc-one-pager" novalidate class="space-y-2">
              <input type="hidden" name="access_key" value="dc7b04fa-6e86-415e-8d01-1fe332b4bf21" />
              <input type="hidden" name="subject" value="Notify me: Business Case One-Pager" />
              <input type="hidden" name="from_name" value="Lavelle Pty Ltd - Free Tools Notify Me" />
              <input type="hidden" name="message" value="Please notify me when the Business Case One-Pager becomes available." />
              <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
              <div class="flex gap-2">
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="your@email.com"
                  class="flex-1 min-w-0 px-3 py-2 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent"
                />
                <button
                  type="submit"
                  class="shrink-0 px-3 py-2 text-sm font-medium text-white bg-navy-600 hover:bg-navy-700 rounded-md transition-colors"
                >
                  Notify me
                </button>
              </div>
              <p class="text-xs text-slate-400">No spam. Unsubscribe anytime.</p>
            </form>
            <p id="notify-success-notify-bc-one-pager" class="hidden text-sm text-emerald-700 font-medium">
              You're on the list. We'll notify you when this becomes available.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- TEMPLATES CTA -->
  <section style="background-color: #f3f4f6;" class="py-16 lg:py-24">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl text-slate-900 mb-3">Need More Than a Checklist?</h2>
        <p class="text-slate-600 leading-relaxed mb-6">
          Lavelle Pty Ltd template packs include the full artefacts, working documents and structured guidance for each delivery challenge.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/pmo-resources"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
          >
            View PMO Resources
          </a>
          <a
            href="/consulting"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 hover:border-slate-400 rounded-md transition-colors"
          >
            View Consulting Services
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  function initNotifyToggles() {
    document.querySelectorAll<HTMLButtonElement>('[data-notify-toggle]').forEach((btn) => {
      if (btn.dataset.notifyInitialised) return;
      btn.dataset.notifyInitialised = 'true';
      btn.addEventListener('click', () => {
        const id = btn.dataset.notifyToggle!;
        const panel = document.getElementById(`notify-panel-${id}`);
        if (!panel) return;
        const isHidden = panel.classList.contains('hidden');
        panel.classList.toggle('hidden', !isHidden);
        btn.setAttribute('aria-expanded', String(isHidden));
      });
    });

    document.querySelectorAll<HTMLFormElement>('[data-notify-form]').forEach((form) => {
      if (form.dataset.notifyFormInitialised) return;
      form.dataset.notifyFormInitialised = 'true';
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const id = form.dataset.notifyForm!;
        const submitBtn = form.querySelector<HTMLButtonElement>('[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;
        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: new FormData(form),
          });
          const data = await res.json();
          if (data.success) {
            form.classList.add('hidden');
            document.getElementById(`notify-success-${id}`)?.classList.remove('hidden');
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    });
  }

  initNotifyToggles();
</script>
