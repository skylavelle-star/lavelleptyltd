---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site, products } from "../../config/site";

const bundle = products.projectRecoveryBundle;

// framingDocReady: drafted but not finalised - see recovery-framing-doc.md
// (Template version 1.0; cover fields incomplete). Flipping to true also requires
// PUBLIC_LS_PROJECT_RECOVERY_BUNDLE to be set and the post-purchase fulfilment
// pipeline to actually deliver the doc to buyers.
const framingDocReady = false;
const checkoutUrl =
  framingDocReady && bundle.checkoutUrl ? bundle.checkoutUrl : undefined;

const included = [
  "Recovery framing doc - the opinionated thinking that ties the bundle into a protocol",
  "Project Assurance Checklist",
  "RAID Register",
  "Sponsor Update One-Page",
  "Project Change Request",
];
---

<BaseLayout
  title="Project Recovery Bundle - Lavelle Pty Ltd"
  description="A consulting-led recovery bundle. The opinionated framing doc plus four supporting artefacts that turn a stalled program into a defensible recovery plan."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp;
        <a href="/bundles">Bundles</a> &nbsp;/&nbsp;
        <span>Project Recovery Bundle</span>
      </div>
      <div class="eyebrow">Project Recovery Bundle · consulting-led</div>
      <h1 style="margin-top:1rem;">
        For programs in trouble. <em>A protocol, not a pack.</em>
      </h1>
      <p class="subhero__lead">
        Sold alongside the Project Recovery consulting offer. The recovery
        framing doc is the opinionated thinking that ties four supporting
        artefacts into a coherent recovery protocol - the part you can't
        outsource.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap" style="max-width:64rem;">
      <h2 class="section__title">What is included</h2>
      <ul class="artefact-list">
        {included.map((item) => <li>{item}</li>)}
      </ul>

      <aside class="roi-block" aria-label="What this saves you">
        <div class="eyebrow">What this saves you</div>
        <p>
          About five days of senior PM work assembling a coherent recovery
          artefact set - $7,500 at $1,500/day contractor rates. Bundle: ${bundle.price}.
          ROI: ~2.5×. Plus the framing doc - the opinionated thinking that ties
          the four supporting artefacts into a protocol. That is the part you
          can't outsource.
        </p>
      </aside>

      {
        checkoutUrl ? (
          <div class="callout">
            <div class="eyebrow">Available now</div>
            <div class="callout__price-row">
              <span class="callout__price">${bundle.price}</span>
              <span class="callout__sub">single user · AUD</span>
            </div>
            <a
              href={checkoutUrl}
              class="lemonsqueezy-button btn btn--primary"
              data-ga-event="product_buy_click"
              data-ga-label="Project Recovery Bundle"
            >
              Buy now <span class="btn__arrow">→</span>
            </a>
          </div>
        ) : (
          <div class="callout">
            <div class="eyebrow">Coming online · ${bundle.price}</div>
            <p>
              The recovery framing doc is in final production - the bundle ships
              once the framing doc lands. Use the notify form below to be told
              when it ships, or talk to Sky directly if you have an immediate
              recovery underway.
            </p>
            <form
              data-notify-form="notify-project-recovery-bundle"
              class="callout__form"
              novalidate
            >
              <input type="hidden" name="access_key" value={site.web3formsKey} />
              <input
                type="hidden"
                name="subject"
                value="Interest: Project Recovery Bundle - lavelleptyltd.com.au"
              />
              <input
                type="hidden"
                name="from_name"
                value="Lavelle Pty Ltd Bundles"
              />
              <input
                type="hidden"
                name="message"
                value="Interested in the Project Recovery Bundle when available."
              />
              <input
                type="checkbox"
                name="botcheck"
                class="callout__bot"
                tabindex="-1"
                autocomplete="off"
              />
              <label
                class="visually-hidden"
                for="notify-project-recovery-bundle-email"
              >
                Your email
              </label>
              <input
                id="notify-project-recovery-bundle-email"
                type="email"
                name="email"
                required
                placeholder="your@email.com"
                autocomplete="email"
              />
              <button type="submit" class="btn btn--primary">
                Notify me <span class="btn__arrow">→</span>
              </button>
              <p
                id="notify-success-notify-project-recovery-bundle"
                class="callout__success"
                hidden
              >
                Done - we will email you when it ships.
              </p>
            </form>
            <p class="callout__alt">
              If you are mid-recovery now,
              <a href="/contact?subject=recovery-diagnostic">
                book a Recovery Diagnostic
              </a>
              instead.
            </p>
          </div>
        )
      }

      {
        checkoutUrl && (
          <script src="https://assets.lemonsqueezy.com/lemon.js" defer />
        )
      }

      <div class="framework-note">
        <strong>Bundle anchor:</strong> sits alongside the Project Recovery
        consulting offer, not in the framework stage ladder. The framing doc
        is the spine.
        <a href="/consulting#recovery">See the recovery consulting offer →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .artefact-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    border-top: 1px solid var(--rule);
  }
  .artefact-list li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule);
    color: var(--ink-soft);
  }
  .roi-block {
    margin: 0 0 2rem;
    padding: clamp(1.5rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2.25rem);
    background: var(--paper);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--ochre);
  }
  .roi-block .eyebrow {
    margin-bottom: 0.85rem;
  }
  .roi-block p {
    font-family: "Fraunces", serif;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    font-weight: 400;
    line-height: 1.45;
    color: var(--ink);
    margin: 0;
    max-width: 62ch;
  }
  .callout {
    padding: 1.75rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--ochre);
    margin-bottom: 2rem;
  }
  .callout p {
    color: var(--ink-soft);
    margin: 0.5rem 0 1rem;
  }
  .callout__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin: 0.5rem 0 1rem;
  }
  .callout__price {
    font-family: "Fraunces", serif;
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1;
  }
  .callout__sub {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
  }
  .callout__form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    max-width: 28rem;
  }
  .callout__form input[type="email"] {
    flex: 1 1 14rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    background: var(--bone);
    font-family: inherit;
    font-size: var(--body-sm);
  }
  .callout__bot {
    display: none;
  }
  .callout__success {
    font-size: var(--body-sm);
    color: var(--ochre);
    width: 100%;
  }
  .callout__success[hidden] {
    display: none;
  }
  .callout__alt {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    margin-top: 1rem;
  }
  .callout__alt a {
    color: var(--ochre);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }
  .framework-note {
    padding: 1.25rem 1.5rem;
    background: var(--bone);
    border: 1px solid var(--rule);
    font-size: var(--body-sm);
    color: var(--ink-soft);
  }
  .framework-note a {
    color: var(--ochre);
    margin-left: 0.5rem;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLFormElement>("[data-notify-form]")
    .forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const id = form.dataset.notifyForm!;
        const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
        const botcheck =
          form.querySelector<HTMLInputElement>('[name="botcheck"]');
        if (botcheck?.checked) return;
        if (btn) {
          btn.disabled = true;
          btn.textContent = "Sending…";
        }
        let ok = false;
        try {
          const res = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(
              Object.fromEntries(new FormData(form).entries()),
            ),
          });
          const data = (await res.json().catch(() => ({}))) as {
            success?: boolean;
          };
          ok = data.success === true;
        } catch {
          /* silent */
        }
        if (ok) {
          form.querySelectorAll("input, button, label").forEach((el) => {
            (el as HTMLElement).hidden = true;
          });
          const success = document.getElementById(`notify-success-${id}`);
          if (success) success.hidden = false;
        } else if (btn) {
          btn.disabled = false;
          btn.innerHTML = 'Notify me <span class="btn__arrow">→</span>';
        }
      });
    });
</script>
