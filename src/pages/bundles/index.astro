---
import BaseLayout from "../../layouts/BaseLayout.astro";

const bundles = [
  {
    slug: "tier-3-light",
    label: "Tier 3 Light",
    scoreRange: "Tailoring score 7–14",
    summary: "The minimum viable artefact set for a small, contained delivery.",
    includes: [
      "Lite Business Case",
      "Project Plan Schedule (lightweight)",
      "Lite Project Initiation Documentation",
      "Highlight Report (One Page)",
      "Single-page status",
    ],
    featured: false,
  },
  {
    slug: "tier-2-standard",
    label: "Tier 2 Standard",
    scoreRange: "Tailoring score 15–24",
    summary:
      "The standard mid-complexity delivery artefact set. Most enterprise projects land here.",
    includes: [
      "Business Case",
      "Project Plan",
      "Scope & High-Level Requirements",
      "RAID Log",
      "SteerCo Charter",
      "Steering Committee Pack",
      "Cost Plan",
      "Stage Plan Budget",
      "Cost Tolerance Tracker",
    ],
    featured: true,
  },
  {
    slug: "tier-1-major",
    label: "Tier 1 Major",
    scoreRange: "Tailoring score 25–35",
    summary:
      "The full programme artefact set for high-complexity, high-scrutiny delivery.",
    includes: [
      "Everything in Tier 2 Standard, plus:",
      "Project Assurance Checklist",
      "Portfolio Highlight Report",
      "Release Plan Runsheet",
      "Go No-Go Checklist",
      "Quality Management Approach + Quality Plan + Product Status Account",
      "Risk Budget Calculator",
      "Labour Capitalisation Workbook",
    ],
    featured: false,
  },
];

const recoveryBundle = {
  slug: "project-recovery",
  label: "Project Recovery Bundle",
  summary:
    "A consulting-led bundle. The supporting artefact set behind the Project Recovery consulting offer.",
  includes: [
    "Project Assurance Checklist",
    "RAID Log",
    "Highlight Report (One Page)",
    "Request for Change",
    "Recovery framing doc (in development)",
  ],
};
---

<BaseLayout
  title="Bundles — Lavelle Pty Ltd"
  description="Tier-based bundles of the Lavelle pack set: Tier 3 Light, Tier 2 Standard, Tier 1 Major. Plus the consulting-led Project Recovery Bundle. The Tailoring Calculator routes you to the right one."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Bundles</span>
      </div>
      <div class="eyebrow">Tier-based bundles</div>
      <h1 style="margin-top:1rem;">
        The right artefact set <em>for the complexity of the work.</em>
      </h1>
      <p class="subhero__lead">
        Three tier-based bundles mirror the Project Tailoring Calculator's
        recommended artefact sets. Score the project, get the matching
        bundle. A fourth bundle — Project Recovery — sits alongside the
        consulting offer.
      </p>
      <div class="hero__ctas" style="margin-top:2rem;">
        <a href="/free-tools#tiering-calculator" class="btn btn--primary">
          Score your project first <span class="btn__arrow">→</span>
        </a>
        <a href="/framework" class="btn btn--ghost">
          See the framework
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">The three tier bundles</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Light. Standard. <em>Major.</em>
          </h2>
        </div>
        <p class="lead">
          Each bundle is built around the artefacts that match a tailoring
          score band. Run the Tailoring Calculator if you are not sure where
          your project lands.
        </p>
      </header>

      <div class="bundle-grid">
        {
          bundles.map((bundle) => (
            <article
              class={`bundle${bundle.featured ? " bundle--featured" : ""}`}
            >
              {bundle.featured && <div class="bundle__badge">Most common</div>}
              <div class="eyebrow">{bundle.label}</div>
              <div class="bundle__score">{bundle.scoreRange}</div>
              <p class="bundle__summary">{bundle.summary}</p>
              <h3 class="bundle__heading">Included</h3>
              <ul class="bundle__list">
                {bundle.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <a href={`/bundles/${bundle.slug}`} class="btn btn--primary bundle__cta">
                View {bundle.label} <span class="btn__arrow">→</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Consulting-led</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            The Project Recovery <em>Bundle.</em>
          </h2>
        </div>
        <p class="lead">
          A constructed bundle drawing from existing artefacts. Sold alongside
          the Project Recovery consulting offer — not a framework stage. The
          recovery framing doc that ties the bundle together is in
          development.
        </p>
      </header>

      <article class="bundle bundle--recovery">
        <div class="eyebrow">{recoveryBundle.label}</div>
        <p class="bundle__summary" style="margin-top:0.75rem;">
          {recoveryBundle.summary}
        </p>
        <h3 class="bundle__heading">Included</h3>
        <ul class="bundle__list">
          {recoveryBundle.includes.map((item) => <li>{item}</li>)}
        </ul>
        <a
          href="/consulting#recovery"
          class="btn btn--primary bundle__cta"
        >
          Explore the recovery consulting offer
          <span class="btn__arrow">→</span>
        </a>
      </article>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Engage Lavelle</div>
          <h2 style="margin-top:1.25rem;">
            Not sure which bundle <em>fits the work?</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            The Project Tailoring Calculator scores the project across
            complexity dimensions and recommends the matching bundle. If you
            would rather talk it through, start with a thirty-minute call.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/free-tools#tiering-calculator" class="btn btn--primary">
              Use the Tailoring Calculator <span class="btn__arrow">→</span>
            </a>
            <a href="/contact" class="btn btn--ghost">Talk to Sky</a>
          </div>
        </div>
        <ul class="engage__list">
          <li>
            <a href="/framework"
              ><span>See the framework</span><span>→</span></a>
          </li>
          <li>
            <a href="/templates"
              ><span>Individual stage-based packs</span><span>→</span></a>
          </li>
          <li>
            <a href="/enterprise-licensing"
              ><span>Enterprise licensing</span><span>→</span></a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bundle-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 860px) {
    .bundle-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .bundle {
    background: var(--bone);
    border: 1px solid var(--rule);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
  }
  .bundle--featured {
    border: 2px solid var(--ochre);
  }
  .bundle--recovery {
    border-left: 4px solid var(--ink);
  }
  .bundle__badge {
    position: absolute;
    top: -12px;
    right: 1.5rem;
    background: var(--ochre);
    color: var(--bone);
    font-size: var(--micro);
    padding: 0.3rem 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .bundle__score {
    font-family: "DM Sans", sans-serif;
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ochre);
    margin-top: 0.25rem;
  }
  .bundle__summary {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
  }
  .bundle__heading {
    font-family: "Fraunces", serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0.85rem 0 0.4rem;
  }
  .bundle__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-size: var(--body-sm);
    color: var(--ink-soft);
    flex-grow: 1;
  }
  .bundle__list li {
    padding-left: 1rem;
    position: relative;
    line-height: 1.5;
  }
  .bundle__list li::before {
    content: "·";
    position: absolute;
    left: 0.25rem;
    color: var(--ochre);
    font-weight: 700;
  }
  .bundle__cta {
    margin-top: 1rem;
    align-self: flex-start;
  }
</style>
