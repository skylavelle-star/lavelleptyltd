    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }
</style>

<script>
  document
    .querySelectorAll<HTMLFormElement>("[data-notify-form]")
    .forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const id = form.dataset.notifyForm!;
        const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
        const botcheck =
          form.querySelector<HTMLInputElement>('[name="botcheck"]');
        if (botcheck?.checked) return;
        if (btn) {
          btn.disabled = true;
          btn.textContent = "Sending…";
        }
        let ok = false;
        try {
          const res = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(
              Object.fromEntries(new FormData(form).entries()),
            ),
          });
          const data = (await res.json().catch(() => ({}))) as {
            success?: boolean;
          };
          ok = data.success === true;
        } catch {
          /* silent */
        }
        if (ok) {
          form.querySelectorAll("input, button, label").forEach((el) => {
            (el as HTMLElement).hidden = true;
          });
          const success = document.getElementById(`notify-success-${id}`);
          if (success) success.hidden = false;
        } else if (btn) {
          btn.disabled = false;
          btn.innerHTML = 'Notify me <span class="btn__arrow">→</span>';
        }
      });
    });
</script>

<script>
  const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!("IntersectionObserver" in window) || reduce) {
    reveals.forEach((el) => el.classList.add("is-visible"));
  } else {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target as HTMLElement;
          if (el.hasAttribute("data-reveal-stagger")) {
            Array.from(el.children).forEach((child, i) => {
              (child as HTMLElement).style.transitionDelay = `${i * 80}ms`;
            });
          }
          el.classList.add("is-visible");
          obs.unobserve(el);
        }
      },
      { rootMargin: "0px 0px -15% 0px", threshold: 0.1 },
    );
    reveals.forEach((el) => io.observe(el));
  }

  // Banner parallax: image is rendered at its native aspect ratio (taller
  // than the band), so we slide it vertically by up to `slack` pixels as
  // the band scrolls through the viewport. Top edge visible at the start
  // (progress 0), bottom edge visible at the end (progress 1).
  const band = document.querySelector<HTMLElement>(".image-band");
  const bandImg = band?.querySelector<HTMLImageElement>(".image-band__img");
  if (band && bandImg && !reduce) {
    let ticking = false;
    let active = false;

    const update = () => {
      const rect = band.getBoundingClientRect();
      const imgH = bandImg.getBoundingClientRect().height;
      const slack = Math.max(0, imgH - rect.height);
      const vh = window.innerHeight;
      const track = vh + rect.height;
      const consumed = vh - rect.top;
      const progress = Math.max(0, Math.min(1, consumed / track));
      // 1.5× speed: parallax completes once the band reaches ~67% of its
      // scroll travel (33% earlier than the full distance), then holds.
      const eased = Math.min(progress * 1.5, 1);
      const ty = -eased * slack;
      bandImg.style.transform = `translate3d(0, ${ty}px, 0)`;
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking && active) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };

    const visibility = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          active = entry.isIntersecting;
          if (active) update();
        }
      },
      { rootMargin: "100px 0px 100px 0px" },
    );
    visibility.observe(band);

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    if (bandImg.complete) update();
    else bandImg.addEventListener("load", update, { once: true });
  }
</script>
