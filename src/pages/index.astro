  .product__notify .btn {
    flex: 0 0 auto;
  }
  .product__notify-bot {
    display: none;
  }
  .product__notify-success {
    font-size: var(--body-sm);
    color: var(--ochre);
    width: 100%;
    margin: 0;
  }
  .product__notify-success[hidden] {
    display: none;
