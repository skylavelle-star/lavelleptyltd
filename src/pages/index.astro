---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import heroImage from "../assets/images/hero.jpg";
import caseStudyImage from "../assets/images/case-study-quadrangle.jpg";
import templatesImage from "../assets/images/templates-blueprint.jpg";
import engageImage from "../assets/images/engage-boardroom.jpg";
import { site, products } from "../config/site";

const steeringUrl = products.steeringCommitteePack.checkoutUrl || undefined;
const recoveryUrl = products.projectRecoveryPack.checkoutUrl || undefined;
const anyCheckout = Boolean(steeringUrl || recoveryUrl);

const featuredThinking = (await getCollection("articles"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Lavelle Pty Ltd - Project delivery, PMO governance and senior consulting"
  description="Lavelle Pty Ltd partners with government, enterprise and program teams to recover at-risk projects, strengthen PMO governance and deliver outcomes that hold."
>
  {
    anyCheckout && (
      <script src="https://assets.lemonsqueezy.com/lemon.js" defer />
    )
  }
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="hero__grid">
        <div>
          <div class="eyebrow">Project delivery · PMO · Recovery</div>
          <h1 class="hero__headline" style="margin-top:1.5rem;">
            From stalled programs<br />
            to <em>shipped outcomes.</em>
          </h1>
          <p class="hero__sub">
            We partner with media, higher education and government-adjacent
            research organisations to recover at-risk programs, strengthen PMO
            governance and lead complex enterprise technology delivery -
            particularly where previous attempts have failed and stakeholder
            confidence has collapsed.
          </p>
          <div class="hero__ctas">
            <a href="/contact" class="btn btn--primary">
              Engage Lavelle <span class="btn__arrow">→</span>
            </a>
            <a href="/templates" class="btn btn--ghost">
              Browse Templates
            </a>
          </div>
        </div>

        <aside class="hero__panel">
          <div class="hero__signal">Now booking Q2 engagements</div>
          <div>
            <div class="hero__stat-num">
              20<span style="font-size:0.4em;">yrs</span>
            </div>
            <p class="hero__stat-label">
              Senior delivery experience across media, higher education and
              cyber-security research - including a national public
              broadcaster, two Australian universities and a federally-funded
              cyber security research centre.
            </p>
          </div>
          <div style="border-top:1px solid var(--rule); padding-top:1.5rem;">
            <div
              style="font-family:'Fraunces',serif; font-size:1.15rem; font-style:italic; color:var(--ink); margin-bottom:0.5rem;"
            >
              Recipient, university Senior Leadership Award.
            </div>
            <div
              style="font-size:var(--micro); letter-spacing:0.18em; text-transform:uppercase; color:var(--sage);"
            >
              For positive change across individuals, teams &amp; business
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- STRIP -->
  <div class="strip" aria-hidden="true">
    <div class="strip__inner">
      <span>Project recovery</span><span>·</span>
      <span>PMO stand-up &amp; uplift</span><span>·</span>
      <span>Steering committee governance</span><span>·</span>
      <span>Business case development</span><span>·</span>
      <span>Procurement &amp; RFP advisory</span><span>·</span>
      <span>Delivery assurance</span><span>·</span>
      <span>Portfolio reporting</span><span>·</span>
      <span>Project recovery</span><span>·</span>
      <span>PMO stand-up &amp; uplift</span><span>·</span>
      <span>Steering committee governance</span><span>·</span>
      <span>Business case development</span><span>·</span>
      <span>Procurement &amp; RFP advisory</span><span>·</span>
      <span>Delivery assurance</span><span>·</span>
      <span>Portfolio reporting</span><span>·</span>
    </div>
  </div>

  <!-- FEATURED IMAGE -->
  <figure class="image-band" data-reveal>
    <Image
      src={heroImage}
      alt="An empty boardroom with a long meeting table, floor-to-ceiling windows and morning light - the setting where steering committee decisions are made"
      widths={[640, 960, 1280, 1536]}
      sizes="(min-width: 1536px) 1536px, 100vw"
      loading="lazy"
      decoding="async"
      class="image-band__img"
    />
  </figure>

  <!-- CAPABILITIES -->
  <section data-reveal>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">What we do</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Senior delivery expertise<br />across the <em>full lifecycle.</em>
          </h2>
        </div>
        <p class="lead">
          Six closely related capabilities, drawn from twenty years of running
          complex programs. Engaged singly to fix a specific problem, or
          together to lift overall delivery confidence across a portfolio.
        </p>
      </header>

      <div class="capabilities" data-reveal data-reveal-stagger>
        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><path d="m4.93 4.93 4.24 4.24"/><path d="m14.83 9.17 4.24-4.24"/><path d="m14.83 14.83 4.24 4.24"/><path d="m9.17 14.83-4.24 4.24"/></svg>
          </div>
          <div class="cap__num">01 / Recovery</div>
          <h3 class="cap__title">Project recovery</h3>
          <p class="cap__desc">
            Diagnose what's actually broken - scope, schedule, governance or
            capability - and stabilise delivery within the first 30 days.
          </p>
          <a href="/consulting#recovery" class="cap__link"
            >Learn more <span>→</span></a
          >
        </article>

        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <div class="cap__num">02 / Governance</div>
          <h3 class="cap__title">PMO stand-up &amp; uplift</h3>
          <p class="cap__desc">
            Establish or remediate the PMO that complex delivery actually needs:
            artefact set, cadence, reporting line and the day-to-day discipline
            that makes governance real instead of theatrical.
          </p>
          <a href="/consulting#governance" class="cap__link"
            >Learn more <span>→</span></a
          >
        </article>

        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M8 13h2"/><path d="M14 13h2"/><path d="M8 17h2"/><path d="M14 17h2"/></svg>
          </div>
          <div class="cap__num">03 / Investment</div>
          <h3 class="cap__title">Business case development</h3>
          <p class="cap__desc">
            Treasury-grade and ICT business cases that survive scrutiny. We
            write the case the executive actually needs to defend, not the one
            the template asks for.
          </p>
          <a href="/consulting#investment" class="cap__link"
            >Learn more <span>→</span></a
          >
        </article>

        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>
          </div>
          <div class="cap__num">04 / Sourcing</div>
          <h3 class="cap__title">Procurement &amp; RFP advisory</h3>
          <p class="cap__desc">
            RFP design, evaluation governance, vendor selection and contract
            handover. We help you procure the right outcome - not just the
            lowest price or the loudest pitch.
          </p>
          <a href="/consulting#sourcing" class="cap__link"
            >Learn more <span>→</span></a
          >
        </article>

        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <div class="cap__num">05 / Assurance</div>
          <h3 class="cap__title">Steering committee governance</h3>
          <p class="cap__desc">
            Make the boardroom 30 minutes count. We design steering packs,
            decision papers and reporting cadence that put decisions before
            status and surface escalations before they become surprises.
          </p>
          <a href="/consulting#assurance" class="cap__link"
            >Learn more <span>→</span></a
          >
        </article>

        <article class="cap">
          <div class="cap__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
          </div>
          <div class="cap__num">06 / Independence</div>
          <h3 class="cap__title">Delivery assurance</h3>
          <p class="cap__desc">
            Independent health checks, gate reviews and red-team analysis. A
            second pair of senior eyes on your most consequential programs -
            before the board asks for one.
          </p>
          <a href="/consulting#independence" class="cap__link"
            >Learn more <span>→</span></a
          >
        </article>
      </div>
    </div>
  </section>

  <!-- CASE STUDY / QUOTE -->
  <section class="case case--imaged" data-reveal>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Real engagements · real outcomes</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            The program<br />that defined a <em>decade.</em>
          </h2>
        </div>
        <p class="lead">
          A career is built on the moments where everyone else has lost
          confidence and you have to find a way to deliver anyway. A major
          Australian research university's WCMS transformation is one of those.
          Four more are documented in the case study library.
        </p>
      </header>

      <figure class="case__image" data-reveal>
        <Image
          src={caseStudyImage}
          alt="A sandstone university building with a clock tower - the kind of institutional setting where the WCMS recovery played out"
          widths={[640, 960, 1280, 1800]}
          sizes="(min-width: 1080px) 1100px, 100vw"
          loading="lazy"
          decoding="async"
          class="case__image-img"
        />
      </figure>

      <div class="case__grid">
        <div>
          <p class="case__quote">
            "Politically charged. Forecast at three years. Organised resistance
            from architecture, security, development and the business
            simultaneously. <em>Delivered in twelve months</em> - with every previously-resistant
            group standing behind the outcome."
          </p>
          <div class="case__attr">
            Australian research university · WCMS · Senior Leadership Award ·
            2015-2016
          </div>
        </div>
        <div class="case__metrics" data-reveal data-reveal-stagger>
          <div>
            <div class="case__metric-num">
              36<span style="font-size:0.5em;">→12</span>
            </div>
            <div class="case__metric-label">
              Months forecast versus actual delivery.
            </div>
          </div>
          <div>
            <div class="case__metric-num">1</div>
            <div class="case__metric-label">
              Senior Leadership Award awarded post-delivery.
            </div>
          </div>
          <div>
            <div class="case__metric-num">4</div>
            <div class="case__metric-label">
              Stakeholder groups: organised resistance to active endorsement.
            </div>
          </div>
          <div>
            <div class="case__metric-num">
              5<span style="font-size:0.5em;">yr</span>
            </div>
            <div class="case__metric-label">
              Follow-on mandate at the same university across three further
              transformation programs.
            </div>
          </div>
        </div>
      </div>

      <div style="margin-top:3rem; text-align:center;">
        <a href="/case-studies" class="btn btn--ghost"
          >Read four more case studies <span class="btn__arrow">→</span></a
        >
      </div>
    </div>
  </section>

  <!-- FEATURED ARTICLES -->
  <section class="thinking" data-reveal>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Featured articles</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Field notes from<br />the <em>delivery floor.</em>
          </h2>
        </div>
        <p class="lead">
          Practical writing for the people doing the work. No frameworks for
          their own sake - only the patterns, artefacts and decisions that hold
          up under board scrutiny.
        </p>
      </header>

      <div class="thinking__grid" data-reveal data-reveal-stagger>
        {
          featuredThinking.map((article) => (
            <a href={`/articles/${article.id}`} class="think-card">
              <div class="think-card__kicker">{article.data.category}</div>
              <h3 class="think-card__title">{article.data.title}.</h3>
              <p class="think-card__desc">{article.data.description}</p>
              <div class="think-card__meta">
                Article · {article.data.readTime} min read
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PMO RESOURCES TEASER -->
  <section class="products-section" data-reveal>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Templates</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Battle-tested artefacts.<br /><em>Ready to deploy.</em>
          </h2>
        </div>
        <p class="lead">
          The exact packs Lavelle uses on engagement, packaged for download.
          Built for project managers, PMO leads and program directors who need
          something solid in front of the steering committee by Monday.
        </p>
      </header>

      <figure class="products-section__image" data-reveal>
        <Image
          src={templatesImage}
          alt="A hand drafting on a technical blueprint with ruler and pencil - the precision behind project artefacts"
          widths={[640, 960, 1280, 1800]}
          sizes="(min-width: 1080px) 1100px, 100vw"
          loading="lazy"
          decoding="async"
          class="products-section__image-img"
        />
      </figure>

      <div class="products" data-reveal data-reveal-stagger>
        <article class="product">
          <span class="product__tag">Flagship · ships first</span>
          <h3 class="product__title">Steering Pack</h3>
          <p class="product__desc">
            A complete steering committee toolkit - decision papers, status
            dashboards, escalation logs and meeting protocols - built so the
            committee sees risks, escalations and decisions before they become
            headlines.
          </p>
          <ul class="product__list">
            <li>7 board-ready templates</li>
            <li>Decision-paper writing guide</li>
            <li>Pre-read protocol &amp; agenda framework</li>
            <li>RAID escalation thresholds</li>
          </ul>
          <div class="product__footer">
            <div>
              <div class="product__price">${products.steeringCommitteePack.price}</div>
              <div class="product__price-sub">single user · AUD</div>
            </div>
            {
              steeringUrl ? (
                <a
                  href={steeringUrl}
                  class="lemonsqueezy-button btn btn--primary"
                  data-ga-event="product_buy_click"
                  data-ga-label="Steering Committee Pack"
                >
                  Buy now <span class="btn__arrow">→</span>
                </a>
              ) : (
                <form
                  data-notify-form="notify-home-steering"
                  class="product__notify"
                  novalidate
                >
                  <input
                    type="hidden"
                    name="access_key"
                    value={site.web3formsKey}
                  />
                  <input
                    type="hidden"
                    name="subject"
                    value="Interest: Steering Pack - lavelleptyltd.com.au"
                  />
                  <input
                    type="hidden"
                    name="from_name"
                    value="Lavelle Pty Ltd Templates"
                  />
                  <input
                    type="hidden"
                    name="message"
                    value="Interested in the Steering Pack when available."
                  />
                  <input
                    type="checkbox"
                    name="botcheck"
                    class="product__notify-bot"
                    tabindex="-1"
                    autocomplete="off"
                  />
                  <label
                    class="visually-hidden"
                    for="notify-home-steering-email"
                  >
                    Your email
                  </label>
                  <input
                    id="notify-home-steering-email"
                    type="email"
                    name="email"
                    required
                    placeholder="your@email.com"
                    autocomplete="email"
                  />
                  <button type="submit" class="btn btn--primary">
                    Notify me <span class="btn__arrow">→</span>
                  </button>
                  <p
                    id="notify-success-notify-home-steering"
                    class="product__notify-success"
                    hidden
                  >
                    Done - we will email you when it ships.
                  </p>
                </form>
              )
            }
          </div>
        </article>

        <article class="product">
          <span class="product__tag">Available now</span>
          <h3 class="product__title">Project Recovery Pack</h3>
          <p class="product__desc">
            The full 30-day diagnostic and stabilisation playbook for project
            managers stepping into a red program. Templates, scripts,
            stakeholder maps and the day-by-day cadence we use on engagement.
          </p>
          <ul class="product__list">
            <li>30-day recovery roadmap</li>
            <li>Health-check diagnostic instrument</li>
            <li>Stakeholder &amp; sponsor scripts</li>
            <li>Re-baseline communication kit</li>
          </ul>
          <div class="product__footer">
            <div>
              <div class="product__price">${products.projectRecoveryPack.price}</div>
              <div class="product__price-sub">single user · AUD</div>
            </div>
            {
              recoveryUrl ? (
                <a
                  href={recoveryUrl}
                  class="lemonsqueezy-button btn btn--primary"
                  data-ga-event="product_buy_click"
                  data-ga-label="Project Recovery Pack"
                >
                  Buy now <span class="btn__arrow">→</span>
                </a>
              ) : (
                <form
                  data-notify-form="notify-home-recovery"
                  class="product__notify"
                  novalidate
                >
                  <input
                    type="hidden"
                    name="access_key"
                    value={site.web3formsKey}
                  />
                  <input
                    type="hidden"
                    name="subject"
                    value="Interest: Project Recovery Pack - lavelleptyltd.com.au"
                  />
                  <input
                    type="hidden"
                    name="from_name"
                    value="Lavelle Pty Ltd Templates"
                  />
                  <input
                    type="hidden"
                    name="message"
                    value="Interested in the Project Recovery Pack when available."
                  />
                  <input
                    type="checkbox"
                    name="botcheck"
                    class="product__notify-bot"
                    tabindex="-1"
                    autocomplete="off"
                  />
                  <label
                    class="visually-hidden"
                    for="notify-home-recovery-email"
                  >
                    Your email
                  </label>
                  <input
                    id="notify-home-recovery-email"
                    type="email"
                    name="email"
                    required
                    placeholder="your@email.com"
                    autocomplete="email"
                  />
                  <button type="submit" class="btn btn--primary">
                    Notify me <span class="btn__arrow">→</span>
                  </button>
                  <p
                    id="notify-success-notify-home-recovery"
                    class="product__notify-success"
                    hidden
                  >
                    Done - we will email you when it ships.
                  </p>
                </form>
              )
            }
          </div>
        </article>
      </div>

      <div
        style="margin-top:3rem; padding:2.5rem; border:1px solid var(--rule); background:var(--paper); display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap;"
      >
        <div>
          <div class="eyebrow" style="margin-bottom:0.75rem;">
            Free · for delivery leads
          </div>
          <h3
            style="font-family:'Fraunces',serif; font-size:1.6rem; font-weight:500; margin-bottom:0.5rem;"
          >
            The Project Recovery Checklist
          </h3>
          <p
            style="font-size:var(--body-sm); color:var(--ink-soft); max-width:50ch;"
          >
            Twenty-three questions we ask in the first 48 hours of any recovery
            engagement. Print it, take it into your steering meeting and you'll
            know within an hour where the real problems are.
          </p>
        </div>
        <a href="/free-tools/project-recovery-checklist" class="btn btn--primary"
          >Download free <span class="btn__arrow">→</span></a
        >
      </div>
    </div>
  </section>

  <!-- ENGAGE / FINAL CTA -->
  <section class="engage engage--imaged" data-reveal>
    <figure class="engage__bg" aria-hidden="true">
      <Image
        src={engageImage}
        alt=""
        widths={[960, 1440, 1920, 2400]}
        sizes="100vw"
        loading="lazy"
        decoding="async"
        class="engage__bg-img"
      />
    </figure>
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Engage Lavelle</div>
          <h2 style="margin-top:1.25rem;">
            Let's talk about <em>what's not moving.</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            Whether you need a confidential second opinion on a stalled program,
            a senior delivery lead to take the helm for ninety days, or a PMO
            stood up from scratch - start with a thirty-minute conversation. No
            pitch deck, no obligation, no sales call disguised as a workshop.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Request an engagement conversation <span class="btn__arrow"
                >→</span
              >
            </a>
          </div>
        </div>

        <ul class="engage__list" data-reveal data-reveal-stagger>
          <li>
            <a href="/contact?topic=brief">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
              </span>
              <span>Submit a brief (RFP / EOI)</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/contact?topic=call">
              <span class="engage__icon" aria-hidden="true">
