---
import Layout from '../layouts/Layout.astro';
import CapabilityCard from '../components/CapabilityCard.astro';
import ProductCard from '../components/ProductCard.astro';
import { products, site } from '../config/site';

const productList = Object.values(products);

const capabilities = [
  {
    title: 'Project Recovery',
    copy: 'Practical tools and consulting support for projects that need stronger control, clearer governance and a credible path back to delivery.',
    href: '/pmo-resources#project-recovery-pack',
  },
  {
    title: 'Business Cases',
    copy: 'Structured business case resources that help define the case for change, expected benefits, delivery costs, risks, dependencies and approval pathways.',
    href: '/pmo-resources#business-case-pack',
  },
  {
    title: 'Procurement Governance',
    copy: 'Templates and guidance for procurement planning, RFP support, evaluation governance, BAFO processes and delegate approvals.',
    href: '/pmo-resources#procurement-pack',
  },
  {
    title: 'Steering Committee Reporting',
    copy: 'Clear reporting structures for project boards and steering committees, including status, risks, issues, decisions, financials and escalation points.',
    href: '/pmo-resources#steering-committee-pack',
  },
  {
    title: 'Delivery Frameworks',
    copy: 'A practical hybrid delivery framework that combines structured governance with Agile execution, using clear artefacts, decision points and delivery rhythms.',
    href: '/delivery-framework',
  },
  {
    title: 'Risk, Issue and Decision Management',
    copy: 'Registers, reporting structures and escalation practices that make project control visible, consistent and easier to manage.',
    href: '/pmo-resources',
  },
];

const trustItems = [
  'Senior project delivery consulting',
  'Practical PMO resources and templates',
  'Hybrid delivery framework',
  'Australian company',
];
---

<Layout
  title="Lavelle Pty Ltd | PMO Resources, Project Delivery Consulting and Digital Assets"
  description="Lavelle Pty Ltd provides senior project delivery consulting, practical PMO resources and digital asset development for organisations that need stronger governance and clearer project control."
>
  <!-- HERO -->
  <section class="bg-navy-950 text-white py-20 lg:py-32">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
          Project Delivery Tools, Templates and Consulting
        </h1>
        <p class="text-lg lg:text-xl text-slate-300 leading-relaxed mb-8 max-w-2xl">
          Lavelle Pty Ltd provides senior project delivery consulting and practical PMO resources for organisations that need stronger governance, clearer artefacts and better control over complex technology and business change initiatives.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/pmo-resources"
            data-ga-event="hero_cta_primary"
            class="inline-flex items-center px-6 py-3.5 text-base font-medium text-white bg-navy-600 hover:bg-navy-500 rounded-md transition-colors"
          >
            Browse PMO Resources
          </a>
          <a
            href="/contact"
            data-ga-event="hero_cta_secondary"
            class="inline-flex items-center px-6 py-3.5 text-base font-medium text-white border border-slate-500 hover:border-slate-300 hover:bg-white/5 rounded-md transition-colors"
          >
            Engage Lavelle Pty Ltd
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="bg-navy-900 border-b border-navy-800">
    <div class="container py-4">
      <ul class="flex flex-wrap gap-x-8 gap-y-2" role="list">
        {trustItems.map((item) => (
          <li class="flex items-center gap-2 text-sm text-slate-300">
            <span class="w-1.5 h-1.5 rounded-full bg-navy-400 shrink-0" aria-hidden="true"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- WHAT WE HELP WITH -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Capabilities</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-slate-900">What We Help With</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {capabilities.map((cap) => (
          <CapabilityCard title={cap.title} copy={cap.copy} href={cap.href} />
        ))}
      </div>
    </div>
  </section>

  <!-- PMO RESOURCES PREVIEW -->
  <section class="section">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">PMO Resources</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-slate-900">Practical Resources for Real Delivery Environments</h2>
        <p class="text-slate-600 mt-3">
          Designed for environments where governance, funding, procurement, stakeholder management and execution need to work together.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {productList.map((product) => (
          <ProductCard
            name={product.name}
            description={product.description}
            statusBadge={product.checkoutUrl ? 'Available' : 'Coming Soon'}
            ctaText="View Resource"
            ctaUrl={product.pmoResourcesHref}
            disabled={false}
            id={undefined}
          />
        ))}
      </div>
      <div class="mt-8">
        <a
          href="/pmo-resources"
          class="inline-flex items-center text-sm font-medium text-navy-700 hover:text-navy-900 transition-colors"
        >
          Browse all PMO resources
          <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CONSULTING TEASER -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Consulting</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 mb-4">
          Senior Project Delivery Consulting
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          Lavelle Pty Ltd provides senior project management and delivery consulting through Sky Lavelle, its principal consultant, director and owner. Sky works with organisations that need experienced delivery leadership across complex technology, digital transformation, procurement, governance, implementation and business change initiatives.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/consulting"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
          >
            View Consulting Services
          </a>
          <a
            href={site.skyLavelleUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 hover:border-slate-400 rounded-md transition-colors"
          >
            Sky Lavelle Profile
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-navy-950 py-16 lg:py-20">
    <div class="container max-w-3xl">
      <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">Work With Lavelle Pty Ltd</h2>
      <p class="text-slate-300 leading-relaxed mb-8">
        For consulting, contract project management, PMO resources, delivery support or digital asset enquiries, contact Lavelle Pty Ltd.
      </p>
      <a
        href="/contact"
        data-ga-event="final_cta_click"
        class="inline-flex items-center px-7 py-3.5 text-base font-medium text-navy-950 bg-white hover:bg-slate-100 rounded-md transition-colors"
      >
        Send an Enquiry
      </a>
    </div>
  </section>
</Layout>
