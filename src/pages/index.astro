---
import Layout from '../layouts/Layout.astro';
import CapabilityCard from '../components/CapabilityCard.astro';
import ProductCard from '../components/ProductCard.astro';
import { products, site } from '../config/site';
import boardroomImage from '../assets/images/steering-committee-boardroom.jpg';

const productList = Object.values(products);

const capabilities = [
  {
    title: 'Project Recovery',
    copy: 'Stabilise stalled programs with structured assessment, replan and governance reset artefacts.',
    href: '/pmo-resources#project-recovery-pack',
    iconPaths:
      '<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path stroke-linecap="round" stroke-linejoin="round" d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>',
  },
  {
    title: 'Business Cases',
    copy: 'Build defensible business cases with options analysis, financials, benefits and approval routing.',
    href: '/pmo-resources#business-case-pack',
    iconPaths:
      '<path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  },
  {
    title: 'Procurement Governance',
    copy: 'Plan, run and document defensible procurement from RFP through to delegate approval.',
    href: '/pmo-resources#procurement-pack',
    iconPaths:
      '<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="m9 12 2 2 4-4"/>',
  },
  {
    title: 'Steering Committee Reporting',
    copy: 'Give boards and steering committees decision-ready reports - not status theatre.',
    href: '/pmo-resources#steering-committee-pack',
    iconPaths:
      '<path stroke-linecap="round" stroke-linejoin="round" d="M18 20V10"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 20V4"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 20v-6"/>',
  },
  {
    title: 'Delivery Frameworks',
    copy: 'Run programs on a hybrid framework that combines structured governance with Agile execution.',
    href: '/delivery-framework',
    iconPaths:
      '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
  },
  {
    title: 'Risk, Issue and Decision Management',
    copy: 'Make project control visible with clear registers, escalation paths and decision logs.',
    href: '/pmo-resources',
    iconPaths:
      '<path stroke-linecap="round" stroke-linejoin="round" d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 17h.01"/>',
  },
];

const trustItems = [
  'Senior delivery consulting',
  'PMO templates and free tools',
  'Hybrid delivery framework',
  'Australian company',
];
---

<Layout
  title="Lavelle Pty Ltd | PMO Resources, Project Delivery Consulting and Digital Assets"
  description="Lavelle Pty Ltd provides senior project delivery consulting, practical PMO resources and digital asset development for organisations that need stronger governance and clearer project control."
>
  <!-- HERO -->
  <section class="bg-navy-950 text-white py-20 lg:py-28">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Left column -->
        <div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5">
            Project Delivery Tools, Templates and Consulting
          </h1>
          <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-xl">
            Senior delivery consulting and practical PMO resources for organisations that need stronger governance and better control over complex programs.
          </p>

          <!-- Lead magnet block -->
          <div class="rounded-xl border border-navy-800 bg-navy-900 p-6">
            <h2 class="text-base font-semibold text-white mb-1" style="line-height: 1.4;">
              Get the Free Project Recovery Checklist
            </h2>
            <p class="text-sm text-slate-400 mb-4 leading-relaxed">
              A practical one-page checklist for project managers stepping into a project that needs stabilising. Sent to your inbox immediately.
            </p>
            <form id="lead-magnet-form" novalidate class="space-y-3">
              <input type="hidden" name="access_key" value={site.web3formsKey} />
              <input type="hidden" name="subject" value="Free Resource Request - Project Recovery Checklist" />
              <input type="hidden" name="from_name" value="Lavelle Pty Ltd - Lead Magnet" />
              <input type="hidden" name="message" value="Please send the Free Project Recovery Checklist." />
              <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
              <div class="flex gap-2.5">
                <input
                  type="email"
                  id="lead-magnet-email"
                  name="email"
                  required
                  placeholder="your@email.com.au"
                  class="flex-1 min-w-0 px-3.5 py-2.5 text-sm rounded-md bg-white text-slate-900 placeholder-slate-400 border-0 focus:outline-none focus:ring-2 focus:ring-navy-400"
                />
                <button
                  type="submit"
                  id="lead-magnet-btn"
                  class="shrink-0 inline-flex items-center px-4 py-2.5 text-sm font-medium text-white bg-navy-600 hover:bg-navy-500 rounded-md transition-colors disabled:opacity-60 disabled:cursor-not-allowed whitespace-nowrap"
                >
                  Send the checklist
                </button>
              </div>
              <p class="text-xs text-slate-500">No spam. Unsubscribe anytime.</p>
            </form>
            <p id="lead-magnet-success" class="hidden text-sm text-emerald-400 font-medium mt-3">
              Checklist on its way - check your inbox.
            </p>
            <p id="lead-magnet-error" class="hidden text-sm text-red-400 mt-3">
              Something went wrong. Please try again.
            </p>
          </div>

          <div class="mt-4">
            <a
              href="/pmo-resources"
              data-ga-event="hero_cta_secondary"
              class="inline-flex items-center text-sm font-medium text-slate-300 hover:text-white transition-colors"
            >
              Browse PMO Resources
              <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

          <!-- Trust indicators -->
          <ul class="flex flex-wrap gap-x-6 gap-y-2 mt-8" role="list">
            {trustItems.map((item) => (
              <li class="flex items-center gap-2 text-sm text-slate-400">
                <span class="w-1.5 h-1.5 rounded-full bg-navy-500 shrink-0" aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Right column - product preview -->
        <div class="hidden lg:flex items-center justify-center">
          {/* TODO: Add product preview image or template screenshot */}
          <div class="relative w-full max-w-sm">
            <!-- Stacked card effect (background layers) -->
            <div class="absolute inset-0 rounded-xl bg-navy-800 border border-navy-700 transform rotate-2 translate-y-3 scale-[0.97]" aria-hidden="true"></div>
            <div class="absolute inset-0 rounded-xl bg-navy-800 border border-navy-700 transform rotate-1 translate-y-1.5 scale-[0.985]" aria-hidden="true"></div>
            <!-- Front card -->
            <div class="relative rounded-xl bg-navy-900 border border-navy-700 p-7">
              <p class="text-xs font-semibold text-navy-400 uppercase tracking-wider mb-5">Steering Committee Pack</p>
              <div class="space-y-2 mb-6">
                <div class="h-2 rounded bg-navy-700 w-3/4"></div>
                <div class="h-2 rounded bg-navy-700 w-full"></div>
                <div class="h-2 rounded bg-navy-700 w-4/5"></div>
              </div>
              <div class="grid grid-cols-2 gap-3 mb-6">
                <div class="rounded-lg bg-navy-800 border border-navy-700 p-3">
                  <p class="text-xs text-navy-500 mb-2">Status</p>
                  <div class="h-2 rounded bg-navy-600 w-1/2"></div>
                </div>
                <div class="rounded-lg bg-navy-800 border border-navy-700 p-3">
                  <p class="text-xs text-navy-500 mb-2">RAG</p>
                  <div class="flex gap-1.5">
                    <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
                    <div class="w-3 h-3 rounded-full bg-amber-400"></div>
                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                  </div>
                </div>
              </div>
              <div class="space-y-2">
                {['Charter', 'Meeting Agenda', 'Status Report', 'Decision Log'].map((item) => (
                  <div class="flex items-center gap-2.5">
                    <div class="w-1.5 h-1.5 rounded-full bg-navy-500 shrink-0" aria-hidden="true"></div>
                    <span class="text-xs text-navy-400">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHAT WE HELP WITH -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-600 uppercase tracking-wider mb-3">Capabilities</p>
        <h2 class="text-2xl lg:text-3xl text-slate-900">What We Help With</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {capabilities.map((cap) => (
          <CapabilityCard
            title={cap.title}
            copy={cap.copy}
            href={cap.href}
            iconPaths={cap.iconPaths}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- PMO RESOURCES PREVIEW -->
  <section class="section">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-600 uppercase tracking-wider mb-3">PMO Resources</p>
        <h2 class="text-2xl lg:text-3xl text-slate-900">Practical Resources for Real Delivery Environments</h2>
        <p class="text-slate-600 mt-3">
          Built for environments where governance, funding, procurement and execution all have to hold together.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {productList.map((product) => (
          <ProductCard
            name={product.name}
            description={product.description}
            whatsIncluded={[...product.whatsIncluded]}
            price={product.price || 'Pricing announced soon'}
            statusBadge={product.checkoutUrl ? 'Available' : 'Coming Soon'}
            ctaText="View Resource"
            ctaUrl={product.pmoResourcesHref}
            disabled={false}
            id={undefined}
            notifyEnabled={true}
            image={product.href === '/templates/steering-committee-pack' ? boardroomImage : undefined}
            imageAlt={product.href === '/templates/steering-committee-pack' ? 'An empty boardroom with a long meeting table - the setting where steering committee decisions are made' : undefined}
          />
        ))}
      </div>
      <div class="mt-8">
        <a
          href="/pmo-resources"
          class="inline-flex items-center text-sm font-medium text-navy-600 hover:text-navy-800 transition-colors"
        >
          Browse all PMO resources
          <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CONSULTING TEASER -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-navy-600 uppercase tracking-wider mb-3">Consulting</p>
        <h2 class="text-2xl lg:text-3xl text-slate-900 mb-4">
          Senior Project Delivery Consulting
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          Lavelle Pty Ltd provides senior project management and delivery consulting through its principal consultant, Sky Lavelle. Sky leads delivery on complex technology programs, business cases, procurement and program recovery.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/consulting"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
          >
            View Consulting Services
          </a>
          <a
            href={site.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 hover:border-slate-400 rounded-md transition-colors"
          >
            Sky Lavelle on LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-navy-950 py-16 lg:py-20">
    <div class="container max-w-3xl">
      <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">Work With Lavelle Pty Ltd</h2>
      <p class="text-slate-300 leading-relaxed mb-8">
        Talk to Lavelle Pty Ltd about consulting, contract project management or PMO resource enquiries.
      </p>
      <a
        href="/contact"
        data-ga-event="final_cta_click"
        class="inline-flex items-center px-7 py-3.5 text-base font-medium text-navy-950 bg-white hover:bg-slate-100 rounded-md transition-colors"
      >
        Send an Enquiry
      </a>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('lead-magnet-form') as HTMLFormElement;
  const btn = document.getElementById('lead-magnet-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('lead-magnet-success') as HTMLParagraphElement;
  const errorMsg = document.getElementById('lead-magnet-error') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    btn.disabled = true;
    btn.textContent = 'Sending...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        if (typeof window.gtag === 'function') window.gtag('event', 'lead_magnet_submit');
        window.location.href = '/free-tools/project-recovery-checklist/thanks';
        return;
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send the checklist';
    }
  });
</script>
