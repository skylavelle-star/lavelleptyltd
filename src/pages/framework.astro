---
import BaseLayout from "../layouts/BaseLayout.astro";

const stages = [
  {
    number: "01",
    name: "Initiation",
    duration: "1-8 weeks",
    produces: "A funded mandate",
    description:
      "Establish sponsor intent, governance structure, funding pathway and approval routes. The work of this stage is to leave with permission to spend money on Discovery.",
  },
  {
    number: "02",
    name: "Discovery",
    duration: "4-16 weeks",
    produces: "A defensible recommendation",
    description:
      "Frame the problem, test options, shape the business case and align stakeholders. Discovery ends with a recommendation the executive can defend.",
  },
  {
    number: "03",
    name: "Design",
    duration: "4-24 weeks",
    produces: "An agreed solution",
    description:
      "Define the solution. Architecture, detailed design and design authority endorsement. The solution is now specific enough to build to.",
  },
  {
    number: "04",
    name: "Build",
    duration: "Variable",
    produces: "Working capability",
    description:
      "Construct the solution. Configure, integrate and verify against design intent. Duration scales with scope; cadence stays steady.",
  },
  {
    number: "05",
    name: "Test",
    duration: "4-16 weeks",
    produces: "Evidence of fit",
    description:
      "Prove the solution. System, integration and user acceptance through to go-live readiness. The test record is what the gate decision rests on.",
  },
  {
    number: "06",
    name: "Cutover",
    duration: "1-4 weeks",
    produces: "Executed runsheet · evidenced · reversible",
    description:
      "Transition to live. Go/no-go decision, deployment and operational stand-up. Every step is on the runsheet, evidenced and reversible if the rollback is called.",
  },
  {
    number: "07",
    name: "Closure",
    duration: "2-6 weeks",
    produces: "Benefits handed over · finances reconciled · lessons captured",
    description:
      "Closure report, financial close, benefits handover and lessons learned. The work returns to the organisation with the artefacts and accountability in place.",
  },
];

const paths = [
  {
    name: "Predictive",
    summary: "Phase by phase. Gated. Paper trail.",
    bestFor:
      "Best where requirements are stable and a defensible paper trail is needed.",
  },
  {
    name: "Iterative",
    summary: "Short cycles. Steady cadence.",
    bestFor:
      "Best where requirements will move and the team runs to cadence.",
  },
  {
    name: "Hybrid",
    summary:
      "Predictive at the programme layer. Iterative at the team layer.",
    bestFor:
      "Best for most enterprise delivery - funding, procurement and assurance run on cadence, while delivery teams work in cycles.",
  },
];

const gates = [
  {
    id: "G1",
    name: "Authorise Initiation",
    decisions: [
      "Seed Funding Case received",
      "Project Brief sign-off",
      "Lite Business Case approved",
    ],
  },
  {
    id: "G2",
    name: "Authorise the Project",
    decisions: [
      "SteerCo Charter sign-off",
      "Procurement Management Approach approved",
      "Business Case signed off",
    ],
  },
  {
    id: "G3",
    name: "Authorise Stage - Design",
    decisions: [
      "Stage Plan - Design sign-off",
      "Design authority endorsement",
      "Cost Tolerance Tracker live",
    ],
  },
  {
    id: "G4",
    name: "Authorise Stage - Build",
    decisions: ["Stage Plan - Build complete sign-off", "Integration verified"],
  },
  {
    id: "G5",
    name: "Authorise Release",
    decisions: [
      "Go No-Go Checklist sign-off",
      "Release Plan sign-off",
    ],
  },
  {
    id: "G6",
    name: "Authorise Project Closure",
    decisions: [
      "End Project Report sign-off",
      "Lessons Report captured",
      "Project closed",
    ],
  },
];
---

<BaseLayout
  title="Framework - Lavelle Pty Ltd"
  description="The Lavelle Delivery Framework v1.0. Seven stages, six gates, three paths. A practical structure for governing and executing complex technology and business change."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Framework</span>
      </div>
      <h1>
        The Lavelle Delivery Framework. <em
          >Seven stages. Six gates. Three paths.</em>
      </h1>
      <p class="subhero__lead">
        A practical structure for delivering complex technology and business
        change. Seven stages give the work shape. Six gates give it assurance.
        Three paths - predictive, iterative or hybrid - let the approach fit
        the work rather than the other way around. The framework is the
        navigational spine of this site: every template, pack and bundle links
        back to its stage and gate.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Framework</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            The seven <em>stages.</em>
          </h2>
        </div>
        <p class="lead">
          Initiation and Discovery set up the work. Design, Build and Test
          deliver it. Cutover and Closure return it to the organisation with
          the right artefacts and accountability.
        </p>
      </header>

      <div class="stages">
        {
          stages.map((stage) => (
            <article class="stage">
              <div class="stage__num">{stage.number}</div>
              <h3 class="stage__title">{stage.name}</h3>
              <div class="stage__meta">
                <span class="stage__duration">{stage.duration}</span>
                <span aria-hidden="true">·</span>
                <span class="stage__produces">Produces: {stage.produces}</span>
              </div>
              <p class="stage__desc">{stage.description}</p>
            </article>
          ))
        }
      </div>

      <aside class="not-a-stage">
        <div class="not-a-stage__label">Important</div>
        <p>
          <strong>Recovery is not a stage.</strong> Project Recovery is a
          consulting offer (see <a href="/consulting#recovery">Consulting</a>)
          and a constructed bundle of existing artefacts (see <a
            href="/bundles">Project Recovery Bundle</a>). It sits across the
          framework, not inside it.
        </p>
      </aside>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Three paths</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Predictive, iterative <em>or hybrid.</em>
          </h2>
        </div>
        <p class="lead">
          The stages stay the same. The path through them changes with the
          work. Most enterprise delivery runs hybrid - but the choice is
          deliberate, not residual.
        </p>
      </header>

      <div class="paths">
        {
          paths.map((path) => (
            <article class="path">
              <div class="path__label">{path.name}</div>
              <h3 class="path__title">{path.summary}</h3>
              <p class="path__best">{path.bestFor}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Governance assurance</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            The six <em>gates.</em>
          </h2>
        </div>
        <p class="lead">
          Each gate is a named decision with a named decider. Gates exist to
          confirm the work is fit to continue - not to slow it down. The same
          six gates apply whether the work runs predictive, iterative or
          hybrid.
        </p>
      </header>

      <div class="gates">
        {
          gates.map((gate) => (
            <article class="gate">
              <div class="gate__head">
                <span class="gate__id">{gate.id}</span>
                <span class="gate__name">{gate.name}</span>
              </div>
              <ul class="gate__decisions">
                {gate.decisions.map((d) => (
                  <li>{d}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Apply this framework</div>
          <h2 style="margin-top:1.25rem;">Need help <em>applying it?</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            Every template, pack and bundle on this site is wired to a stage
            and a gate of the framework. The Tailoring Calculator routes you to
            the right bundle for your project's complexity. Consulting picks
            up where templates leave off.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Engage Lavelle <span class="btn__arrow">→</span>
            </a>
            <a
              href="/templates"
              class="btn"
              style="background:transparent; color:var(--bone); border:1px solid var(--bone);"
            >
              Browse Templates
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li>
            <a href="/consulting"
              ><span>Consulting capabilities</span><span>→</span></a>
          </li>
          <li>
            <a href="/templates"
              ><span>Stage-based packs</span><span>→</span></a>
          </li>
          <li>
            <a href="/bundles"
              ><span>Tier-based bundles</span><span>→</span></a>
          </li>
          <li>
            <a href="/free-tools"
              ><span>Free tools &amp; Tailoring Calculator</span><span>→</span></a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .stages {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 760px) {
    .stages {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1080px) {
    .stages {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .stage {
    background: var(--bone);
    border: 1px solid var(--rule);
    border-top: 3px solid var(--ochre);
    padding: 1.75rem;
  }
  .stage__num {
    font-family: "DM Sans", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: var(--ochre);
    margin-bottom: 0.6rem;
  }
  .stage__title {
    font-family: "Fraunces", serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  .stage__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: var(--micro);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 0.85rem;
  }
  .stage__duration {
    color: var(--ochre);
    font-weight: 500;
  }
  .stage__desc {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
  }

  .not-a-stage {
    margin-top: 2rem;
    padding: 1.5rem 1.75rem;
    background: var(--bone);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--ink);
  }
  .not-a-stage__label {
    font-family: "DM Sans", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.6rem;
  }
  .not-a-stage p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0;
    max-width: 72ch;
  }

  .paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 860px) {
    .paths {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .path {
    background: var(--bone);
    border: 1px solid var(--rule);
    border-top: 3px solid var(--ochre);
    padding: 1.75rem;
  }
  .path__label {
    font-family: "DM Sans", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ochre);
    margin-bottom: 0.75rem;
  }
  .path__title {
    font-family: "Fraunces", serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.85rem;
    line-height: 1.25;
  }
  .path__best {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
  }

  .gates {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 760px) {
    .gates {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1080px) {
    .gates {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .gate {
    background: var(--bone);
    border: 1px solid var(--rule);
    padding: 1.5rem;
    border-left: 3px solid var(--ochre);
  }
  .gate__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .gate__id {
    font-family: "DM Sans", sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    color: var(--ochre);
  }
  .gate__name {
    font-family: "Fraunces", serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--ink);
  }
  .gate__decisions {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .gate__decisions li {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }
  .gate__decisions li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 1px;
    background: var(--ochre);
  }
</style>
