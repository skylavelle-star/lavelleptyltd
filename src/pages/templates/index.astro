---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import templatesImage from "../../assets/images/templates.jpg";
import { site, products } from "../../config/site";

const library = products.completePractitionerLibrary;

// The full nine stage-based packs from STRATEGY.md §"3. Templates".
// `products` in site.ts holds the live, priced subset; this index renders all nine
// from the table below so STRATEGY.md stays the single source of truth for pack
// taxonomy. Live packs link through to their existing pages; the rest to stubs.

const stagePacks = [
  {
    name: "Business Case Pack",
    href: "/templates/business-case-pack",
    stage: "Initiation (G1 → G2)",
    description:
      "Business Case, Lite Business Case, Project Brief, Seed Funding Case, Business Case Workshop Pack.",
    status: "live" as const,
  },
  {
    name: "Project Setup Pack",
    href: "/templates/project-setup-pack",
    stage: "Initiation / Mobilisation",
    description:
      "Project Initiation Checklist, Project Plan Schedule, Project Plan, Scope & High-Level Requirements, Initiation Stage Kick-off Pack.",
    status: "stub" as const,
  },
  {
    name: "Discovery Pack",
    href: "/templates/discovery-pack",
    stage: "Discovery (G2 → G3)",
    description:
      "BA Discovery Assessment, Change Impact Assessment, Project Approach Selector, Project Assurance Checklist, Project Tailoring Calculator.",
    status: "stub" as const,
  },
  {
    name: "Requirements & Design Pack",
    href: "/templates/requirements-design-pack",
    stage: "Design (G3 → G4)",
    description:
      "Product Description — UI, Workflow, Use Case and Service; Product Gap Analysis; Requirements Traceability Matrix.",
    status: "stub" as const,
  },
  {
    name: "Financial Control Pack",
    href: "/templates/financial-control-pack",
    stage: "Spans all stages",
    description:
      "Cost Plan, Estimation Approach Guide, Stage Plan Budget, Cost Tolerance Tracker, Risk Budget Calculator, Labour Capitalisation Workbook, Configuration Item Register, Finance Journal Request, RAID Log.",
    status: "stub" as const,
  },
  {
    name: "Testing Pack",
    href: "/templates/testing-pack",
    stage: "Test (G4 → G5)",
    description:
      "Quality Management Approach, Quality Plan, Product Status Account, Quality Inspection Sheet.",
    status: "stub" as const,
  },
  {
    name: "Cutover Pack",
    href: "/templates/cutover-pack",
    stage: "Cutover (G5)",
    description: "Release Plan Runsheet, Go No-Go Checklist.",
    status: "stub" as const,
  },
  {
    name: "Steering Pack",
    href: "/templates/steering-committee-pack",
    stage: "Spans all stages",
    description:
      "SteerCo Charter, Lite Project Initiation Documentation, Steering Committee Pack, Highlight Report, Portfolio Highlight Report, Request for Change, Report Specification.",
    status: "live" as const,
  },
  {
    name: "Training / Change Pack",
    href: "/templates/training-change-pack",
    stage: "Cutover → Closure (G5 → G6)",
    description:
      "Communication & Training Approach, Operational Acceptance Criteria, Change Control Approach Review.",
    status: "stub" as const,
  },
];

const additionalPacks = [
  {
    name: "Procurement Pack",
    href: "/templates/procurement-pack",
    stage: "Sourcing / RFP",
    description:
      "Restricted-RFP evaluation set — evaluation plan, technical and commercial matrices, BAFO request, recommendation report, probity checklist.",
    status: "live" as const,
  },
  {
    name: "Project Recovery Pack",
    href: "/templates/project-recovery-pack",
    stage: "Consulting-led · stabilisation",
    description:
      "Recovery assessment, stakeholder reset, replan and governance artefacts. Sold alongside the Project Recovery consulting offer.",
    status: "live" as const,
  },
];

const additionalTemplates = [
  { name: "RAID Log", slug: "raid-log" },
  { name: "Daily Log", slug: "daily-log" },
  { name: "Highlight Report", slug: "highlight-report" },
  { name: "SteerCo Charter", slug: "project-initiation-documentation" },
  { name: "Project Plan", slug: "project-plan" },
  { name: "Benefits Management Approach", slug: "benefits-management-approach" },
  { name: "End Project Report", slug: "end-project-report" },
];
---

<BaseLayout
  title="Project Management Templates — Lavelle Pty Ltd"
  description="Practical project management templates for project recovery, business cases, procurement, steering committee reporting, RAID management and delivery governance."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Templates</span>
      </div>
      <h1>Project management templates. <em>For real delivery.</em></h1>
      <p class="subhero__lead">
        Lavelle Pty Ltd templates are designed for practical project
        environments where artefacts need to support decisions, governance and
        delivery, not just fill a document library.
      </p>
    </div>
  </section>

  <figure class="image-band">
    <Image
      src={templatesImage}
      alt="Two people sketching project artefacts on paper alongside laptops — the working state these templates are designed to support"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      loading="lazy"
      class="image-band__img"
    />
  </figure>

  <section style="background:var(--paper);">
    <div class="wrap">
      <div class="flagship-card">
        <div>
          <div class="eyebrow">Flagship · single transaction</div>
          <h2 class="flagship-card__title">
            The Complete Practitioner <em>Library.</em>
          </h2>
          <p class="flagship-card__lead">
            Every stage pack, every bundle, the Framework documentation and
            twelve months of artefact updates. One opinionated artefact set,
            one named user.
          </p>
        </div>
        <div class="flagship-card__cta">
          <div class="flagship-card__price">${library.price}</div>
          <div class="flagship-card__price-sub">single named user · AUD</div>
          <a href={library.href} class="btn btn--primary"
            >View the library <span class="btn__arrow">→</span></a
          >
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Nine stage-based packs</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            One pack per <em>framework stage.</em>
          </h2>
        </div>
        <p class="lead">
          Each pack is anchored to a stage and gate of the Lavelle Delivery
          Framework. Buy individually, or use the Tailoring Calculator to find
          the tier-based bundle that matches the complexity of your work.
        </p>
      </header>

      <div class="products">
        {
          stagePacks.map((pack) => (
            <article class="product">
              <span class="product__tag">
                {pack.status === "live" ? "Available" : "In development"}
              </span>
              <h3 class="product__title">{pack.name}</h3>
              <div class="product__stage">{pack.stage}</div>
              <p class="product__desc">{pack.description}</p>
              <div class="product__footer">
                <div>
                  <div class="product__price-sub">
                    {pack.status === "live" ? "Single user · AUD" : "Notify when shipped"}
                  </div>
                </div>
                <a href={pack.href} class="btn btn--primary">
                  View pack <span class="btn__arrow">→</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Additional packs</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Outside the framework, still in the <em>catalogue.</em>
          </h2>
        </div>
        <p class="lead">
          Two further packs sit alongside the nine framework-anchored packs —
          one for restricted-RFP procurement, one for consulting-led project
          recovery.
        </p>
      </header>

      <div class="products">
        {
          additionalPacks.map((pack) => (
            <article class="product">
              <span class="product__tag">
                {pack.status === "live" ? "Available" : "In development"}
              </span>
              <h3 class="product__title">{pack.name}</h3>
              <div class="product__stage">{pack.stage}</div>
              <p class="product__desc">{pack.description}</p>
              <div class="product__footer">
                <div>
                  <div class="product__price-sub">
                    {pack.status === "live" ? "Single user · AUD" : "Notify when shipped"}
                  </div>
                </div>
                <a href={pack.href} class="btn btn--primary">
                  View pack <span class="btn__arrow">→</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <div class="bundle-card">
        <div>
          <div class="eyebrow">Tier-based bundles</div>
          <h2
            style="font-family:'Fraunces',serif; font-size:2rem; font-weight:500; line-height:1.05; margin:1rem 0; color:var(--ink);"
          >
            The right bundle for the <em style="color:var(--ochre);"
              >complexity of the work.</em>
          </h2>
          <p
            style="font-size:var(--body); color:var(--ink-soft); margin-bottom:1.5rem; max-width:50ch;"
          >
            Three tier-based bundles — Tier 3 Light, Tier 2 Standard and Tier
            1 Major — mirror the Project Tailoring Calculator. Score the
            project, get the matching bundle.
          </p>
        </div>
        <a href="/bundles" class="btn btn--primary"
          >See the bundles <span class="btn__arrow">→</span></a
        >
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Individual templates</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Standalone <em>artefacts.</em>
          </h2>
        </div>
        <p class="lead">
          Individual governance and delivery artefacts, available separately
          from the packs.
        </p>
      </header>

      <div class="standalone-grid">
        {
          additionalTemplates.map((tpl) => (
            <article class="standalone-card">
              <div class="standalone-card__head">
                <h3>{tpl.name}</h3>
                <span class="standalone-card__tag">In development</span>
              </div>
              <form
                data-notify-form={`notify-${tpl.slug}`}
                class="tool-notify"
                novalidate
              >
                <input
                  type="hidden"
                  name="access_key"
                  value={site.web3formsKey}
                />
                <input
                  type="hidden"
                  name="subject"
                  value={`Interest: ${tpl.name} - lavelleptyltd.com.au`}
                />
                <input
                  type="hidden"
                  name="from_name"
                  value="Lavelle Pty Ltd Templates"
                />
                <input
                  type="hidden"
                  name="message"
                  value={`Interested in the ${tpl.name} template when available.`}
                />
                <input
                  type="checkbox"
                  name="botcheck"
                  class="hidden-bot"
                  tabindex="-1"
                  autocomplete="off"
                />
                <label for={`notify-${tpl.slug}-email`}>
                  Get notified when it ships
                </label>
                <div class="tool-notify__row">
                  <input
                    id={`notify-${tpl.slug}-email`}
                    type="email"
                    name="email"
                    required
                    placeholder="your@email.com"
                    autocomplete="email"
                  />
                  <button type="submit" class="btn btn--ghost">
                    Notify me
                  </button>
                </div>
                <p
                  id={`notify-success-notify-${tpl.slug}`}
                  class="tool-notify__success"
                  hidden
                >
                  Done — we will email you when it ships.
                </p>
              </form>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Not ready to purchase?</div>
          <h2 style="margin-top:1.25rem;">
            Start with the <em>free tools.</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            The Project Recovery Checklist and other free resources are
            available at no cost.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/free-tools" class="btn btn--primary"
              >Browse free tools <span class="btn__arrow">→</span></a
            >
            <a
              href="/contact"
              class="btn"
              style="background:transparent; color:var(--bone); border:1px solid var(--bone);"
              >Send an enquiry</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .product__stage {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ochre);
    margin-bottom: 0.85rem;
  }
  .bundle-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
    padding: 2.5rem;
    background: var(--bone);
    border: 1px solid var(--rule);
  }
  @media (min-width: 880px) {
    .bundle-card {
      grid-template-columns: 1.5fr auto;
      gap: 3rem;
    }
  }
  .flagship-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    padding: 3rem;
    background: var(--bone);
    border: 2px solid var(--ochre);
  }
  @media (min-width: 880px) {
    .flagship-card {
      grid-template-columns: 1.5fr auto;
      gap: 3rem;
    }
  }
  .flagship-card__title {
    font-family: "Fraunces", serif;
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.05;
    margin: 1rem 0;
    color: var(--ink);
  }
  .flagship-card__title em {
    color: var(--ochre);
  }
  .flagship-card__lead {
    font-size: var(--body);
    color: var(--ink-soft);
    max-width: 56ch;
  }
  .flagship-card__cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .flagship-card__price {
    font-family: "Fraunces", serif;
    font-size: 2.5rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
  }
  .flagship-card__price-sub {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 0.85rem;
  }
  .bundle-card__price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    font-size: var(--body-sm);
  }
  .bundle-card__price {
    font-family: "Fraunces", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--ink);
  }
  .bundle-card__strike {
    text-decoration: line-through;
    color: var(--sage);
  }
  .bundle-card__save {
    color: var(--ochre);
    font-weight: 500;
  }
  .standalone-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 760px) {
    .standalone-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .standalone-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .standalone-card {
    border: 1px solid var(--rule);
    background: var(--bone);
    padding: 1.5rem 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .standalone-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .standalone-card__head h3 {
    font-family: "Fraunces", serif;
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
  }
  .standalone-card__tag {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    border: 1px solid var(--rule);
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .tool-notify {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tool-notify label {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 500;
  }
  .tool-notify__row {
    display: flex;
    gap: 0.5rem;
  }
  .tool-notify input[type="email"] {
    flex: 1;
    min-width: 0;
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-family: inherit;
    font-size: var(--body-sm);
  }
  .tool-notify input[type="email"]:focus {
    outline: none;
    border-color: var(--ochre);
  }
  .tool-notify .btn {
    padding: 0.55rem 1rem;
    font-size: var(--micro);
  }
  .tool-notify__success {
    font-size: var(--body-sm);
    color: var(--ochre);
  }
  .tool-notify__success[hidden] {
    display: none;
  }
  .hidden-bot {
    display: none;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLFormElement>("[data-notify-form]")
    .forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const id = form.dataset.notifyForm!;
        const btn = form.querySelector<HTMLButtonElement>('[type="submit"]');
        const botcheck =
          form.querySelector<HTMLInputElement>('[name="botcheck"]');
        if (botcheck?.checked) return;
        if (btn) {
          btn.disabled = true;
          btn.textContent = "Sending…";
        }
        let ok = false;
        try {
          const res = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(
              Object.fromEntries(new FormData(form).entries()),
            ),
          });
          const data = (await res.json().catch(() => ({}))) as {
            success?: boolean;
          };
          ok = data.success === true;
        } catch {
          /* silent */
        }
        if (ok) {
          form
            .querySelectorAll("input, button, label, .tool-notify__row")
            .forEach((el) => {
              (el as HTMLElement).hidden = true;
            });
          const success = document.getElementById(`notify-success-${id}`);
          if (success) success.hidden = false;
        } else if (btn) {
          btn.disabled = false;
          btn.textContent = "Notify me";
        }
      });
    });
</script>
