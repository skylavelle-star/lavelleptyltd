---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import templatesImage from '../../assets/images/templates.jpg';
import { products } from '../../config/site';

const { bundlePack, ...individualPacks } = products;
const paidPacks = Object.values(individualPacks);

const additionalTemplates = [
  'RAID Register',
  'Decision Log',
  'Weekly Status Report',
  'Project Initiation Document',
  'Project Management Plan',
  'Benefits Register',
  'Closure Report',
];
---

<BaseLayout
  title="Project Management Templates — Lavelle Pty Ltd"
  description="Practical project management templates for project recovery, business cases, procurement, steering committee reporting, RAID management and delivery governance."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Templates</span>
      </div>
      <h1>Project management templates. <em>For real delivery.</em></h1>
      <p class="subhero__lead">
        Lavelle Pty Ltd templates are designed for practical project environments where artefacts need to support decisions, governance and delivery, not just fill a document library.
      </p>
    </div>
  </section>

  <figure class="image-band">
    <Image
      src={templatesImage}
      alt="Two people sketching project artefacts on paper alongside laptops — the working state these templates are designed to support"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      loading="lazy"
      class="image-band__img"
    />
  </figure>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Template packs</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Structured packs<br />for <em>specific needs.</em>
          </h2>
        </div>
        <p class="lead">
          Each pack brings together the templates, artefacts and guidance for a specific delivery challenge.
        </p>
      </header>

      <div class="products">
        {paidPacks.map((pack) => (
          <article class="product">
            <span class="product__tag">
              {pack.checkoutUrl ? 'Available' : 'Coming Soon'}
            </span>
            <h3 class="product__title">{pack.name}</h3>
            <p class="product__desc">{pack.description}</p>
            <div class="product__footer">
              <div>
                {pack.checkoutUrl ? (
                  <>
                    <div class="product__price">{pack.price}</div>
                    <div class="product__price-sub">AUD</div>
                  </>
                ) : (
                  <div class="product__price-sub">Coming soon</div>
                )}
              </div>
              <a href={pack.href} class="btn btn--primary">
                View pack <span class="btn__arrow">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <div class="bundle-card">
        <div>
          <div class="eyebrow">Best value</div>
          <h2 style="font-family:'Fraunces',serif; font-size:2rem; font-weight:500; line-height:1.05; margin:1rem 0; color:var(--ink);">
            Four-Pack Bundle. <em style="color:var(--ochre);">All four packs.</em>
          </h2>
          <p style="font-size:var(--body); color:var(--ink-soft); margin-bottom:1.5rem; max-width:50ch;">
            All four PMO packs — Steering Committee, Business Case, Procurement and Project Recovery — in one purchase.
          </p>
          <div class="bundle-card__price-row">
            <span class="bundle-card__price">AUD 797</span>
            <span class="bundle-card__strike">AUD 988 individually</span>
            <span class="bundle-card__save">Save AUD 191</span>
          </div>
        </div>
        <a href={bundlePack.href} class="btn btn--primary">View bundle <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Individual templates</div>
          <h2 class="section__title" style="margin-top:1.25rem;">Standalone <em>artefacts.</em></h2>
        </div>
        <p class="lead">
          Individual governance and delivery artefacts, available separately from the packs.
        </p>
      </header>

      <div class="standalone-grid">
        {additionalTemplates.map((name) => (
          <div class="standalone">
            <span>{name}</span>
            <span class="standalone__tag">Coming soon</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Not ready to purchase?</div>
          <h2 style="margin-top:1.25rem;">Start with the <em>free tools.</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            The Project Recovery Checklist and other free resources are available at no cost.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/free-tools" class="btn btn--primary">Browse free tools <span class="btn__arrow">→</span></a>
            <a href="/contact" class="btn" style="background:transparent; color:var(--bone); border:1px solid var(--bone);">Send an enquiry</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bundle-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
    padding: 2.5rem;
    background: var(--bone);
    border: 1px solid var(--rule);
  }
  @media (min-width: 880px) {
    .bundle-card {
      grid-template-columns: 1.5fr auto;
      gap: 3rem;
    }
  }
  .bundle-card__price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    font-size: var(--body-sm);
  }
  .bundle-card__price {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--ink);
  }
  .bundle-card__strike {
    text-decoration: line-through;
    color: var(--sage);
  }
  .bundle-card__save {
    color: var(--ochre);
    font-weight: 500;
  }
  .standalone-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 600px) {
    .standalone-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .standalone-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .standalone {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border: 1px solid var(--rule);
    background: var(--bone);
    font-size: var(--body-sm);
    color: var(--ink-soft);
  }
  .standalone__tag {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
  }
</style>
