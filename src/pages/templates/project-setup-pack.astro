---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StubPack from "../../components/StubPack.astro";
import { products } from "../../config/site";

const pack = products.projectSetupPack;

// TODO: Pack copy and tagline pending.
---

<BaseLayout
  title="Project Setup Pack — Lavelle Pty Ltd"
  description="The artefacts a new project manager needs in the first two weeks. Onboarding checklist, project schedule, PMP, scope and high-level requirements, kick-off pack."
>
  <StubPack
    packName="Project Setup Pack"
    packSlug="project-setup-pack"
    frameworkStage="Initiation / Mobilisation"
    frameworkGate="G1 Approve → G2 Discover"
    subhead="The artefacts a new project manager needs in the first two weeks of mobilisation. The pack that turns a funded mandate into a running project."
    artefacts={[
      "Project Initiation Checklist",
      "Project Plan Schedule",
      "Project Plan",
      "Scope & High-Level Requirements",
      "Initiation Stage Kick-off Pack",
    ]}
    price={pack.price}
    roiBlock="About two days of senior PM work covering onboarding, scheduling, the plan, the scope and the kick-off — $3,000 of bespoke artefact development at $1,500/day contractor rates. Pack: $847. ROI: ~3.5×. The opinionated thinking and the framework lineage are the part you can't outsource."
  />
</BaseLayout>
