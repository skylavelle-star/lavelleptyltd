---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StubPack from "../../components/StubPack.astro";
import { products } from "../../config/site";

const pack = products.testingPack;

// TODO: STRATEGY.md does not quote a tagline for Testing Pack.
---

<BaseLayout
  title="Testing Pack — Lavelle Pty Ltd"
  description="The Test stage artefact set. Test strategy, test plan, test summary report and test script — the evidence record that the cutover decision rests on."
>
  <StubPack
    packName="Testing Pack"
    packSlug="testing-pack"
    frameworkStage="Test"
    frameworkGate="G4 Build → G5 Cutover"
    subhead="The artefacts that prove the solution fits. System, integration and user acceptance testing — through to the evidence record the cutover decision rests on."
    artefacts={[
      "Quality Management Approach",
      "Quality Plan",
      "Product Status Account",
      "Quality Inspection Sheet",
    ]}
    price={pack.price}
    roiBlock="A day and a half of senior PM work assembling a test strategy, a test plan, a test summary report and a working test script — $2,250 of bespoke artefact development at $1,500/day contractor rates. Pack: $747. ROI: ~3×. The opinionated thinking and the framework lineage are the part you can't outsource."
  />
</BaseLayout>
