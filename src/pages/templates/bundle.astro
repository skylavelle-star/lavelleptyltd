---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../config/site';

const bundle = products.bundlePack;
const checkoutUrl = bundle.checkoutUrl || undefined;

const packs = [
  {
    name: 'Steering Committee Pack',
    price: 'AUD 147',
    href: '/templates/steering-committee-pack',
    count: '8 documents',
    items: ['Status Report Template', 'Executive Dashboard', 'RAID Register', 'Decision Register', 'Escalation Paper Template', 'RAG Rating Guide', 'Committee Agenda Template', 'Action Register'],
  },
  {
    name: 'Business Case Pack',
    price: 'AUD 247',
    href: '/templates/business-case-pack',
    count: 'Full end-to-end structure',
    items: ['Problem Statement and Case for Change', 'Options Analysis Framework', 'Benefits Register', 'Financial Model', 'Risk Register', 'Dependency Log', 'Delegate Approval Templates'],
  },
  {
    name: 'Procurement Pack',
    price: 'AUD 297',
    href: '/templates/procurement-pack',
    count: 'RFP to approval',
    items: ['RFP Planning Template', 'Evaluation Criteria and Scoring Matrix', 'Supplier Response Register', 'BAFO Process Templates', 'Recommendation Report', 'Delegate Approval Record'],
  },
  {
    name: 'Project Recovery Pack',
    price: 'AUD 297',
    href: '/templates/project-recovery-pack',
    count: '9 documents',
    items: ['Project Health Diagnostic', 'Recovery Assessment Workbook', 'Stakeholder Reset Plan', 'Executive Reset Briefing', 'Re-Baselined Delivery Roadmap', 'Vendor Remediation Plan', 'Risk Re-Baselining Workbook', '30/60/90 Day Recovery Plan', 'Steering Committee Recovery Pack'],
  },
];

const individualTotal = 147 + 247 + 297 + 297;
const bundlePrice = 797;
const saving = individualTotal - bundlePrice;

const faqs = [
  { q: 'What format are the templates in?', a: 'Microsoft Word (.docx) and Excel (.xlsx). All documents are fully editable and work in Google Docs and Google Sheets, though some conditional formatting may not carry across.' },
  { q: 'Is this a single download?', a: 'Yes. After purchase via Lemon Squeezy you receive a single download link containing all four packs in clearly labelled folders.' },
  { q: 'Can I buy individual packs instead?', a: `Yes — each pack is available separately. The bundle saves AUD ${saving} versus buying all four individually.` },
  { q: 'Do I get updates if a pack is revised?', a: 'Purchases include access to the version available at time of purchase. Major revisions are released as new products.' },
  { q: 'Can my organisation use these across multiple projects?', a: 'Your purchase gives you a single-user licence. For multi-seat or organisational access, see our enterprise licensing options.' },
];
---

<BaseLayout
  title="Four-Pack Bundle — Lavelle Pty Ltd"
  description="All four Lavelle Pty Ltd PMO packs — Steering Committee, Business Case, Procurement and Project Recovery — in one purchase at AUD 797."
>
  {checkoutUrl && <script src="https://assets.lemonsqueezy.com/lemon.js" defer></script>}

  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/templates">Templates</a> &nbsp;/&nbsp; <span>Four-Pack Bundle</span>
      </div>
      <h1>The Four-Pack Bundle. <em>Your entire delivery system.</em></h1>
      <p class="subhero__lead">
        All four PMO packs — Steering Committee, Business Case, Procurement and Project Recovery — in one purchase. AUD {saving} saving versus buying individually.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="split">
        <div class="prose">
          {checkoutUrl ? (
            <div class="bundle-price-row">
              <div>
                <span class="bundle-price">{bundle.price}</span>
                <span class="bundle-strike">AUD {individualTotal} individually</span>
              </div>
              <a href={checkoutUrl} class="lemonsqueezy-button btn btn--primary" data-ga-event="product_buy_click" data-ga-label="Four-Pack Bundle">
                Buy bundle <span class="btn__arrow">→</span>
              </a>
            </div>
          ) : (
            <div class="pack-coming">
              Coming soon —
              <a href="/contact" style="color:var(--ochre); text-decoration:underline; margin-left:0.4rem;">register your interest</a>
            </div>
          )}

          <h2>What is included</h2>
          <p>
            The four-pack bundle gives you the complete Lavelle Pty Ltd PMO artefact library — covering governance, recovery, business case development and procurement — in one download.
          </p>

          <div class="pack-list">
            {packs.map((pack) => (
              <div class="pack-block">
                <div class="pack-block__head">
                  <a href={pack.href} class="pack-block__name">{pack.name}</a>
                  <span class="pack-block__meta">{pack.count} · {pack.price}</span>
                </div>
                <ul class="pack-block__items">
                  {pack.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            ))}
          </div>

          <h2>Who it is for</h2>
          <ul>
            <li>PMO leads building a practice from scratch who need the full artefact library</li>
            <li>Senior project managers who regularly step into governance, recovery and procurement contexts</li>
            <li>Consulting firms who want a solid PMO baseline they can customise for each engagement</li>
            <li>Organisations building internal PMO capability and needing standardised artefacts across the function</li>
          </ul>

          <h2>Format and delivery</h2>
          <p>
            Microsoft Word templates (.docx) and Excel workbooks (.xlsx) across all four packs. All documents are fully editable. Delivered as a single download via Lemon Squeezy after purchase.
          </p>

          <h2>Frequently asked questions</h2>
          <div class="faq-list">
            {faqs.map((item) => (
              <details class="faq">
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>

          {checkoutUrl && (
            <div style="margin-top:2.5rem;">
              <a href={checkoutUrl} class="lemonsqueezy-button btn btn--primary" data-ga-event="product_buy_click" data-ga-label="Four-Pack Bundle">
                Buy bundle <span class="btn__arrow">→</span>
              </a>
            </div>
          )}
        </div>

        <aside class="sidecard">
          {checkoutUrl ? (
            <>
              <h4>One-time purchase</h4>
              <div class="bundle-price" style="margin-bottom:0.25rem;">{bundle.price} <span class="bundle-price-sub">AUD</span></div>
              <p style="font-size:var(--body-sm); color:var(--sage); text-decoration:line-through; margin-bottom:0.25rem;">
                AUD {individualTotal} individually
              </p>
              <p style="font-size:var(--body-sm); color:var(--ochre); font-weight:500; margin-bottom:1.5rem;">
                Save AUD {saving}
              </p>
              <a href={checkoutUrl} class="lemonsqueezy-button btn btn--primary" data-ga-event="product_buy_click" data-ga-label="Four-Pack Bundle">
                Buy bundle <span class="btn__arrow">→</span>
              </a>
              <ul style="margin-top:1.5rem;">
                <li>All four PMO packs included</li>
                <li>Microsoft Word + Excel format</li>
                <li>Fully editable templates</li>
                <li>Australian English</li>
                <li>Delivered via Lemon Squeezy</li>
              </ul>
            </>
          ) : (
            <>
              <h4>Coming soon</h4>
              <p style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1.5rem;">
                Register your interest to be notified when the bundle is available.
              </p>
              <a href="/contact" class="btn btn--primary">Register interest <span class="btn__arrow">→</span></a>
            </>
          )}

          <h4 style="margin-top:2rem;">Or buy individually</h4>
          <ul style="font-size:var(--body-sm);">
            {packs.map((pack) => (
              <li style="display:flex; justify-content:space-between; gap:0.5rem; padding-left:0;">
                <a href={pack.href} style="color:var(--ink-soft);">{pack.name}</a>
                <span style="color:var(--sage);">{pack.price}</span>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bundle-price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1rem;
  }
  .bundle-price {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
  }
  .bundle-price-sub {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    margin-left: 0.4rem;
  }
  .bundle-strike {
    font-size: var(--body-sm);
    color: var(--sage);
    text-decoration: line-through;
    margin-left: 0.75rem;
  }
  .pack-coming {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-size: var(--body-sm);
    color: var(--ink-soft);
    margin-bottom: 1rem;
  }
  .pack-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0 2rem;
  }
  .pack-block {
    border: 1px solid var(--rule);
    background: var(--bone);
  }
  .pack-block__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
  }
  .pack-block__name {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--ink);
  }
  .pack-block__name:hover {
    color: var(--ochre);
  }
  .pack-block__meta {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
  }
  .pack-block__items {
    list-style: none;
    padding: 1rem 1.25rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }
  @media (min-width: 600px) {
    .pack-block__items {
      grid-template-columns: 1fr 1fr;
    }
  }
  .pack-block__items li {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    padding-left: 1.25rem;
    position: relative;
  }
  .pack-block__items li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--ochre);
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1rem 0 2rem;
  }
  .faq {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 1rem 1.25rem;
  }
  .faq summary {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq summary::before {
    content: '+';
    display: inline-block;
    color: var(--ochre);
    margin-right: 0.75rem;
  }
  .faq[open] summary::before {
    content: '−';
  }
  .faq p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    margin-top: 0.75rem;
    max-width: none;
  }
</style>
