---
import Layout from '../../layouts/Layout.astro';
import BuyButton from '../../components/BuyButton.astro';
import { products } from '../../config/site';

const bundle = products.bundlePack;
const checkoutUrl = bundle.checkoutUrl || undefined;

const packs = [
  {
    name: 'Steering Committee Pack',
    price: 'AUD 147',
    href: '/templates/steering-committee-pack',
    count: '8 documents',
    items: [
      'Status Report Template',
      'Executive Dashboard',
      'RAID Register',
      'Decision Register',
      'Escalation Paper Template',
      'RAG Rating Guide',
      'Committee Agenda Template',
      'Action Register',
    ],
  },
  {
    name: 'Business Case Pack',
    price: 'AUD 247',
    href: '/templates/business-case-pack',
    count: 'Full end-to-end structure',
    items: [
      'Problem Statement and Case for Change',
      'Options Analysis Framework',
      'Benefits Register',
      'Financial Model',
      'Risk Register',
      'Dependency Log',
      'Delegate Approval Templates',
    ],
  },
  {
    name: 'Procurement Pack',
    price: 'AUD 297',
    href: '/templates/procurement-pack',
    count: 'RFP to approval',
    items: [
      'RFP Planning Template',
      'Evaluation Criteria and Scoring Matrix',
      'Supplier Response Register',
      'BAFO Process Templates',
      'Recommendation Report',
      'Delegate Approval Record',
    ],
  },
  {
    name: 'Project Recovery Pack',
    price: 'AUD 297',
    href: '/templates/project-recovery-pack',
    count: '9 documents',
    items: [
      'Project Health Diagnostic',
      'Recovery Assessment Workbook',
      'Stakeholder Reset Plan',
      'Executive Reset Briefing',
      'Re-Baselined Delivery Roadmap',
      'Vendor Remediation Plan',
      'Risk Re-Baselining Workbook',
      '30/60/90 Day Recovery Plan',
      'Steering Committee Recovery Pack',
    ],
  },
];

const individualTotal = 147 + 247 + 297 + 297;
const bundlePrice = 797;
const saving = individualTotal - bundlePrice;

const faqs = [
  { q: 'What format are the templates in?', a: 'Microsoft Word (.docx) and Excel (.xlsx). All documents are fully editable and work in Google Docs and Google Sheets, though some conditional formatting may not carry across.' },
  { q: 'Is this a single download?', a: 'Yes. After purchase via Lemon Squeezy you receive a single download link containing all four packs in clearly labelled folders.' },
  { q: 'Can I buy individual packs instead?', a: 'Yes - each pack is available separately. The bundle saves AUD ' + saving + ' versus buying all four individually.' },
  { q: 'Do I get updates if a pack is revised?', a: 'Purchases include access to the version available at time of purchase. Major revisions are released as new products.' },
  { q: 'Can my organisation use these across multiple projects?', a: 'Your purchase gives you a single-user licence. For multi-seat or organisational access, see our enterprise licensing options.' },
];
---

<Layout
  title="Four-Pack Bundle | Lavelle Pty Ltd"
  description="All four Lavelle Pty Ltd PMO packs - Steering Committee, Business Case, Procurement and Project Recovery - in one purchase at AUD 797."
>
  {checkoutUrl && <script slot="head" src="https://assets.lemonsqueezy.com/lemon.js" defer></script>}

  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Templates</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Four-Pack Bundle</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          All four PMO packs - Steering Committee, Business Case, Procurement and Project Recovery - in one purchase. AUD {saving} saving versus buying individually.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-10">

          {checkoutUrl ? (
            <div class="flex items-center gap-6 flex-wrap">
              <div>
                <span class="text-3xl font-bold text-slate-900">{bundle.price}</span>
                <span class="text-sm text-slate-500 ml-1">AUD</span>
                <span class="ml-3 text-sm text-slate-400 line-through">AUD {individualTotal}</span>
                <span class="ml-2 text-sm font-semibold text-emerald-600">Save AUD {saving}</span>
              </div>
              <BuyButton checkoutUrl={checkoutUrl} label="Buy Bundle" fullWidth={false} gaEvent="product_buy_click" gaLabel="Four-Pack Bundle" />
            </div>
          ) : (
            <div class="inline-flex items-center px-4 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 border border-slate-200 rounded-md">
              Coming Soon - <a href="/contact" class="ml-1 text-navy-700 hover:text-navy-900 underline">register your interest</a>
            </div>
          )}

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-2">What Is Included</h2>
            <p class="text-slate-600 mb-6">The four-pack bundle gives you the complete Lavelle Pty Ltd PMO artefact library - covering governance, recovery, business case development and procurement - in one download.</p>
            <div class="space-y-5">
              {packs.map((pack) => (
                <div class="border border-slate-200 rounded-lg overflow-hidden">
                  <div class="flex items-center justify-between px-5 py-3 bg-slate-50 border-b border-slate-200">
                    <div>
                      <a href={pack.href} class="text-sm font-bold text-navy-800 hover:text-navy-900 hover:underline">{pack.name}</a>
                      <span class="text-xs text-slate-500 ml-2">- {pack.count}</span>
                    </div>
                    <span class="text-xs text-slate-400">{pack.price}</span>
                  </div>
                  <ul class="px-5 py-3 grid grid-cols-1 sm:grid-cols-2 gap-1">
                    {pack.items.map((item) => (
                      <li class="flex items-start gap-2 text-xs text-slate-600">
                        <svg class="w-3.5 h-3.5 text-navy-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Who It Is For</h2>
            <ul class="space-y-2.5">
              {[
                'PMO leads building a practice from scratch who need the full artefact library',
                'Senior project managers who regularly step into governance, recovery and procurement contexts',
                'Consulting firms who want a solid PMO baseline they can customise for each engagement',
                'Organisations building internal PMO capability and needing standardised artefacts across the function',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-bold text-slate-900 mb-2">Format and Delivery</h2>
            <p class="text-sm text-slate-600">Microsoft Word templates (.docx) and Excel workbooks (.xlsx) across all four packs. All documents are fully editable. Delivered as a single download via Lemon Squeezy after purchase.</p>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Frequently Asked Questions</h2>
            <div class="space-y-3">
              {faqs.map(({ q, a }) => (
                <div class="border border-slate-200 rounded-lg p-4">
                  <p class="text-sm font-semibold text-slate-900 mb-1.5">{q}</p>
                  <p class="text-sm text-slate-600 leading-relaxed">{a}</p>
                </div>
              ))}
            </div>
          </div>

          {checkoutUrl && (
            <div>
              <BuyButton checkoutUrl={checkoutUrl} label="Buy Bundle" gaEvent="product_buy_click" gaLabel="Four-Pack Bundle" />
            </div>
          )}

        </div>

        <aside class="space-y-5">
          <div class="rounded-lg border border-navy-200 bg-white p-6 sticky top-24">
            {checkoutUrl ? (
              <>
                <div class="mb-1">
                  <span class="text-3xl font-bold text-slate-900">{bundle.price}</span>
                  <span class="text-sm text-slate-500 ml-1">AUD</span>
                </div>
                <p class="text-sm text-slate-400 line-through mb-1">AUD {individualTotal} individually</p>
                <p class="text-sm font-semibold text-emerald-600 mb-4">You save AUD {saving}</p>
                <BuyButton checkoutUrl={checkoutUrl} label="Buy Bundle" gaEvent="product_buy_click" gaLabel="Four-Pack Bundle" />
                <div class="mt-4 pt-4 border-t border-slate-100 space-y-2">
                  {['All 4 PMO packs included', 'Microsoft Word + Excel format', 'Fully editable templates', 'Australian English', 'Delivered via Lemon Squeezy'].map((f) => (
                    <div class="flex items-center gap-2 text-sm text-slate-600">
                      <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {f}
                    </div>
                  ))}
                </div>
              </>
            ) : (
              <>
                <h2 class="text-base font-semibold text-slate-900 mb-2">Coming Soon</h2>
                <p class="text-sm text-slate-600 mb-4">Register your interest to be notified when the bundle is available.</p>
                <a href="/contact" class="inline-flex items-center w-full justify-center px-4 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors">
                  Register Interest
                </a>
              </>
            )}
            <div class="mt-5 pt-4 border-t border-slate-100">
              <p class="text-xs text-slate-500 mb-2">Need multi-seat access?</p>
              <a href="/enterprise-licensing" class="text-xs font-medium text-navy-700 hover:text-navy-900 underline">View enterprise licensing</a>
            </div>
          </div>

          <div class="rounded-lg border border-slate-200 p-5 space-y-3">
            <h2 class="text-sm font-semibold text-slate-900">Or buy individually</h2>
            {packs.map((pack) => (
              <a href={pack.href} class="flex items-center justify-between text-xs text-slate-600 hover:text-navy-700">
                <span>{pack.name}</span>
                <span class="font-medium">{pack.price}</span>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
