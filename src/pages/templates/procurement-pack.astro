---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PackPage from "../../components/PackPage.astro";
import { products } from "../../config/site";

const pack = products.procurementPack;
const checkoutUrl = pack.checkoutUrl || undefined;

const audience = [
  "Project managers and procurement teams running a restricted technology tender",
  "Evaluation panel chairs who need a structured and defensible evaluation process",
  "Program managers preparing delegate approval documentation after a BAFO process",
  "Governance and probity leads who need clear documentation of evaluation decisions",
];

const problemStatement = [
  "Technology procurement processes fail on governance when the evaluation is not structured, scoring is inconsistent, or the recommendation cannot be traced back to the evaluation criteria. This pack provides the artefacts needed to run a defensible, probity-sound evaluation.",
  "The templates are designed for the governance and accountability requirements common in government and regulated sector technology acquisitions.",
];

const included = [
  {
    title: "RFP Evaluation Plan",
    desc: "A structured plan for the evaluation process, including evaluation criteria, scoring approach, panel roles and probity arrangements.",
  },
  {
    title: "Technical Evaluation Matrix",
    desc: "A scoring matrix for assessing supplier technical responses against defined criteria and weightings.",
  },
  {
    title: "Commercial Evaluation Matrix",
    desc: "A scoring matrix for assessing commercial terms, pricing and contract structure.",
  },
  {
    title: "Supplier Clarification Register",
    desc: "A structured register for managing written clarifications during the evaluation period.",
  },
  {
    title: "BAFO Request Template",
    desc: "A formal template for issuing a Best and Final Offer request to shortlisted suppliers.",
  },
  {
    title: "Evaluation Recommendation Report",
    desc: "A structured report template for documenting the evaluation outcome, recommended supplier and supporting rationale.",
  },
  {
    title: "Probity Checklist",
    desc: "A checklist for reviewing probity obligations throughout the evaluation process.",
  },
];

const howToUse = [
  {
    title: "Start with the evaluation plan before issuing the RFP",
    desc: "Confirm the criteria, weightings and scoring approach with the evaluation panel before any supplier responses are received. This prevents challenges to the evaluation process after the fact and ensures the recommendation can be defended at delegate approval.",
  },
];

const stats = [
  { num: `${included.length}`, label: "Artefacts included" },
  { num: `$${pack.price}`, label: "Single-user · AUD" },
  { num: "Word + Excel", label: "Editable, all formats" },
  { num: "G2 → G3", label: "Framework anchor" },
];

const faqs = [
  {
    q: "What format are the templates in?",
    a: "Microsoft Word (.docx) and Excel (.xlsx). All documents are fully editable and work in Google Docs and Google Sheets, though some conditional formatting may not carry across.",
  },
  {
    q: "Is this suitable for small and large procurements?",
    a: "Yes. The pack scales from a straightforward RFQ to a complex multi-stage RFP with BAFO. Use the documents that are proportionate to the size and risk of your procurement.",
  },
  {
    q: "Does it cover the BAFO process?",
    a: "Yes. The pack includes a structured BAFO process template covering the invitation to BAFO, revised response assessment and updated evaluation scoring.",
  },
  {
    q: "Do I need procurement experience to use it?",
    a: "The templates are structured and self-explanatory, but they assume familiarity with the procurement process. If you are new to formal procurement, consider advisory support alongside the pack.",
  },
  {
    q: "Can I share this with my team?",
    a: "Your purchase gives you a single-user licence. For multi-seat access across a team or practice, see the <a href=\"/templates/complete-practitioner-library\">Complete Practitioner Library</a> - a named-user licence that covers every pack, every bundle and twelve months of artefact updates.",
  },
  {
    q: "What if I need support running a procurement?",
    a: "Lavelle Pty Ltd provides procurement governance advisory and RFP management support. See the consulting page or contact us directly.",
  },
];
---

<BaseLayout
  title="Procurement Pack - Lavelle Pty Ltd"
  description="A practical procurement governance pack for project teams managing RFPs, evaluation planning, supplier responses, BAFO processes and delegate approval pathways."
>
  {
    checkoutUrl && (
      <script src="https://assets.lemonsqueezy.com/lemon.js" defer />
    )
  }

  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/templates">Templates</a> &nbsp;/&nbsp;
        <span>Procurement Pack</span>
      </div>
      <div class="eyebrow">Procurement Pack</div>
      <h1 style="margin-top:1rem;">Probity-sound <em>by design.</em></h1>
      <p class="subhero__lead">
        A practical procurement governance pack for project teams managing RFPs,
        evaluation planning, supplier responses, BAFO processes and delegate
        approval pathways.
      </p>
    </div>
  </section>

  <PackPage
    packName="Procurement Pack"
    packSlug="procurement-pack"
    price={pack.price}
    checkoutUrl={checkoutUrl}
    gaLabel="Procurement Pack"
    stats={stats}
    audience={audience}
    problemStatement={problemStatement}
    included={included}
    howToUse={howToUse}
    faqs={faqs}
    roiBlock="About two and a half days of senior PM work covering the RFP evaluation plan, the technical and commercial evaluation matrices, supplier clarification, BAFO, evaluation recommendation and probity - $3,750 of bespoke artefact development at $1,500/day contractor rates. Pack: $1,197. ROI: ~3.1×. The opinionated thinking and the framework lineage are the part you can't outsource."
    relatedConsultingHref="/consulting#sourcing"
    framework={{
      stage: "Discovery → Design (Sourcing track)",
      gate: "G2 Discover → G3 Design",
    }}
    relatedConsultingLabel="View procurement consulting"
  />
</BaseLayout>
