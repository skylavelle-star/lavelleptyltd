---
import Layout from '../../layouts/Layout.astro';
import BuyButton from '../../components/BuyButton.astro';
import { products } from '../../config/site';

const pack = products.businessCasePack;
const checkoutUrl = pack.checkoutUrl || undefined;
---

<Layout
  title="Business Case Pack | Lavelle Pty Ltd"
  description="A structured business case template pack for defining the case for change, investment rationale, options, costs, risks, benefits, dependencies and approval pathways."
>
  {checkoutUrl && <script slot="head" src="https://assets.lemonsqueezy.com/lemon.js" defer></script>}

  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Templates</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Business Case Pack</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          A structured business case template pack for defining the case for change, investment rationale, options, costs, risks, benefits, dependencies and approval pathways.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-10">

          {checkoutUrl ? (
            <div class="flex items-center gap-6 flex-wrap">
              <div>
                <span class="text-3xl font-bold text-slate-900">{pack.price}</span>
                <span class="text-sm text-slate-500 ml-1">AUD</span>
              </div>
              <BuyButton checkoutUrl={checkoutUrl} label="Buy Now" fullWidth={false} gaEvent="product_buy_click" gaLabel="Business Case Pack" />
            </div>
          ) : (
            <div class="inline-flex items-center px-4 py-2.5 text-sm font-medium text-slate-600 bg-slate-100 border border-slate-200 rounded-md">
              Coming Soon - <a href="/contact" class="ml-1 text-navy-700 hover:text-navy-900 underline">register your interest</a>
            </div>
          )}

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Who It Is For</h2>
            <ul class="space-y-2.5">
              {[
                'Senior project managers preparing a business case for a technology investment',
                'Program managers building the investment proposal for delegate approval',
                'Technology leaders who need to present a rigorous options analysis to executives',
                'Business analysts authoring or reviewing a formal business case document',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">What It Helps With</h2>
            <div class="space-y-3 text-slate-600 leading-relaxed">
              <p>Investment proposals fail delegate approval when the problem is poorly defined, the options analysis is weak, or the financial model cannot withstand scrutiny. This pack provides a structured approach to building a business case that can survive a rigorous review.</p>
              <p>Each section of the template is structured to address the questions that approval authorities, finance reviewers and governance bodies will ask.</p>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">What Is Included</h2>
            <div class="space-y-3">
              {[
                { title: 'Business Case Template', desc: 'A structured template covering executive summary, problem statement, options analysis, recommended option, financial model, benefits, risks and governance.' },
                { title: 'Executive Summary Guide', desc: 'Guidance and examples for writing an executive summary that clearly states the ask, the rationale and the recommendation.' },
                { title: 'Options Analysis Framework', desc: 'A structured approach to defining, assessing and comparing investment options, including the status quo option.' },
                { title: 'Financial Model Structure', desc: 'A template for presenting costs, benefits and investment returns in a format suitable for delegate approval and finance review.' },
                { title: 'Benefits Register', desc: 'A structured register for mapping expected benefits to delivery activities and identifying who will be accountable for realisation.' },
                { title: 'Risk Register', desc: 'A risk register template structured for inclusion in the business case approval documentation.' },
                { title: 'Approval Checklist', desc: 'A checklist for reviewing business case readiness against common delegate approval criteria.' },
              ].map((item) => (
                <div class="flex gap-4 p-4 rounded-lg border border-slate-200 bg-white">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  <div>
                    <p class="text-sm font-semibold text-slate-900 mb-1">{item.title}</p>
                    <p class="text-sm text-slate-600 leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">How To Use It</h2>
            <p class="text-slate-600 leading-relaxed">
              Start with the problem statement and options analysis before building the financial model. The most common mistake is to begin with the preferred option already decided and work backwards. This pack is designed to support a genuine options analysis that will withstand scrutiny from finance teams and approval authorities.
            </p>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Sample Preview</h2>
            <p class="text-sm text-slate-600 mb-4">The Options Analysis Framework is the document most organisations get wrong. Below is a representation of its structure - actual documents are fully editable Word and Excel files.</p>
            <div class="border border-slate-200 rounded-lg overflow-hidden text-xs">
              <div class="bg-navy-800 px-4 py-3">
                <p class="text-navy-200 font-semibold uppercase tracking-wider">Example - Options Analysis Framework</p>
              </div>
              <div class="bg-slate-50 px-5 py-4 space-y-3 font-mono text-slate-700">
                <p class="font-bold text-slate-900 text-sm not-italic">OPTIONS ANALYSIS</p>
                <div class="space-y-2">
                  <div class="bg-white border border-slate-200 rounded p-2"><p class="text-slate-500 text-xs">Status Quo</p><p class="font-bold text-red-600">Not recommended</p></div>
                  <div class="bg-white border border-slate-200 rounded p-2"><p class="text-slate-500 text-xs">Option A - Build Internal</p><p class="font-bold text-amber-600">Feasible - high cost</p></div>
                  <div class="bg-white border border-slate-200 rounded p-2"><p class="text-slate-500 text-xs">Option B - Procure External</p><p class="font-bold text-green-600">Recommended</p></div>
                </div>
                <p class="font-semibold not-italic">Evaluation Criteria</p>
                <p class="text-slate-400">[ Cost / Risk / Benefit / Feasibility scoring matrix ]</p>
                <p class="font-semibold not-italic">Financial Summary</p>
                <p class="text-slate-400">[ NPV / IRR / Payback period / Sensitivity ranges ]</p>
                <p class="font-semibold not-italic">Recommended Option and Rationale</p>
                <p class="text-slate-400">[ Structured narrative with approval pathway ]</p>
              </div>
            </div>
            <p class="text-xs text-slate-500 mt-2">Plus structured templates for problem statement, benefits register, risk register, dependency log and delegate approval routing.</p>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Frequently Asked Questions</h2>
            <div class="space-y-3">
              {[
                { q: 'What format are the templates in?', a: 'Microsoft Word (.docx) and Excel (.xlsx). All documents are fully editable and work in Google Docs and Google Sheets, though some conditional formatting may not carry across.' },
                { q: 'Is this suitable for a formal government approval submission?', a: 'Yes. The structure follows common government approval frameworks - problem statement, options analysis, financial model, risk, benefits and recommendation. It is not jurisdiction-specific but adapts well to most government business case requirements.' },
                { q: 'Does the financial model cover costs and benefits?', a: 'Yes. The pack includes a benefits register, a cost model and a high-level financial summary covering NPV, payback and sensitivity. The financial model is a practical planning tool, not a certified financial statement.' },
                { q: 'How detailed is the options analysis?', a: 'The pack supports a full options analysis across financial, risk, feasibility and strategic fit dimensions. The evaluation criteria and weightings are editable to reflect your organisation\'s priorities.' },
                { q: 'Can I share this with my team?', a: 'Your purchase gives you a single-user licence. If you need multi-seat access for a team or organisation, see our enterprise licensing options.' },
                { q: 'What if I need advisory support building the case?', a: 'Lavelle Pty Ltd provides business case development consulting. See the consulting page or contact us directly.' },
              ].map(({ q, a }) => (
                <div class="border border-slate-200 rounded-lg p-4">
                  <p class="text-sm font-semibold text-slate-900 mb-1.5">{q}</p>
                  <p class="text-sm text-slate-600 leading-relaxed">{a}</p>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-xl font-bold text-slate-900 mb-2">Format and Delivery</h2>
            <p class="text-sm text-slate-600">Microsoft Word templates (.docx) and Excel workbooks (.xlsx). All documents are fully editable. Delivered via Lemon Squeezy after purchase.</p>
          </div>

          {checkoutUrl && (
            <div>
              <BuyButton checkoutUrl={checkoutUrl} label="Buy Now" gaEvent="product_buy_click" gaLabel="Business Case Pack" />
            </div>
          )}

        </div>

        <aside class="space-y-5">
          <div class="rounded-lg border border-navy-200 bg-white p-6 sticky top-24">
            {checkoutUrl ? (
              <>
                <div class="mb-1">
                  <span class="text-3xl font-bold text-slate-900">{pack.price}</span>
                  <span class="text-sm text-slate-500 ml-1">AUD</span>
                </div>
                <p class="text-sm text-slate-600 mb-5">One-time purchase. Delivered via Lemon Squeezy.</p>
                <BuyButton checkoutUrl={checkoutUrl} label="Buy Now" gaEvent="product_buy_click" gaLabel="Business Case Pack" />
                <div class="mt-4 pt-4 border-t border-slate-100 space-y-2">
                  {['Microsoft Word + Excel format', 'Fully editable templates', 'Australian English', 'Delivered via Lemon Squeezy'].map((f) => (
                    <div class="flex items-center gap-2 text-sm text-slate-600">
                      <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {f}
                    </div>
                  ))}
                </div>
              </>
            ) : (
              <>
                <h2 class="text-base font-semibold text-slate-900 mb-2">Coming Soon</h2>
                <p class="text-sm text-slate-600 mb-4">Register your interest to be notified on launch.</p>
                <a href="/contact" class="inline-flex items-center w-full justify-center px-4 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors">
                  Register Interest
                </a>
              </>
            )}
            <div class="mt-5 pt-4 border-t border-slate-100">
              <p class="text-xs text-slate-500 mb-2">Need advisory support instead?</p>
              <a href="/consulting#business-case" class="text-xs font-medium text-navy-700 hover:text-navy-900 underline">View business case consulting</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
