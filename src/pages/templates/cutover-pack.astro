---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StubPack from "../../components/StubPack.astro";
import { products } from "../../config/site";

const pack = products.cutoverPack;

// TODO: STRATEGY.md does not quote a tagline for Cutover Pack.
---

<BaseLayout
  title="Cutover Pack — Lavelle Pty Ltd"
  description="The Cutover stage artefact set. Runsheet and Go / No-Go Checklist — executed on a runsheet, evidenced and reversible."
>
  <StubPack
    packName="Cutover Pack"
    packSlug="cutover-pack"
    frameworkStage="Cutover"
    frameworkGate="G5 Cutover (Go / No-Go)"
    subhead="The runsheet and gate artefacts for the transition to live. Every step on the runsheet, evidenced, and reversible if the rollback is called."
    artefacts={[
      "Release Plan Runsheet",
      "Go No-Go Checklist",
    ]}
    price={pack.price}
    roiBlock="About a day of senior PM work — $1,500 of bespoke artefact development at $1,500/day contractor rates. Pack: $747. ROI: ~2×. The opinionated thinking and the framework lineage are the part you can't outsource."
  />
</BaseLayout>
