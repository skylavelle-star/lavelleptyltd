---
import BaseLayout from '../layouts/BaseLayout.astro';

const offerings = [
  {
    num: '01',
    eyebrow: 'Advisory',
    title: 'Consulting',
    description:
      'Project recovery, PMO stand-up, business case development, procurement advisory, steering committee governance and delivery assurance — engaged personally by Sky Lavelle.',
    href: '/consulting',
    cta: 'View the six capabilities',
  },
  {
    num: '02',
    eyebrow: 'Productised',
    title: 'PMO Resources',
    description:
      'The exact artefact sets Lavelle deploys on engagement, packaged for download. Steering Committee, Project Recovery, Business Case and Procurement packs — plus the free Project Recovery Checklist.',
    href: '/pmo-resources',
    cta: 'Browse the product packs',
  },
  {
    num: '03',
    eyebrow: 'Evidence',
    title: 'Case Studies',
    description:
      'Five recent engagements drawn from twenty years across media, higher education and cybersecurity research — Griffith, the ABC, CQUniversity and the Cyber Security CRC.',
    href: '/case-studies',
    cta: 'Read the case studies',
  },
  {
    num: '04',
    eyebrow: 'Method',
    title: 'Delivery Framework',
    description:
      'A practical hybrid framework that combines structured governance with Agile execution for complex technology and business change. Seven stages, ten artefacts.',
    href: '/delivery-framework',
    cta: 'View the framework',
  },
];
---

<BaseLayout
  title="Services — Lavelle Pty Ltd"
  description="Senior project delivery services from Lavelle Pty Ltd — consulting, PMO Resources, case studies and the delivery framework. One place to start, whatever the situation."
  currentNav="services"
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Services</span>
      </div>
      <h1>One firm. <em>Four ways to engage.</em></h1>
      <p class="subhero__lead">
        Whether you need senior delivery in the room, a structured artefact set to standardise your PMO, evidence that we have done this before, or the method behind it — start here. Each route below leads to the deeper page for that capability.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">What we offer</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Four offerings.<br />One <em>delivery practice.</em>
          </h2>
        </div>
        <p class="lead">
          Most engagements start in one place and draw on another within the first month. Consulting clients often adopt the PMO packs. PMO-pack buyers regularly come back for an advisory conversation. The framework underpins both.
        </p>
      </header>

      <div class="capabilities">
        {offerings.map((offering) => (
          <article class="cap">
            <div class="cap__num">{offering.num} / {offering.eyebrow}</div>
            <h3 class="cap__title">{offering.title}</h3>
            <p class="cap__desc">{offering.description}</p>
            <a href={offering.href} class="cap__link">{offering.cta} <span>→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="case">
    <div class="wrap">
      <div class="case__grid">
        <div>
          <div class="eyebrow">Not sure where to start?</div>
          <h2 style="font-family:'Fraunces',serif; font-size:var(--display-md); font-weight:500; line-height:1.1; margin:1.25rem 0 1.5rem;">
            Most conversations begin the <em style="color:var(--ochre);">same way.</em>
          </h2>
          <p style="font-size:var(--body-lg); color:var(--ink-soft); line-height:1.55; max-width:50ch;">
            A thirty-minute confidential conversation about what is not moving. From there, we agree whether the right next step is consulting, a productised pack, an independent gate review, or simply a written diagnostic.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Send an enquiry <span class="btn__arrow">→</span>
            </a>
            <a href="/case-studies" class="btn btn--ghost">Read the case studies</a>
          </div>
        </div>
        <ul class="engage__list" style="border-top-color:var(--rule);">
          <li style="border-bottom-color:var(--rule);">
            <a href="/consulting" style="color:var(--ink);"><span>Consulting capabilities</span><span style="font-family:'Fraunces',serif; font-style:italic;">→</span></a>
          </li>
          <li style="border-bottom-color:var(--rule);">
            <a href="/pmo-resources" style="color:var(--ink);"><span>PMO Resources catalogue</span><span style="font-family:'Fraunces',serif; font-style:italic;">→</span></a>
          </li>
          <li style="border-bottom-color:var(--rule);">
            <a href="/case-studies" style="color:var(--ink);"><span>Five recent engagements</span><span style="font-family:'Fraunces',serif; font-style:italic;">→</span></a>
          </li>
          <li style="border-bottom-color:var(--rule);">
            <a href="/delivery-framework" style="color:var(--ink);"><span>Seven-stage delivery framework</span><span style="font-family:'Fraunces',serif; font-style:italic;">→</span></a>
          </li>
          <li style="border-bottom-color:var(--rule);">
            <a href="/thinking" style="color:var(--ink);"><span>Thinking &amp; field notes</span><span style="font-family:'Fraunces',serif; font-style:italic;">→</span></a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Engage Lavelle</div>
          <h2 style="margin-top:1.25rem;">Let's talk about <em>what's not moving.</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            Confidential thirty-minute conversation. No pitch deck, no obligation, no sales call disguised as a workshop.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Send an enquiry <span class="btn__arrow">→</span>
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li><a href="/contact"><span>Submit a brief (RFP / EOI)</span><span>→</span></a></li>
          <li><a href="/contact"><span>Book a 30-minute call with Sky</span><span>→</span></a></li>
          <li><a href="/contact"><span>Request a capability statement</span><span>→</span></a></li>
          <li><a href="/contact"><span>Government panel listing</span><span>→</span></a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
