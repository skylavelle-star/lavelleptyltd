---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";
---

<BaseLayout
  title="Contact - Lavelle Pty Ltd"
  description="Contact Lavelle Pty Ltd for consulting, contract project management, PMO resources, delivery support or digital asset enquiries."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Contact</span>
      </div>
      <h1>Work with <em>Lavelle Pty Ltd.</em></h1>
      <p class="subhero__lead">
        For consulting, contract project management, PMO resources, delivery
        support or digital asset enquiries, send an enquiry below. All messages
        receive a response within one business day.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="split">
        <div>
          <form
            id="enquiry-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="enquiry-form"
            novalidate
          >
            <input type="hidden" name="access_key" value={site.web3formsKey} />
            <input
              type="hidden"
              name="subject"
              value="New business enquiry - lavelleptyltd.com.au"
            />
            <input
              type="hidden"
              name="from_name"
              value="Lavelle Pty Ltd Contact Form"
            />
            <input
              type="checkbox"
              name="botcheck"
              class="hidden-bot"
              tabindex="-1"
              autocomplete="off"
            />

            <div class="row">
              <div>
                <label for="name"
                  >Name <span class="required" aria-hidden="true">*</span
                  ></label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  autocomplete="name"
                  required
                  placeholder="Your full name"
                />
              </div>
              <div>
                <label for="email"
                  >Email <span class="required" aria-hidden="true">*</span
                  ></label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  placeholder="you@organisation.com.au"
                />
              </div>
            </div>

            <div>
              <label for="organisation">Organisation</label>
              <input
                type="text"
                id="organisation"
                name="organisation"
                autocomplete="organization"
                placeholder="Your organisation"
              />
            </div>

            <div>
              <label for="enquiry-type">Enquiry type</label>
              <select id="enquiry-type" name="enquiry_type">
                <option value="">Select an enquiry type</option>
                <option value="consulting">Consulting</option>
                <option value="contract-pm">Contract Project Management</option>
                <option value="templates">Templates</option>
                <option value="project-recovery">Project Recovery</option>
                <option value="brief">Submit a brief (RFP / EOI)</option>
                <option value="call">Book a 30-minute call with Sky</option>
                <option value="capability"
                  >Request a capability statement</option
                >
                <option value="speaking"
                  >Speaking &amp; advisory enquiries</option
                >
                <option value="panel"
                  >Government panel &amp; supplier listing</option
                >
                <option value="enterprise"
                  >Bulk &amp; enterprise licensing</option
                >
                <option value="branding">Co-branded artefact packs</option>
                <option value="training"
                  >Training &amp; onboarding workshops</option
                >
                <option value="digital-asset">Digital Asset Enquiry</option>
                <option value="general">General Business Enquiry</option>
              </select>
            </div>

            <div>
              <label for="message"
                >Message <span class="required" aria-hidden="true">*</span
                ></label
              >
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                placeholder="Describe your situation and what you need. The more specific, the better."
              ></textarea>
            </div>

            <div
              id="form-success"
              class="form-alert form-alert--success"
              role="alert"
              hidden
            >
              <strong>Enquiry sent.</strong> You will receive a response within one
              business day.
            </div>
            <div
              id="form-error"
              class="form-alert form-alert--error"
              role="alert"
              hidden
            >
              Something went wrong. Please try again.
            </div>

            <div>
              <button id="submit-btn" type="submit" class="btn btn--primary">
                <span id="submit-label">Send enquiry</span>
                <span class="btn__arrow">→</span>
              </button>
            </div>

            <p class="form-fineprint">
              Fields marked with * are required. Your information will not be
              shared with third parties.
            </p>
          </form>
        </div>

        <aside class="sidecard">
          <h4>Enquiry types</h4>
          <ul>
            <li>Consulting and contract project management</li>
            <li>PMO resources and template packs</li>
            <li>Project recovery support</li>
            <li>Delivery framework advisory</li>
            <li>Digital asset portfolio enquiries</li>
            <li>General business enquiries</li>
          </ul>
          <h4 style="margin-top:2rem;">Response time</h4>
          <p style="font-size:var(--body-sm); color:var(--ink-soft);">
            All enquiries receive a response within one business day. For urgent
            situations, note that in your message.
          </p>
          <h4 style="margin-top:2rem;">Based in Australia</h4>
          <p style="font-size:var(--body-sm); color:var(--ink-soft);">
            Lavelle Pty Ltd is an Australian company. Consulting engagements are
            available remotely and on-site across Australia.
          </p>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .enquiry-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .enquiry-form .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 600px) {
    .enquiry-form .row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .enquiry-form label {
    display: block;
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  .enquiry-form .required {
    color: var(--ochre);
  }
  .enquiry-form input[type="text"],
  .enquiry-form input[type="email"],
  .enquiry-form select,
  .enquiry-form textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-family: inherit;
    font-size: var(--body);
    color: var(--ink);
    transition: border-color 0.2s;
  }
  .enquiry-form input:focus,
  .enquiry-form select:focus,
  .enquiry-form textarea:focus {
    outline: none;
    border-color: var(--ochre);
  }
  .enquiry-form textarea {
    resize: vertical;
    min-height: 7rem;
  }
  .hidden-bot {
    display: none;
  }
  .form-alert {
    padding: 1rem 1.25rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-size: var(--body-sm);
    color: var(--ink-soft);
  }
  .form-alert--success {
    border-color: var(--ochre);
    background: rgba(184, 92, 42, 0.06);
    color: var(--ink);
  }
  .form-alert--error {
    border-color: #b34a3a;
    background: rgba(179, 74, 58, 0.06);
    color: #7a2e22;
  }
  .form-alert[hidden] {
    display: none;
  }
  .form-fineprint {
    font-size: var(--micro);
    color: var(--sage);
    letter-spacing: 0.04em;
  }
  #submit-btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  const form = document.getElementById("enquiry-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitLabel = document.getElementById(
    "submit-label",
  ) as HTMLSpanElement;
  const successMsg = document.getElementById("form-success") as HTMLDivElement;
  const errorMsg = document.getElementById("form-error") as HTMLDivElement;

  const params = new URLSearchParams(window.location.search);
  const topic = params.get("topic");
  if (topic) {
    const select = document.getElementById(
      "enquiry-type",
    ) as HTMLSelectElement | null;
    if (select && Array.from(select.options).some((o) => o.value === topic)) {
      select.value = topic;
    }
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    submitLabel.textContent = "Sending…";
    successMsg.hidden = true;
    errorMsg.hidden = true;

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
      });

      const data = await res.json();

      if (data.success) {
        if (typeof window.gtag === "function")
          window.gtag("event", "contact_form_submit");
        window.location.href = "/thank-you/contact/";
        return;
      } else {
        errorMsg.hidden = false;
      }
    } catch {
      errorMsg.hidden = false;
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = "Send enquiry";
    }
  });
</script>
