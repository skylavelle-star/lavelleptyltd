---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
---

<Layout
  title="Contact"
  description="Contact Lavelle Pty Ltd for consulting, contract project management, PMO resources, delivery support or digital asset enquiries."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Work With Lavelle Pty Ltd</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          For consulting, contract project management, PMO resources, delivery support or digital asset enquiries, contact Lavelle Pty Ltd.
        </p>
      </div>
    </div>
  </section>

  <!-- FORM + SIDEBAR -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- FORM -->
        <div class="lg:col-span-2">
          <form
            id="enquiry-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
            novalidate
          >
            <input type="hidden" name="access_key" value={site.web3formsKey} />
            <input type="hidden" name="subject" value="New business enquiry - lavelleptyltd.com.au" />
            <input type="hidden" name="from_name" value="Lavelle Pty Ltd Contact Form" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Name <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  autocomplete="name"
                  required
                  class="w-full px-4 py-2.5 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition-colors"
                  placeholder="Your full name"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Email <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  class="w-full px-4 py-2.5 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition-colors"
                  placeholder="you@organisation.com.au"
                />
              </div>
            </div>

            <div>
              <label for="organisation" class="block text-sm font-medium text-slate-700 mb-1.5">
                Organisation
              </label>
              <input
                type="text"
                id="organisation"
                name="organisation"
                autocomplete="organization"
                class="w-full px-4 py-2.5 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition-colors"
                placeholder="Your organisation"
              />
            </div>

            <div>
              <label for="enquiry-type" class="block text-sm font-medium text-slate-700 mb-1.5">
                Enquiry Type
              </label>
              <select
                id="enquiry-type"
                name="enquiry_type"
                class="w-full px-4 py-2.5 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition-colors bg-white"
              >
                <option value="">Select an enquiry type</option>
                <option value="consulting">Consulting</option>
                <option value="contract-pm">Contract Project Management</option>
                <option value="pmo-resources">PMO Resources</option>
                <option value="project-recovery">Project Recovery</option>
                <option value="digital-asset">Digital Asset Enquiry</option>
                <option value="general">General Business Enquiry</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">
                Message <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full px-4 py-2.5 text-sm border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition-colors resize-vertical"
                placeholder="Describe your situation and what you need. The more specific, the better."
              ></textarea>
            </div>

            <div
              id="form-success"
              class="hidden flex items-start gap-3 p-4 rounded-lg bg-emerald-50 border border-emerald-200"
              role="alert"
            >
              <svg class="w-5 h-5 text-emerald-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-sm text-emerald-800">
                <strong>Enquiry sent.</strong> You will receive a response within one business day.
              </p>
            </div>

            <div
              id="form-error"
              class="hidden flex items-start gap-3 p-4 rounded-lg bg-red-50 border border-red-200"
              role="alert"
            >
              <svg class="w-5 h-5 text-red-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-sm text-red-800" id="form-error-text">
                Something went wrong. Please try again.
              </p>
            </div>

            <div class="flex items-center gap-4">
              <button
                id="submit-btn"
                type="submit"
                class="inline-flex items-center gap-2 px-7 py-3.5 text-base font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
              >
                <span id="submit-label">Send Enquiry</span>
                <svg
                  id="submit-spinner"
                  class="hidden w-4 h-4 animate-spin"
                  fill="none"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </button>
            </div>

            <p class="text-xs text-slate-500">
              Fields marked with * are required. Your information will not be shared with third parties.
            </p>
          </form>
        </div>

        <!-- SIDEBAR -->
        <aside class="space-y-5">
          <div class="rounded-lg border border-slate-200 p-6">
            <h2 class="text-base font-semibold text-slate-900 mb-4">Enquiry types</h2>
            <ul class="space-y-3">
              {[
                'Consulting and contract project management',
                'PMO resources and template packs',
                'Project recovery support',
                'Delivery framework advisory',
                'Digital asset portfolio enquiries',
                'General business enquiries',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-lg border border-slate-200 p-6">
            <h2 class="text-base font-semibold text-slate-900 mb-2">Response time</h2>
            <p class="text-sm text-slate-600">
              All enquiries receive a response within one business day. For urgent situations, note that in your message.
            </p>
          </div>

          <div class="rounded-lg border border-slate-200 p-6">
            <h2 class="text-base font-semibold text-slate-900 mb-2">Based in Australia</h2>
            <p class="text-sm text-slate-600">
              Lavelle Pty Ltd is an Australian company. Consulting engagements are available remotely and on-site across Australia.
            </p>
          </div>

          <div class="rounded-lg border border-slate-200 p-6">
            <h2 class="text-base font-semibold text-slate-900 mb-2">Direct contact</h2>
            <p class="text-sm text-slate-600">Use the enquiry form to get in touch. All messages are responded to within one business day.</p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('enquiry-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitLabel = document.getElementById('submit-label') as HTMLSpanElement;
  const submitSpinner = document.getElementById('submit-spinner') as SVGElement;
  const successMsg = document.getElementById('form-success') as HTMLDivElement;
  const errorMsg = document.getElementById('form-error') as HTMLDivElement;
  const errorText = document.getElementById('form-error-text') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    submitLabel.textContent = 'Sending...';
    submitSpinner.classList.remove('hidden');
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });

      const data = await res.json();

      if (data.success) {
        if (typeof window.gtag === 'function') window.gtag('event', 'contact_form_submit');
        window.location.href = '/thank-you/contact/';
        return;
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = 'Send Enquiry';
      submitSpinner.classList.add('hidden');
    }
  });
</script>
