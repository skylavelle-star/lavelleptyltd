---
import Layout from '../layouts/Layout.astro';

const portfolioCategories = [
  {
    title: 'Professional services content and digital products',
    description: 'Information assets, templates and tools serving professional service providers and their clients.',
  },
  {
    title: 'Project management templates, guides and frameworks',
    description: 'PMO resources, delivery frameworks and project artefacts for project managers and delivery leads.',
  },
  {
    title: 'Local search and business information assets',
    description: 'Location-based information and business directory assets serving local search intent.',
  },
  {
    title: 'Property, renovation and construction-related content',
    description: 'Information assets covering property, renovation planning, construction trades and home improvement.',
  },
  {
    title: 'Lead generation and niche information platforms',
    description: 'Targeted information assets designed to capture commercial intent in specific market niches.',
  },
  {
    title: 'Newsletter, search and analytics-enabled content systems',
    description: 'Content platforms built with integrated search visibility, newsletter distribution and analytics tracking.',
  },
];
---

<Layout
  title="Digital Assets"
  description="Lavelle Pty Ltd develops and operates a growing portfolio of digital assets across professional services, local business information, property, construction and digital products."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Digital Assets</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          A growing portfolio of digital assets built around useful content, searchable information, commercial intent and repeatable systems.
        </p>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-lg text-slate-700 leading-relaxed mb-6">
          Alongside its consulting and PMO resource work, Lavelle Pty Ltd develops and operates a growing portfolio of digital assets. These assets are designed around useful content, searchable information, commercial intent and repeatable systems.
        </p>
        <p class="text-lg text-slate-700 leading-relaxed">
          The portfolio includes assets across professional services, local business information, property and renovation content, construction-related markets and digital products. Each asset is built with a focus on search visibility, practical user value, commercial conversion and long-term scalability.
        </p>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO CATEGORIES -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Portfolio</p>
        <h2 class="text-2xl font-bold text-slate-900">Portfolio Categories</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {portfolioCategories.map((cat) => (
          <div class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white">
            <h3 class="text-sm font-semibold text-slate-900 mb-2 leading-snug">{cat.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-3">Digital Asset Enquiries</h2>
        <p class="text-slate-600 leading-relaxed mb-6">
          For enquiries related to the Lavelle Pty Ltd digital asset portfolio, use the contact form and select "Digital Asset Enquiry" as the enquiry type.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
        >
          Send an Enquiry
        </a>
      </div>
    </div>
  </section>
</Layout>
