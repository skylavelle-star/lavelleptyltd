---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import engageImage from "../assets/images/engage-boardroom.jpg";

const portfolioCategories = [
  {
    title: "Professional services content and digital products",
    description:
      "Information assets, templates and tools serving professional service providers and their clients.",
    icon: '<path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/>',
  },
  {
    title: "Project management templates, guides and frameworks",
    description:
      "PMO resources, delivery frameworks and project artefacts for project managers and delivery leads.",
    icon: '<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>',
  },
  {
    title: "Local search and business information assets",
    description:
      "Location-based information and business directory assets serving local search intent.",
    icon: '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>',
  },
  {
    title: "Property, renovation and construction-related content",
    description:
      "Information assets covering property, renovation planning, construction trades and home improvement.",
    icon: '<path d="M2 18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1z"/><path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"/><path d="M4 15v-3a6 6 0 0 1 6-6"/><path d="M14 6a6 6 0 0 1 6 6v3"/>',
  },
  {
    title: "Lead generation and niche information platforms",
    description:
      "Targeted information assets designed to capture commercial intent in specific market niches.",
    icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  },
  {
    title: "Newsletter, search and analytics-enabled content systems",
    description:
      "Content platforms built with integrated search visibility, newsletter distribution and analytics tracking.",
    icon: '<path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/>',
  },
];
---

<BaseLayout
  title="Digital Assets - Lavelle Pty Ltd"
  description="Lavelle Pty Ltd develops and operates a growing portfolio of digital assets across professional services, local business information, property, construction and digital products."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Digital Assets</span>
      </div>
      <h1>A growing portfolio of <em>digital assets.</em></h1>
      <p class="subhero__lead">
        Built around useful content, searchable information, commercial intent
        and repeatable systems. Each asset is built with a focus on search
        visibility, practical user value, commercial conversion and long-term
        scalability.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="prose">
        <p>
          Alongside its consulting and PMO resource work, Lavelle Pty Ltd
          develops and operates a growing portfolio of digital assets. These
          assets are designed around useful content, searchable information,
          commercial intent and repeatable systems.
        </p>
        <p>
          The portfolio includes assets across professional services, local
          business information, property and renovation content,
          construction-related markets and digital products.
        </p>
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Portfolio</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Portfolio <em>categories.</em>
          </h2>
        </div>
        <p class="lead">
          Each category reflects a focused area where the company has built
          operational systems for content, search visibility, lead capture and
          commercial conversion.
        </p>
      </header>

      <div class="capabilities">
        {
          portfolioCategories.map((cat, i) => (
            <article class="cap">
              <div class="cap__icon" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={cat.icon}
                />
              </div>
              <div class="cap__num">
                {String(i + 1).padStart(2, "0")} / Category
              </div>
              <h3 class="cap__title" style="font-size:1.25rem;">
                {cat.title}
              </h3>
              <p class="cap__desc">{cat.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="engage engage--imaged">
    <figure class="engage__bg" aria-hidden="true">
      <Image
        src={engageImage}
        alt=""
        widths={[960, 1440, 1920, 2400]}
        sizes="100vw"
        loading="lazy"
        decoding="async"
        class="engage__bg-img"
      />
    </figure>
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Portfolio enquiries</div>
          <h2 style="margin-top:1.25rem;">Digital asset <em>enquiries.</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            For enquiries related to the Lavelle Pty Ltd digital asset
            portfolio, use the contact form and select "Digital Asset Enquiry"
            as the enquiry type.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Send an enquiry <span class="btn__arrow">→</span>
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li>
            <a href="/">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
              </span>
              <span>Lavelle Pty Ltd home</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/consulting">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
              </span>
              <span>Consulting services</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/templates">
              <span class="engage__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
              </span>
              <span>Templates</span>
              <span class="engage__arrow">→</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
