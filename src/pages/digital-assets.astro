---
import BaseLayout from "../layouts/BaseLayout.astro";

const portfolioCategories = [
  {
    title: "Professional services content and digital products",
    description:
      "Information assets, templates and tools serving professional service providers and their clients.",
  },
  {
    title: "Project management templates, guides and frameworks",
    description:
      "PMO resources, delivery frameworks and project artefacts for project managers and delivery leads.",
  },
  {
    title: "Local search and business information assets",
    description:
      "Location-based information and business directory assets serving local search intent.",
  },
  {
    title: "Property, renovation and construction-related content",
    description:
      "Information assets covering property, renovation planning, construction trades and home improvement.",
  },
  {
    title: "Lead generation and niche information platforms",
    description:
      "Targeted information assets designed to capture commercial intent in specific market niches.",
  },
  {
    title: "Newsletter, search and analytics-enabled content systems",
    description:
      "Content platforms built with integrated search visibility, newsletter distribution and analytics tracking.",
  },
];
---

<BaseLayout
  title="Digital Assets — Lavelle Pty Ltd"
  description="Lavelle Pty Ltd develops and operates a growing portfolio of digital assets across professional services, local business information, property, construction and digital products."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Digital Assets</span>
      </div>
      <h1>A growing portfolio of <em>digital assets.</em></h1>
      <p class="subhero__lead">
        Built around useful content, searchable information, commercial intent
        and repeatable systems. Each asset is built with a focus on search
        visibility, practical user value, commercial conversion and long-term
        scalability.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="prose">
        <p>
          Alongside its consulting and PMO resource work, Lavelle Pty Ltd
          develops and operates a growing portfolio of digital assets. These
          assets are designed around useful content, searchable information,
          commercial intent and repeatable systems.
        </p>
        <p>
          The portfolio includes assets across professional services, local
          business information, property and renovation content,
          construction-related markets and digital products.
        </p>
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Portfolio</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Portfolio <em>categories.</em>
          </h2>
        </div>
        <p class="lead">
          Each category reflects a focused area where the company has built
          operational systems for content, search visibility, lead capture and
          commercial conversion.
        </p>
      </header>

      <div class="capabilities">
        {
          portfolioCategories.map((cat, i) => (
            <article class="cap">
              <div class="cap__num">
                {String(i + 1).padStart(2, "0")} / Category
              </div>
              <h3 class="cap__title" style="font-size:1.25rem;">
                {cat.title}
              </h3>
              <p class="cap__desc">{cat.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Portfolio enquiries</div>
          <h2 style="margin-top:1.25rem;">Digital asset <em>enquiries.</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            For enquiries related to the Lavelle Pty Ltd digital asset
            portfolio, use the contact form and select "Digital Asset Enquiry"
            as the enquiry type.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Send an enquiry <span class="btn__arrow">→</span>
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li>
            <a href="/"><span>Lavelle Pty Ltd home</span><span>→</span></a>
          </li>
          <li>
            <a href="/consulting"
              ><span>Consulting services</span><span>→</span></a>
          </li>
          <li>
            <a href="/pmo-resources"
              ><span>PMO Resources</span><span>→</span></a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
