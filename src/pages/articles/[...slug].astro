---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await render(article);

const formattedDate = article.data.pubDate.toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout
  title={`${article.data.title} | Lavelle Pty Ltd`}
  description={article.data.description}
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 text-xs text-navy-200 mb-4">
          <span class="font-semibold uppercase tracking-wider">{article.data.category}</span>
          <span aria-hidden="true">·</span>
          <time datetime={article.data.pubDate.toISOString()}>{formattedDate}</time>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{article.data.title}</h1>
        <p class="text-lg text-slate-300 leading-relaxed">{article.data.description}</p>
      </div>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="section">
    <div class="container">
      <article class="article-content max-w-3xl">
        <Content />
      </article>

      {article.data.tags.length > 0 && (
        <div class="max-w-3xl mt-10 pt-6 border-t border-slate-200">
          <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Topics</p>
          <ul class="flex flex-wrap gap-2 list-none p-0">
            {article.data.tags.map((tag) => (
              <li class="px-3 py-1 text-xs font-medium text-slate-700 bg-slate-100 rounded-full">{tag}</li>
            ))}
          </ul>
        </div>
      )}

      <div class="max-w-3xl mt-10">
        <a
          href="/articles"
          class="inline-flex items-center text-sm font-medium text-navy-700 hover:text-navy-900 transition-colors"
        >
          <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          All articles
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-950 py-14">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold text-white mb-3">Engage Lavelle Pty Ltd</h2>
        <p class="text-slate-300 leading-relaxed mb-6">
          For consulting, contract project management or delivery advisory enquiries, use the contact form to describe your situation and requirements.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-navy-950 bg-white hover:bg-slate-100 rounded-md transition-colors"
        >
          Send an Enquiry
        </a>
      </div>
    </div>
  </section>
</Layout>
