---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'project-management',
    title: 'Senior Project Management',
    description:
      'End-to-end project management for complex technology and business change initiatives. Covers delivery planning, team coordination, vendor management, stakeholder reporting and governance.',
  },
  {
    id: 'project-recovery',
    title: 'Project Recovery',
    description:
      'Structured recovery support for projects that have stalled, lost stakeholder confidence or are consuming resources without delivering results. Covers health assessment, reset planning, stakeholder communications and recovery roadmap.',
  },
  {
    id: 'business-case',
    title: 'Business Case Development',
    description:
      'Development of structured business cases for technology investment decisions. Covers options analysis, financial modelling, benefits mapping, risk assessment, governance and delegate approval documentation.',
  },
  {
    id: 'procurement',
    title: 'Procurement and RFP Support',
    description:
      'Procurement planning and governance support covering RFP development, evaluation framework design, evaluation panel governance, BAFO management, vendor clarification and delegate approval documentation.',
  },
  {
    id: 'steering-committee',
    title: 'Steering Committee and Governance Support',
    description:
      'Governance framework design and steering committee support. Covers reporting structures, escalation pathways, meeting governance, decision-making protocols and artefact standards.',
  },
  {
    id: 'digital-transformation',
    title: 'Digital Transformation Delivery',
    description:
      'Delivery leadership for digital transformation programs involving platforms, data, content, integration, identity and user experience change across large organisations.',
  },
  {
    id: 'technology-implementation',
    title: 'Technology Implementation',
    description:
      'Hands-on project management for technology implementations including CMS, CRM, ERP, cloud migration, data platform, cybersecurity uplift and enterprise integration programs.',
  },
  {
    id: 'pmo-framework',
    title: 'PMO and Delivery Framework Support',
    description:
      'Development and implementation of project management office frameworks, delivery standards, artefact libraries and governance models tailored to the organisation\'s operating context.',
  },
  {
    id: 'risk-issue',
    title: 'Risk, Issue and Decision Management',
    description:
      'Structured approaches to risk identification, assessment, escalation and resolution. Covers RAID register design, reporting integration and decision governance.',
  },
  {
    id: 'vendor-stakeholder',
    title: 'Vendor and Stakeholder Coordination',
    description:
      'Coordination and management of multi-vendor delivery environments, evaluation panels, contract performance and stakeholder communication frameworks.',
  },
  {
    id: 'delivery-assurance',
    title: 'Delivery Assurance',
    description:
      'Independent review and assurance of delivery health, governance, artefacts and reporting. Provides a structured assessment with clear recommendations and actions.',
  },
];
---

<Layout
  title="Consulting"
  description="Lavelle Pty Ltd provides senior project management and delivery consulting through Sky Lavelle for complex technology, digital transformation, procurement, governance and business change initiatives."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Consulting</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Senior project management and delivery consulting for organisations that need experienced delivery leadership.
        </p>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-lg text-slate-700 leading-relaxed mb-4">
          Lavelle Pty Ltd provides senior project management and delivery consulting services through Sky Lavelle, its principal consultant, director and owner.
        </p>
        <p class="text-lg text-slate-700 leading-relaxed">
          Sky works with organisations that need experienced delivery leadership across complex technology, digital transformation, procurement, governance, implementation and business change initiatives.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Services</p>
        <h2 class="text-2xl font-bold text-slate-900">What Lavelle Pty Ltd Delivers</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((service) => (
          <div
            id={service.id}
            class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white hover:border-navy-300 hover:shadow-sm transition-all"
          >
            <h3 class="text-base font-semibold text-slate-900 mb-3">{service.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{service.description}</p>
          </div>
        ))}
        <div class="flex flex-col p-6 rounded-lg border border-navy-200 bg-navy-50 hover:bg-navy-100 transition-all">
          <h3 class="text-base font-semibold text-navy-900 mb-3">Not sure what you need?</h3>
          <p class="text-sm text-navy-800 leading-relaxed flex-1 mb-4">
            Send a short description of your situation and what outcome you are working towards. An initial conversation costs nothing.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center text-sm font-medium text-navy-700 hover:text-navy-900 transition-colors"
          >
            Send an enquiry
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ENGAGEMENT MODEL -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Engagement</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">How Engagements Work</h2>
          <div class="space-y-4 text-slate-600 leading-relaxed">
            <p>
              Engagements are typically structured as contract project management arrangements, where Sky Lavelle operates as the senior project manager or delivery lead for the duration of the engagement.
            </p>
            <p>
              Alternatively, advisory and consulting support can be scoped for specific deliverables such as business case development, procurement governance, project recovery assessment or steering committee reporting design.
            </p>
            <p>
              Engagements are agreed with a clear scope, timeframe and expected outputs. For larger programs, arrangements are structured through Lavelle Pty Ltd as the contracting entity.
            </p>
          </div>
        </div>
        <div class="space-y-4">
          {[
            { label: 'Contract project management', detail: 'Embedded senior PM for the duration of the program' },
            { label: 'Delivery advisory', detail: 'Structured advisory on specific delivery challenges' },
            { label: 'Artefact development', detail: 'Production of specific governance or delivery documents' },
            { label: 'Framework design', detail: 'PMO and delivery framework development for your organisation' },
          ].map((item) => (
            <div class="flex gap-4 p-5 rounded-lg border border-slate-200 bg-slate-50">
              <div class="w-1 rounded-full bg-navy-600 shrink-0 self-stretch" aria-hidden="true"></div>
              <div>
                <p class="text-sm font-semibold text-slate-900 mb-1">{item.label}</p>
                <p class="text-sm text-slate-600">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-950 py-14">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold text-white mb-3">Engage Lavelle Pty Ltd</h2>
        <p class="text-slate-300 leading-relaxed mb-6">
          For consulting, contract project management or delivery advisory enquiries, use the contact form to describe your situation and requirements.
        </p>
        <a
          href="/contact"
          data-ga-event="consulting_cta_click"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-navy-950 bg-white hover:bg-slate-100 rounded-md transition-colors"
        >
          Send an Enquiry
        </a>
      </div>
    </div>
  </section>
</Layout>
