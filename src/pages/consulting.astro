---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'project-recovery',
    title: 'Project Recovery',
    lead: 'When a program has stalled or lost credibility, the first job is an honest assessment of where it actually is, not where the status reports say it is.',
    body: 'Lavelle Pty Ltd runs a structured recovery process: assessment, stakeholder reset, replan and governance changes that hold. The work produces a clear picture of program health, a credible path forward and the governance artefacts that keep the recovery on track.',
  },
  {
    id: 'enterprise-technology-delivery',
    title: 'Enterprise Technology Delivery',
    lead: 'Complex multi-vendor programs need someone running the program end-to-end, not just chairing meetings.',
    body: 'Lavelle Pty Ltd leads delivery across data, cloud, cybersecurity, content management and CRM environments. Engagements typically involve coordinating multiple vendors, internal teams and executive stakeholders through to a measurable outcome.',
  },
  {
    id: 'procurement',
    title: 'Procurement Governance',
    lead: 'Restricted tenders and large technology acquisitions need a process that holds up to probity review and delegate scrutiny.',
    body: 'Lavelle Pty Ltd designs evaluation frameworks, runs BAFO and produces the documentation delegates actually need to approve. The output is a defensible procurement record from RFP through to contract signature.',
  },
  {
    id: 'business-case',
    title: 'Business Case Development',
    lead: 'A business case has to survive Treasury review, board scrutiny or delegate approval, often all three.',
    body: 'Lavelle Pty Ltd writes rigorous cases with proper options analysis, financial modelling and the supporting documentation that gets investments approved. The deliverable is built to withstand the level of scrutiny it will actually face.',
  },
  {
    id: 'steering-committee',
    title: 'Steering Committee Reporting',
    lead: 'Most steering committee reports tell the committee what people want them to hear. That is not useful.',
    body: 'Lavelle Pty Ltd builds reporting frameworks that surface actual project health, real risks and the decisions the committee needs to make. The aim is a steering committee that can govern, not one that is managed.',
  },
];

const deliveryHighlights = [
  'A major web content management transformation at Griffith University, delivered in roughly 12 months against an expected multi-year timeline',
  'An analytics migration at the ABC across approximately 100 staff in product, data and engineering teams',
  'A Salesforce CRM and Microsoft 365 E5 security uplift program delivered in a sensitive environment',
];
---

<Layout
  title="Consulting Services"
  description="Senior project delivery consulting from Lavelle Pty Ltd - project recovery, enterprise technology delivery, procurement governance, business case development and steering committee reporting."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Senior Support for Complex Delivery Situations</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Lavelle Pty Ltd helps organisations get difficult technology programs back under control. Project recovery, governance reset, procurement and the senior delivery work that gets stalled initiatives across the line.
        </p>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-lg text-slate-700 leading-relaxed mb-6">
          Engagements are led by principal consultant Sky Lavelle, who has more than 20 years of experience in enterprise technology delivery across government, higher education, media and not-for-profit sectors.
        </p>
        <a
          href="/contact"
          data-ga-event="consulting_enquiry_click"
          class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
        >
          Send an enquiry
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Services</p>
        <h2 class="text-2xl font-bold text-slate-900">Consulting Services</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {services.map((service) => (
          <div
            id={service.id}
            class="flex flex-col p-6 rounded-lg border border-slate-200 bg-white hover:border-navy-300 hover:shadow-sm transition-all"
          >
            <h3 class="text-lg font-semibold text-slate-900 mb-3">{service.title}</h3>
            <p class="text-sm text-slate-700 leading-relaxed mb-3">{service.lead}</p>
            <p class="text-sm text-slate-600 leading-relaxed">{service.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DELIVERY BACKGROUND -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Background</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Delivery Background</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Recent engagements led by Sky Lavelle through Lavelle Pty Ltd include the programs listed alongside.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Procurement work has included enterprise restricted RFPs with multi-supplier panels, BAFO management, contract negotiation and delegate approval. Lavelle Pty Ltd has authored the business case for an enterprise content infrastructure initiative and chaired evaluation panels of up to 15 people.
          </p>
          <p class="text-slate-600 leading-relaxed">
            If your situation looks something like this, an enquiry is a sensible starting point.
          </p>
          <div class="mt-6">
            <a
              href="/contact"
              data-ga-event="consulting_background_cta_click"
              class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
            >
              Send an enquiry
            </a>
          </div>
        </div>
        <div class="space-y-4">
          {deliveryHighlights.map((item) => (
            <div class="flex gap-4 p-5 rounded-lg border border-slate-200 bg-slate-50">
              <div class="w-1 rounded-full bg-navy-600 shrink-0 self-stretch" aria-hidden="true"></div>
              <p class="text-sm text-slate-700 leading-relaxed">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HOW ENGAGEMENTS WORK -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Engagement</p>
        <h2 class="text-2xl font-bold text-slate-900 mb-4">How Engagements Work</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          Send a short description of the situation. An initial conversation costs nothing and helps clarify what support is actually useful before any commercial discussion.
        </p>
        <p class="text-slate-600 leading-relaxed mb-6">
          Engagements are scoped against the problem, not a generic methodology. Recovery work looks different to procurement work, which looks different to business case development. The shape of the engagement is agreed up front.
        </p>
        <a
          href="/contact"
          data-ga-event="consulting_engagement_cta_click"
          class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
        >
          Send an enquiry
        </a>
      </div>
    </div>
  </section>

  <!-- RELATED RESOURCES -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Related</p>
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Related Resources</h2>
        <p class="text-slate-600 leading-relaxed mb-6">
          The PMO resources, templates and free tools developed through this work are published on this site:
        </p>
        <ul class="space-y-3">
          <li class="flex gap-3">
            <span class="text-navy-600 shrink-0" aria-hidden="true">·</span>
            <span class="text-slate-700 leading-relaxed">
              <a href="/pmo-resources" class="text-navy-700 hover:text-navy-900 font-medium underline">PMO Resources</a> - Project Recovery Pack, Business Case Pack, Procurement Pack and Steering Committee Pack
            </span>
          </li>
          <li class="flex gap-3">
            <span class="text-navy-600 shrink-0" aria-hidden="true">·</span>
            <span class="text-slate-700 leading-relaxed">
              <a href="/free-tools" class="text-navy-700 hover:text-navy-900 font-medium underline">Free Tools</a> - including the free Project Recovery Checklist
            </span>
          </li>
          <li class="flex gap-3">
            <span class="text-navy-600 shrink-0" aria-hidden="true">·</span>
            <span class="text-slate-700 leading-relaxed">
              <a href="/delivery-framework" class="text-navy-700 hover:text-navy-900 font-medium underline">Delivery Framework</a> - the hybrid governance and Agile execution framework used on engagements
            </span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-950 py-14">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold text-white mb-3">Engage Lavelle Pty Ltd</h2>
        <p class="text-slate-300 leading-relaxed mb-6">
          For consulting, contract project management or delivery advisory enquiries, use the contact form to describe your situation and requirements.
        </p>
        <a
          href="/contact"
          data-ga-event="consulting_cta_click"
          class="inline-flex items-center px-6 py-3 text-sm font-medium text-navy-950 bg-white hover:bg-slate-100 rounded-md transition-colors"
        >
          Send an Enquiry
        </a>
      </div>
    </div>
  </section>
</Layout>
