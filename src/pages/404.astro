---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Lavelle Pty Ltd" description="Page not found.">
  <section style="padding: clamp(6rem, 12vw, 10rem) 0;">
    <div class="wrap" style="max-width: 640px; text-align: center;">
      <div
        style="font-family:'Fraunces',serif; font-size:clamp(5rem,12vw,9rem); font-weight:300; color:var(--ochre); line-height:1; font-variation-settings:'opsz' 144; margin-bottom:1.5rem;"
        aria-hidden="true"
      >
        404
      </div>
      <h1
        style="font-size:var(--display-md); font-weight:400; margin-bottom:1rem;"
      >
        Page not found.
      </h1>
      <p class="lead" style="margin: 0 auto 2.5rem;">
        The page you are looking for does not exist or has been moved.
      </p>
      <div class="hero__ctas" style="justify-content:center;">
        <a href="/" class="btn btn--primary">Back to home <span class="btn__arrow">→</span></a>
        <a href="/engage" class="btn btn--ghost">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
