---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" noindex>
  <section class="section">
    <div class="container max-w-xl text-center mx-auto">
      <p class="text-6xl font-bold text-slate-200 mb-4" aria-hidden="true">404</p>
      <h1 class="text-2xl font-bold text-slate-900 mb-3">Page Not Found</h1>
      <p class="text-slate-600 mb-8">
        The page you are looking for does not exist or has been moved.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
        >
          Go to Home
        </a>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 hover:border-slate-400 rounded-md transition-colors"
        >
          Contact
        </a>
      </div>
    </div>
  </section>
</Layout>
