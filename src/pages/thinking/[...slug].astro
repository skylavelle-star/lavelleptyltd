---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const pieces = await getCollection("thinking");
  return pieces.map((piece) => ({
    params: { slug: piece.id },
    props: { article: piece },
  }));
}

interface Props {
  article: CollectionEntry<"thinking">;
}

const { article } = Astro.props;
const { Content } = await render(article);

const formattedDate = article.data.pubDate.toLocaleDateString("en-AU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout
  title={`${article.data.title} — Lavelle Pty Ltd`}
  description={article.data.description}
>
  <section class="subhero">
    <div class="wrap" style="max-width:64rem;">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/thinking">Thinking</a> &nbsp;/&nbsp;
        <span>{article.data.category}</span>
      </div>
      <div class="article-hero-meta">
        <span class="article-hero-cat">{article.data.category}</span>
        <span aria-hidden="true">·</span>
        <time datetime={article.data.pubDate.toISOString()}
          >{formattedDate}</time
        >
        <span aria-hidden="true">·</span>
        <span>{article.data.readTime} min read</span>
      </div>
      <h1>{article.data.title}</h1>
      <p class="subhero__lead">{article.data.description}</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <article class="articles">
        <Content />
      </article>

      {
        article.data.tags.length > 0 && (
          <div class="article-tags">
            <span class="article-tags__label">Topics</span>
            <ul>
              {article.data.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </div>
        )
      }

      <div class="article-back">
        <a href="/thinking" class="cap__link">
          <span aria-hidden="true">←</span> All thinking
        </a>
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Engage Lavelle</div>
          <h2 style="margin-top:1.25rem;">
            Dealing with a <em>situation like this?</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            For consulting, contract project management or delivery advisory
            enquiries, use the contact form to describe your situation and
            requirements.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary"
              >Send an enquiry <span class="btn__arrow">→</span></a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .article-hero-meta {
    display: flex;
    gap: 0.6rem;
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 1rem;
  }
  .article-hero-cat {
    color: var(--ochre);
    font-weight: 500;
  }
  .article-tags {
    max-width: 64ch;
    margin: 3rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }
  .article-tags__label {
    display: block;
    font-size: var(--micro);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 500;
    margin-bottom: 0.85rem;
  }
  .article-tags ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
  }
  .article-tags li {
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
  }
  .article-back {
    max-width: 64ch;
    margin-top: 2rem;
  }
</style>
