---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("thinking")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-AU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<BaseLayout
  title="Thinking — Lavelle Pty Ltd"
  description="Practical thinking on project delivery, governance, procurement, business case development and steering committee reporting. Written from real enterprise technology delivery experience."
  currentNav="thinking"
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Thinking</span>
      </div>
      <h1>Thinking. <em>Field notes from delivery.</em></h1>
      <p class="subhero__lead">
        Practical guidance on project delivery, governance, procurement and the
        senior delivery work that gets enterprise programs across the line.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="article-list">
        {
          articles.map((article) => (
            <article class="article-list__item">
              <div class="article-list__meta">
                <span class="article-list__category">
                  {article.data.category}
                </span>
                <span aria-hidden="true">·</span>
                <time datetime={article.data.pubDate.toISOString()}>
                  {formatDate(article.data.pubDate)}
                </time>
                <span aria-hidden="true">·</span>
                <span>{article.data.readTime} min read</span>
              </div>
              <h2 class="article-list__title">
                <a href={`/thinking/${article.id}`}>{article.data.title}</a>
              </h2>
              <p class="article-list__desc">{article.data.description}</p>
              <a href={`/thinking/${article.id}`} class="article-list__link">
                Read it <span class="btn__arrow">→</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Engage Lavelle</div>
          <h2 style="margin-top:1.25rem;">
            Need help with a <em>specific situation?</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            For consulting, contract project management or delivery advisory
            enquiries, use the contact form to describe your situation and
            requirements.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary"
              >Send an enquiry <span class="btn__arrow">→</span></a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .article-list {
    display: flex;
    flex-direction: column;
    max-width: 56rem;
  }
  .article-list__item {
    padding: 2rem 0;
    border-bottom: 1px solid var(--rule);
    transition: padding 0.2s;
  }
  .article-list__item:first-child {
    border-top: 1px solid var(--rule);
  }
  .article-list__item:hover {
    background: var(--paper);
    padding-left: 1rem;
    padding-right: 1rem;
  }
  .article-list__meta {
    display: flex;
    gap: 0.5rem;
    font-size: var(--micro);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 0.85rem;
  }
  .article-list__category {
    color: var(--ochre);
    font-weight: 500;
  }
  .article-list__title {
    font-family: "Fraunces", serif;
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 500;
    line-height: 1.1;
    margin-bottom: 0.85rem;
  }
  .article-list__title a {
    color: var(--ink);
    transition: color 0.2s;
  }
  .article-list__title a:hover {
    color: var(--ochre);
  }
  .article-list__desc {
    color: var(--ink-soft);
    font-size: var(--body);
    line-height: 1.55;
    max-width: 56ch;
    margin-bottom: 1rem;
  }
  .article-list__link {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
  }
  .article-list__link:hover {
    color: var(--ochre);
  }
</style>
