---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
---

<Layout
  title="Enterprise Licensing | Lavelle Pty Ltd"
  description="Multi-seat PMO template licensing for government agencies, universities and consulting firms. Access the full Lavelle Pty Ltd artefact library across your team or practice."
>

  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Licensing</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Enterprise Licensing</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Multi-seat access to the Lavelle Pty Ltd PMO template library for government agencies, universities and consulting firms. Annual licence with quarterly updates and branded export options.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-10">

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Who Enterprise Licensing Is For</h2>
            <ul class="space-y-2.5">
              {[
                'Government agencies that need standardised PMO artefacts across multiple projects and teams',
                'Universities and business schools incorporating practical PMO frameworks into delivery curriculum',
                'Management consulting firms wanting a proven PMO baseline they can deploy across client engagements',
                'Large organisations building or maturing an internal PMO practice',
                'Program delivery teams that need more than a single-user licence for a shared artefact library',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-6">What Enterprise Licensing Includes</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { title: 'Multi-seat access', desc: 'Licence covers your nominated team or organisation. Seats defined at engagement.' },
                { title: 'Full template library', desc: 'Access to all four packs - Steering Committee, Business Case, Procurement and Project Recovery.' },
                { title: 'Quarterly updates', desc: 'Templates revised quarterly based on user feedback, emerging standards and practical usage.' },
                { title: 'Branded export option', desc: 'Available on request - templates adapted with your organisation\'s logo and style at licence commencement.' },
                { title: 'Onboarding session', desc: 'A 60-minute onboarding call with Sky Lavelle to walk through the library and answer implementation questions.' },
                { title: 'Priority support', desc: 'Direct contact for template questions and implementation support throughout the licence term.' },
              ].map(({ title, desc }) => (
                <div class="p-5 rounded-lg border border-slate-200 bg-white">
                  <p class="text-sm font-semibold text-slate-900 mb-1">{title}</p>
                  <p class="text-sm text-slate-600 leading-relaxed">{desc}</p>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Pricing</h2>
            <div class="rounded-lg border border-navy-200 bg-white p-6">
              <div class="flex items-baseline gap-2 mb-2">
                <span class="text-3xl font-bold text-slate-900">AUD 3,000</span>
                <span class="text-slate-500">- AUD 8,000</span>
                <span class="text-sm text-slate-500">per year</span>
              </div>
              <p class="text-sm text-slate-600 mb-4">Annual licence. Pricing determined by seat count, organisation size and scope of use. Government procurement pathways available.</p>
              <div class="space-y-2 pt-4 border-t border-slate-100">
                {[
                  'Small team (up to 10 seats) - from AUD 3,000/year',
                  'Mid-sized organisation (10-50 seats) - from AUD 5,000/year',
                  'Large organisation or consulting firm (50+ seats) - from AUD 8,000/year',
                  'Pricing includes all packs, quarterly updates and onboarding session',
                ].map((item) => (
                  <div class="flex items-start gap-2 text-sm text-slate-600">
                    <svg class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-2">Submit an Enquiry</h2>
            <p class="text-slate-600 mb-6">
              Enterprise licensing is quoted individually. Complete the form below and we will respond within 2 business days with a proposal or a request for further information.
            </p>

            <form
              id="enterprise-form"
              class="space-y-5 max-w-xl"
              novalidate
            >
              <input type="hidden" name="access_key" value={site.web3formsKey} />
              <input type="hidden" name="subject" value="Enterprise Licensing Enquiry - lavelleptyltd.com.au" />
              <input type="hidden" name="from_name" value="Lavelle Pty Ltd Website" />
              <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="ent-name" class="block text-sm font-medium text-slate-700 mb-1">Full name <span class="text-red-500">*</span></label>
                  <input id="ent-name" name="name" type="text" required autocomplete="name"
                    class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-navy-500 focus:outline-none focus:ring-1 focus:ring-navy-500" />
                </div>
                <div>
                  <label for="ent-org" class="block text-sm font-medium text-slate-700 mb-1">Organisation <span class="text-red-500">*</span></label>
                  <input id="ent-org" name="organisation" type="text" required
                    class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-navy-500 focus:outline-none focus:ring-1 focus:ring-navy-500" />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="ent-email" class="block text-sm font-medium text-slate-700 mb-1">Work email <span class="text-red-500">*</span></label>
                  <input id="ent-email" name="email" type="email" required autocomplete="email"
                    class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-navy-500 focus:outline-none focus:ring-1 focus:ring-navy-500" />
                </div>
                <div>
                  <label for="ent-seats" class="block text-sm font-medium text-slate-700 mb-1">Approximate seat count</label>
                  <select id="ent-seats" name="seat_count"
                    class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-navy-500 focus:outline-none focus:ring-1 focus:ring-navy-500">
                    <option value="">Select range</option>
                    <option value="up-to-10">Up to 10</option>
                    <option value="10-50">10 - 50</option>
                    <option value="50-100">50 - 100</option>
                    <option value="100+">100+</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="ent-type" class="block text-sm font-medium text-slate-700 mb-1">Organisation type</label>
                <select id="ent-type" name="org_type"
                  class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-navy-500 focus:outline-none focus:ring-1 focus:ring-navy-500">
                  <option value="">Select type</option>
                  <option value="government">Government agency</option>
                  <option value="university">University or education provider</option>
                  <option value="consulting">Consulting or professional services firm</option>
                  <option value="corporate">Corporate or enterprise</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label for="ent-message" class="block text-sm font-medium text-slate-700 mb-1">How do you plan to use the templates?</label>
                <textarea id="ent-message" name="message" rows="4"
                  placeholder="Brief description of your use case, procurement context, or any specific requirements..."
                  class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:border-navy-500 focus:outline-none focus:ring-1 focus:ring-navy-500"></textarea>
              </div>

              <p id="ent-status" role="status" aria-live="polite" class="text-sm"></p>

              <button
                type="submit"
                id="ent-submit"
                class="inline-flex items-center px-6 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors"
              >
                Submit Enquiry
              </button>
              <p class="text-xs text-slate-500">We respond within 2 business days.</p>
            </form>
          </div>

        </div>

        <aside class="space-y-5">
          <div class="rounded-lg border border-navy-200 bg-white p-6 sticky top-24 space-y-4">
            <h2 class="text-base font-semibold text-slate-900">Enterprise Licensing</h2>
            <div>
              <p class="text-2xl font-bold text-slate-900">AUD 3,000 - 8,000</p>
              <p class="text-sm text-slate-500">per year</p>
            </div>
            <div class="pt-4 border-t border-slate-100 space-y-2">
              {['Multi-seat access', 'All four PMO packs', 'Quarterly updates', 'Onboarding session', 'Priority support', 'Government procurement pathways'].map((f) => (
                <div class="flex items-center gap-2 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </div>
              ))}
            </div>
            <div class="pt-4 border-t border-slate-100">
              <p class="text-xs text-slate-500 mb-2">Looking for individual templates instead?</p>
              <a href="/templates" class="text-xs font-medium text-navy-700 hover:text-navy-900 underline">View template packs</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('enterprise-form') as HTMLFormElement | null;
  const status = document.getElementById('ent-status') as HTMLElement | null;
  const submitBtn = document.getElementById('ent-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    const botcheck = form.querySelector<HTMLInputElement>('input[name="botcheck"]');
    if (botcheck?.checked) return;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }
    if (status) { status.textContent = ''; status.className = 'text-sm'; }
    let result: { success?: boolean; message?: string } = {};
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form).entries())),
      });
      result = await res.json().catch(() => ({})) as { success?: boolean; message?: string };
    } catch { result = { success: false }; }
    const ok = result.success === true;
    if (status) {
      status.textContent = ok
        ? "Enquiry received - we'll respond within 2 business days."
        : (result.message ?? 'Something went wrong. Please email us directly.');
      status.className = ok ? 'text-sm text-emerald-700' : 'text-sm text-red-700';
    }
    if (ok) form.reset();
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit Enquiry'; }
  });
</script>
