---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";

const tiers = [
  {
    name: "Team licence",
    price: "$3,000",
    period: "/year",
    summary: "Up to 10 users · all packs · annual updates",
    features: [
      "All packs, all updates",
      "10 named seats",
      "Co-branded option",
      "Email support",
    ],
    featured: false,
  },
  {
    name: "Department licence",
    price: "$5,500",
    period: "/year",
    summary: "Up to 50 users · all packs · onboarding workshop",
    features: [
      "All packs, all updates",
      "50 named seats",
      "Co-branded versions",
      "Half-day onboarding workshop",
      "Priority support",
    ],
    featured: true,
  },
  {
    name: "Agency licence",
    price: "$8,000",
    period: "/year",
    summary: "Unlimited users · branded · quarterly advisory",
    features: [
      "All packs, all updates",
      "Unlimited seats within agency",
      "Fully branded artefacts",
      "Full-day onboarding workshop",
      "Quarterly advisory call with Sky",
      "Government panel listing eligible",
    ],
    featured: false,
  },
];
---

<BaseLayout
  title="Enterprise Licensing — Lavelle Pty Ltd"
  description="Multi-seat licensing of Lavelle PMO templates and packs. Three annual seat tiers — Team ($3,000), Department ($5,500), Agency ($8,000) — for consulting firms, government departments and university PMOs."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Enterprise Licensing</span>
      </div>
      <div class="eyebrow">Multi-seat licensing</div>
      <h1 style="margin-top:1rem;">
        Standardise the PMO artefact baseline. <em>Across the whole team.</em>
      </h1>
      <p class="subhero__lead">
        For consulting firms, government departments and agencies, and
        university PMOs that want a single shared artefact set across every
        delivery team. Annual seat licensing, branded versions, onboarding and
        direct advisory access.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Who this is for</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Three target buyers. <em>One shared baseline.</em>
          </h2>
        </div>
        <p class="lead">
          Enterprise licensing is for organisations whose teams are already
          using PMO templates — but where every delivery group has rolled
          their own. The licence collapses that variance into one defensible
          standard.
        </p>
      </header>

      <div class="targets">
        <article class="target">
          <div class="target__label">Consulting firms</div>
          <p>
            Reselling or standardising the PMO baseline across delivery teams.
            Co-branded versions, optional white-label, all updates as they
            ship.
          </p>
        </article>
        <article class="target">
          <div class="target__label">Government departments &amp; agencies</div>
          <p>
            One shared artefact set across delivery groups, with the
            evaluation, RAID, financial control and steering committee
            artefacts that meet probity and accountability requirements.
          </p>
        </article>
        <article class="target">
          <div class="target__label">University PMOs and central ITS</div>
          <p>
            For delivery teams running enterprise technology change across
            faculties, schools and central services. Branded versions and
            onboarding included.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Annual seat tiers</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Three tiers. <em>Annual.</em>
          </h2>
        </div>
        <p class="lead">
          Prices below are inclusive. All tiers cover the full Lavelle pack
          set, all updates across the licence year, and onboarding scaled to
          the tier. Government panel listing is eligible at the Agency tier.
        </p>
      </header>

      <div class="tier-grid">
        {
          tiers.map((tier) => (
            <article class={`tier${tier.featured ? " tier--featured" : ""}`}>
              {tier.featured && <div class="tier__badge">Most popular</div>}
              <div class="eyebrow">{tier.name}</div>
              <div class="tier__price">
                {tier.price}
                <span class="tier__period">{tier.period}</span>
              </div>
              <p class="tier__summary">{tier.summary}</p>
              <ul class="tier__features">
                {tier.features.map((f) => (
                  <li>· {f}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="demo">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Book a demo</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Thirty minutes. <em>The right tier.</em>
          </h2>
        </div>
        <p class="lead">
          Tell us about your team and we will walk through the pack set, show
          the onboarding workshop, and confirm the right tier for your seat
          count and sector. No pitch deck.
        </p>
      </header>

      <form
        id="enterprise-demo-form"
        class="demo-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
      >
        <input type="hidden" name="access_key" value={site.web3formsKey} />
        <input
          type="hidden"
          name="subject"
          value="Enterprise Licensing demo request — lavelleptyltd.com.au"
        />
        <input
          type="hidden"
          name="from_name"
          value="Lavelle Pty Ltd Enterprise"
        />
        <input
          type="checkbox"
          name="botcheck"
          class="demo-form__bot"
          tabindex="-1"
          autocomplete="off"
        />

        <div class="demo-form__row">
          <label for="demo-name">Your name</label>
          <input
            id="demo-name"
            type="text"
            name="name"
            required
            autocomplete="name"
          />
        </div>

        <div class="demo-form__row">
          <label for="demo-email">Work email</label>
          <input
            id="demo-email"
            type="email"
            name="email"
            required
            autocomplete="email"
          />
        </div>

        <div class="demo-form__row">
          <label for="demo-role">Your role</label>
          <input
            id="demo-role"
            type="text"
            name="role"
            placeholder="e.g. PMO Lead, Director of Delivery"
            required
          />
        </div>

        <div class="demo-form__row">
          <label for="demo-team-size">Team size</label>
          <select id="demo-team-size" name="team_size" required>
            <option value="">Select…</option>
            <option value="1-10">1–10 users</option>
            <option value="11-50">11–50 users</option>
            <option value="51-200">51–200 users</option>
            <option value="200+">200+ users</option>
          </select>
        </div>

        <div class="demo-form__row">
          <label for="demo-sector">Sector</label>
          <select id="demo-sector" name="sector" required>
            <option value="">Select…</option>
            <option value="consulting">Consulting firm</option>
            <option value="government">Government department / agency</option>
            <option value="university">University / higher education</option>
            <option value="research">Research / government-adjacent</option>
            <option value="other">Other</option>
          </select>
        </div>

        <button type="submit" class="btn btn--primary demo-form__submit">
          Request a 30-minute demo <span class="btn__arrow">→</span>
        </button>

        <p id="demo-form-success" class="demo-form__success" hidden>
          Thanks. We will email you to book a time within one business day.
        </p>
      </form>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Adjacent offers</div>
          <h2 style="margin-top:1.25rem;">
            Need it <em>combined with consulting?</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            Enterprise licensing pairs naturally with PMO stand-up &amp;
            uplift consulting. We can roll the licence into a wider engagement
            where the goal is to embed the artefact set, not just supply it.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/contact" class="btn btn--primary">
              Engage Lavelle <span class="btn__arrow">→</span>
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li>
            <a href="/consulting#governance"
              ><span>PMO stand-up &amp; uplift</span><span>→</span></a>
          </li>
          <li>
            <a href="/templates"
              ><span>Browse the pack set</span><span>→</span></a>
          </li>
          <li>
            <a href="/framework"
              ><span>See the framework</span><span>→</span></a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .targets {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 860px) {
    .targets {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .target {
    background: var(--bone);
    border: 1px solid var(--rule);
    border-top: 3px solid var(--ochre);
    padding: 1.75rem;
  }
  .target__label {
    font-family: "DM Sans", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ochre);
    margin-bottom: 0.85rem;
  }
  .target p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
  }

  .tier-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 860px) {
    .tier-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tier {
    background: var(--bone);
    border: 1px solid var(--rule);
    padding: 2.5rem;
    position: relative;
  }
  .tier--featured {
    border: 2px solid var(--ochre);
  }
  .tier__badge {
    position: absolute;
    top: -12px;
    right: 1.5rem;
    background: var(--ochre);
    color: var(--bone);
    font-size: var(--micro);
    padding: 0.3rem 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .tier__price {
    font-family: "Fraunces", serif;
    font-size: 3rem;
    font-weight: 300;
    color: var(--ochre);
    margin: 1rem 0 0.5rem;
    line-height: 1;
  }
  .tier__period {
    font-size: 1rem;
    color: var(--ink-soft);
  }
  .tier__summary {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }
  .tier__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: var(--body-sm);
    color: var(--ink-soft);
  }

  .demo-form {
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2.5rem;
    background: var(--bone);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--ochre);
  }
  .demo-form__row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .demo-form label {
    font-size: var(--micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 500;
  }
  .demo-form input,
  .demo-form select {
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    background: var(--paper);
    font-family: inherit;
    font-size: var(--body-sm);
    color: var(--ink);
  }
  .demo-form input:focus,
  .demo-form select:focus {
    outline: none;
    border-color: var(--ochre);
  }
  .demo-form__submit {
    align-self: flex-start;
    margin-top: 0.5rem;
  }
  .demo-form__bot {
    display: none;
  }
  .demo-form__success {
    font-size: var(--body-sm);
    color: var(--ochre);
    margin: 0;
  }
  .demo-form__success[hidden] {
    display: none;
  }
</style>

<script>
  const form = document.getElementById(
    "enterprise-demo-form",
  ) as HTMLFormElement | null;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const botcheck = form.querySelector<HTMLInputElement>('[name="botcheck"]');
      if (botcheck?.checked) return;
      const submit = form.querySelector<HTMLButtonElement>(
        ".demo-form__submit",
      );
      if (submit) {
        submit.disabled = true;
        submit.textContent = "Sending…";
      }
      let ok = false;
      try {
        const res = await fetch(form.action, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(
            Object.fromEntries(new FormData(form).entries()),
          ),
        });
        const data = (await res.json().catch(() => ({}))) as {
          success?: boolean;
        };
        ok = data.success === true;
      } catch {
        /* silent */
      }
      if (ok) {
        form
          .querySelectorAll<HTMLElement>("input, select, button, label")
          .forEach((el) => {
            el.hidden = true;
          });
        const success = document.getElementById("demo-form-success");
        if (success) success.hidden = false;
      } else if (submit) {
        submit.disabled = false;
        submit.innerHTML =
          'Request a 30-minute demo <span class="btn__arrow">→</span>';
      }
    });
  }
</script>
