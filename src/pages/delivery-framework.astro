---
import Layout from '../layouts/Layout.astro';
import FrameworkStage from '../components/FrameworkStage.astro';

const stages = [
  {
    number: '01',
    name: 'Assess',
    description: 'Understand the current state, sponsor intent, scope boundaries and delivery risks.',
  },
  {
    number: '02',
    name: 'Initiate',
    description: 'Establish governance, funding pathway, project structure and approval routes.',
  },
  {
    number: '03',
    name: 'Plan',
    description: 'Define scope, schedule, resourcing, dependencies and the delivery approach.',
  },
  {
    number: '04',
    name: 'Deliver',
    description: 'Execute through fit-for-purpose delivery tools and structured working rhythms.',
  },
  {
    number: '05',
    name: 'Govern',
    description: 'Maintain steering committee oversight, RAID control and financial discipline.',
  },
  {
    number: '06',
    name: 'Recover',
    description: 'Apply structured intervention when projects need stabilising or replanning.',
  },
  {
    number: '07',
    name: 'Transition',
    description: 'Hand over to operations with benefits tracking and closure artefacts.',
  },
];

const artefacts = [
  {
    name: 'Business Case',
    description: 'Defines the case for change, investment options, expected benefits, delivery costs, risks, dependencies and the approval pathway.',
  },
  {
    name: 'Project Initiation Document',
    description: 'Establishes the governance structure, delivery approach, team, roles, reporting cadence and operating model for the project.',
  },
  {
    name: 'Project Management Plan',
    description: 'The primary planning artefact covering scope, schedule, resources, budget, quality, communications, risk and change management.',
  },
  {
    name: 'Project Schedule or Roadmap',
    description: 'A clear timeline showing milestones, dependencies, delivery phases and key decision points endorsed by the steering committee.',
  },
  {
    name: 'RAID Register',
    description: 'The central register for risks, assumptions, issues and dependencies. Maintained throughout delivery and reported to the steering committee.',
  },
  {
    name: 'Decision Log',
    description: 'A record of all significant decisions, the authority that made them and the date. Supports governance accountability and audit requirements.',
  },
  {
    name: 'Weekly Status Report',
    description: 'A structured status update covering RAG ratings, progress, risks, issues, actions, financials and escalation items.',
  },
  {
    name: 'Steering Committee Pack',
    description: 'A formal reporting pack for the project board covering health status, financials, risks, issues, decisions required, scope changes and milestone progress.',
  },
  {
    name: 'Benefits Register',
    description: 'Tracks the expected benefits, measures used to confirm realisation, ownership and the timeline for benefits delivery after project closure.',
  },
  {
    name: 'Closure Report',
    description: 'Formal project closure documentation covering delivery outcomes, benefits realisation status, outstanding risks, lessons learned and delegate sign-off.',
  },
];
---

<Layout
  title="Delivery Framework | Lavelle Pty Ltd"
  description="Lavelle Pty Ltd's practical hybrid delivery framework combines structured governance with Agile execution for complex technology and business change projects."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Delivery Framework</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          A practical hybrid framework that combines structured governance with Agile execution for complex technology and business change projects.
        </p>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-lg text-slate-700 leading-relaxed mb-6">
          Lavelle Pty Ltd uses a practical hybrid delivery framework that combines structured governance with Agile execution. It is designed for complex projects where funding, procurement, architecture, delivery, testing, change and executive reporting all need to stay aligned.
        </p>
      </div>
    </div>
  </section>

  <!-- FRAMEWORK STAGES -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Framework</p>
        <h2 class="text-2xl font-bold text-slate-900">The Seven Stages</h2>
      </div>
      <div class="space-y-4">
        {stages.map((stage) => (
          <FrameworkStage number={stage.number} title={stage.name} description={stage.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- BODY COPY -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl space-y-4 text-slate-600 leading-relaxed">
        <p>
          The framework is intentionally practical. It does not treat governance and delivery as separate worlds. Strategic artefacts such as the Business Case, Project Initiation Document and Project Management Plan sit alongside delivery tools such as Jira timelines, sprint planning, Confluence-based requirements, RAID management and weekly reporting.
        </p>
        <p>
          Steering Committee artefacts, financial controls and endorsed project documents are managed through appropriate governance channels, while day-to-day delivery is managed through fit-for-purpose delivery tools.
        </p>
      </div>
    </div>
  </section>

  <!-- HOW THE ARTEFACTS FIT TOGETHER -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Artefacts</p>
        <h2 class="text-2xl font-bold text-slate-900">How the Artefacts Fit Together</h2>
        <p class="text-slate-600 mt-3">
          Each artefact has a defined purpose and sits at a specific point in the delivery lifecycle.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {artefacts.map((artefact) => (
          <div class="flex gap-4 p-5 rounded-lg border border-slate-200 bg-white">
            <div class="w-1 rounded-full bg-navy-600 shrink-0 self-stretch" aria-hidden="true"></div>
            <div>
              <h3 class="text-sm font-semibold text-slate-900 mb-1">{artefact.name}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{artefact.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-3">Need Help Applying This Framework?</h2>
        <p class="text-slate-600 leading-relaxed mb-6">
          Lavelle Pty Ltd provides consulting and contract project management support for organisations applying structured delivery frameworks to complex programs.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-800 hover:bg-navy-900 rounded-md transition-colors">
            Engage Lavelle Pty Ltd
          </a>
          <a href="/pmo-resources" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-slate-700 border border-slate-300 hover:border-slate-400 rounded-md transition-colors">
            Browse PMO Resources
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
