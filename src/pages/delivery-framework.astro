---
import BaseLayout from '../layouts/BaseLayout.astro';

const stages = [
  { number: '01', name: 'Assess', description: 'Understand the current state, sponsor intent, scope boundaries and delivery risks.' },
  { number: '02', name: 'Initiate', description: 'Establish governance, funding pathway, project structure and approval routes.' },
  { number: '03', name: 'Plan', description: 'Define scope, schedule, resourcing, dependencies and the delivery approach.' },
  { number: '04', name: 'Deliver', description: 'Execute through fit-for-purpose delivery tools and structured working rhythms.' },
  { number: '05', name: 'Govern', description: 'Maintain steering committee oversight, RAID control and financial discipline.' },
  { number: '06', name: 'Recover', description: 'Apply structured intervention when projects need stabilising or replanning.' },
  { number: '07', name: 'Transition', description: 'Hand over to operations with benefits tracking and closure artefacts.' },
];

const artefacts = [
  { name: 'Business Case', description: 'Defines the case for change, investment options, expected benefits, delivery costs, risks, dependencies and the approval pathway.' },
  { name: 'Project Initiation Document', description: 'Establishes the governance structure, delivery approach, team, roles, reporting cadence and operating model for the project.' },
  { name: 'Project Management Plan', description: 'The primary planning artefact covering scope, schedule, resources, budget, quality, communications, risk and change management.' },
  { name: 'Project Schedule or Roadmap', description: 'A clear timeline showing milestones, dependencies, delivery phases and key decision points endorsed by the steering committee.' },
  { name: 'RAID Register', description: 'The central register for risks, assumptions, issues and dependencies. Maintained throughout delivery and reported to the steering committee.' },
  { name: 'Decision Log', description: 'A record of all significant decisions, the authority that made them and the date. Supports governance accountability and audit requirements.' },
  { name: 'Weekly Status Report', description: 'A structured status update covering RAG ratings, progress, risks, issues, actions, financials and escalation items.' },
  { name: 'Steering Committee Pack', description: 'A formal reporting pack for the project board covering health status, financials, risks, issues, decisions required, scope changes and milestone progress.' },
  { name: 'Benefits Register', description: 'Tracks the expected benefits, measures used to confirm realisation, ownership and the timeline for benefits delivery after project closure.' },
  { name: 'Closure Report', description: 'Formal project closure documentation covering delivery outcomes, benefits realisation status, outstanding risks, lessons learned and delegate sign-off.' },
];
---

<BaseLayout
  title="Delivery Framework — Lavelle Pty Ltd"
  description="Lavelle Pty Ltd's practical hybrid delivery framework combines structured governance with Agile execution for complex technology and business change projects."
>
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Delivery Framework</span>
      </div>
      <h1>A practical hybrid framework. <em>Governance plus execution.</em></h1>
      <p class="subhero__lead">
        Combines structured governance with Agile execution for complex technology and business change projects. Designed for environments where funding, procurement, architecture, delivery, testing, change and executive reporting all need to stay aligned.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Framework</div>
          <h2 class="section__title" style="margin-top:1.25rem;">The seven <em>stages.</em></h2>
        </div>
        <p class="lead">
          Strategic artefacts such as the Business Case, Project Initiation Document and Project Management Plan sit alongside delivery tools such as Jira timelines, sprint planning, Confluence-based requirements, RAID management and weekly reporting.
        </p>
      </header>

      <div class="capabilities">
        {stages.map((stage) => (
          <article class="cap">
            <div class="cap__num">{stage.number} / Stage</div>
            <h3 class="cap__title">{stage.name}</h3>
            <p class="cap__desc">{stage.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Artefacts</div>
          <h2 class="section__title" style="margin-top:1.25rem;">How the artefacts <em>fit together.</em></h2>
        </div>
        <p class="lead">
          Each artefact has a defined purpose and sits at a specific point in the delivery lifecycle. Steering Committee artefacts, financial controls and endorsed project documents are managed through appropriate governance channels, while day-to-day delivery is managed through fit-for-purpose delivery tools.
        </p>
      </header>

      <div class="artefact-grid">
        {artefacts.map((artefact) => (
          <div class="artefact-card">
            <h3>{artefact.name}</h3>
            <p>{artefact.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Apply this framework</div>
          <h2 style="margin-top:1.25rem;">Need help <em>applying it?</em></h2>
          <p class="lead" style="margin-top:1.5rem;">
            Lavelle Pty Ltd provides consulting and contract project management support for organisations applying structured delivery frameworks to complex programs.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/engage" class="btn btn--primary">
              Engage Lavelle Pty Ltd <span class="btn__arrow">→</span>
            </a>
            <a href="/pmo-resources" class="btn" style="background:transparent; color:var(--bone); border:1px solid var(--bone);">
              Browse PMO Resources
            </a>
          </div>
        </div>
        <ul class="engage__list">
          <li><a href="/consulting"><span>Consulting services</span><span>→</span></a></li>
          <li><a href="/pmo-resources"><span>PMO Resources</span><span>→</span></a></li>
          <li><a href="/case-studies"><span>Case studies</span><span>→</span></a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .artefact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 760px) {
    .artefact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .artefact-card {
    background: var(--bone);
    border: 1px solid var(--rule);
    padding: 1.5rem;
    border-left: 3px solid var(--ochre);
  }
  .artefact-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }
  .artefact-card p {
    font-size: var(--body-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: none;
  }
</style>
