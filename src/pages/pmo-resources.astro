---
import BaseLayout from "../layouts/BaseLayout.astro";
import { products, site } from "../config/site";

const steeringUrl = products.steeringCommitteePack.checkoutUrl || undefined;
const recoveryUrl = products.projectRecoveryPack.checkoutUrl || undefined;
const businessCaseUrl = products.businessCasePack.checkoutUrl || undefined;
const procurementUrl = products.procurementPack.checkoutUrl || undefined;

const anyCheckout = Boolean(
  steeringUrl || recoveryUrl || businessCaseUrl || procurementUrl,
);
---

<BaseLayout
  title="PMO Resources — Lavelle Pty Ltd"
  description="Battle-tested PMO product packs, templates and free tools from Lavelle Pty Ltd. Steering Committee Pack, Project Recovery Pack, Business Case Pack and more."
>
  {
    anyCheckout && (
      <script src="https://assets.lemonsqueezy.com/lemon.js" defer />
    )
  }
  <!-- SUB-PAGE HERO -->
  <section class="subhero">
    <div class="wrap">
      <div class="subhero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>PMO Resources</span>
      </div>
      <h1>The PMO artefacts we use on engagement. <em>Now packaged.</em></h1>
      <p class="subhero__lead">
        Project managers, PMO leads and program directors don't need another
        framework — they need a steering committee pack that's ready for Monday.
        These are the exact artefact sets Lavelle deploys on engagement,
        structured for download and immediate use. Built by senior
        practitioners, tested on real programs, written in language an executive
        will actually read.
      </p>
      <div class="hero__ctas" style="margin-top:2.5rem;">
        <a href="#packs" class="btn btn--primary"
          >View the product packs <span class="btn__arrow">→</span></a
        >
        <a href="#checklist" class="btn btn--ghost"
          >Download the free checklist</a
        >
      </div>
    </div>
  </section>

  <!-- FREE TOOL -->
  <section
    id="checklist"
    style="background:var(--paper); padding:clamp(3rem,6vw,5rem) 0;"
  >
    <div class="wrap">
      <div class="checklist-grid">
        <div>
          <div class="eyebrow">Free · for delivery leads</div>
          <h2
            style="font-size:var(--display-md); margin:1.25rem 0 1rem; font-weight:500;"
          >
            The <em style="color:var(--ochre);">Project Recovery Checklist.</em>
          </h2>
          <p class="lead" style="margin-bottom:1.5rem;">
            Twenty-three diagnostic questions we ask in the first forty-eight
            hours of any recovery engagement. Print it, take it into your next
            steering meeting, and you'll know within an hour where the real
            problems live — and which ones can wait.
          </p>
          <ul
            style="list-style:none; display:flex; flex-direction:column; gap:0.6rem; margin-bottom:2rem;"
          >
            <li
              style="font-size:var(--body-sm); color:var(--ink-soft); padding-left:1.25rem; position:relative;"
            >
              <span
                style="position:absolute; left:0; color:var(--ochre); font-weight:700;"
                >✓</span
              >23 diagnostic questions across 5 categories
            </li>
            <li
              style="font-size:var(--body-sm); color:var(--ink-soft); padding-left:1.25rem; position:relative;"
            >
              <span
                style="position:absolute; left:0; color:var(--ochre); font-weight:700;"
                >✓</span
              >Scoring rubric &amp; severity matrix
            </li>
            <li
              style="font-size:var(--body-sm); color:var(--ink-soft); padding-left:1.25rem; position:relative;"
            >
              <span
                style="position:absolute; left:0; color:var(--ochre); font-weight:700;"
                >✓</span
              >Stakeholder interview prompts
            </li>
            <li
              style="font-size:var(--body-sm); color:var(--ink-soft); padding-left:1.25rem; position:relative;"
            >
              <span
                style="position:absolute; left:0; color:var(--ochre); font-weight:700;"
                >✓</span
              >One-page summary template
            </li>
          </ul>
        </div>

        <form
          id="checklist-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          style="background:var(--bone); border:1px solid var(--rule); padding:2.5rem;"
          novalidate
        >
          <input type="hidden" name="access_key" value={site.web3formsKey} />
          <input
            type="hidden"
            name="subject"
            value="Project Recovery Checklist request - lavelleptyltd.com.au"
          />
          <input
            type="hidden"
            name="from_name"
            value="Lavelle Pty Ltd PMO Resources"
          />
          <input
            type="checkbox"
            name="botcheck"
            style="display:none;"
            tabindex="-1"
            autocomplete="off"
          />
          <h3
            style="font-family:'Fraunces',serif; font-size:1.4rem; font-weight:500; margin-bottom:0.5rem;"
          >
            Send it to me.
          </h3>
          <p
            style="font-size:var(--body-sm); color:var(--ink-soft); margin-bottom:1.5rem;"
          >
            No newsletter signup wall. We'll send the PDF and one email a
            fortnight with new field notes. Unsubscribe anytime.
          </p>
          <label
            for="checklist-name"
            style="display:block; font-size:var(--micro); letter-spacing:0.15em; text-transform:uppercase; color:var(--sage); margin-bottom:0.5rem;"
          >
            First name
          </label>
          <input
            id="checklist-name"
            name="name"
            type="text"
            required
            autocomplete="given-name"
            placeholder="Your name"
            style="width:100%; padding:0.85rem 1rem; border:1px solid var(--rule); background:var(--paper); font-family:inherit; font-size:var(--body); margin-bottom:1.25rem;"
          />
          <label
            for="checklist-email"
            style="display:block; font-size:var(--micro); letter-spacing:0.15em; text-transform:uppercase; color:var(--sage); margin-bottom:0.5rem;"
          >
            Work email
          </label>
          <input
            id="checklist-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="you@organisation.gov.au"
            style="width:100%; padding:0.85rem 1rem; border:1px solid var(--rule); background:var(--paper); font-family:inherit; font-size:var(--body); margin-bottom:1.5rem;"
          />
          <button
            id="checklist-submit"
            type="submit"
            class="btn btn--primary"
            style="width:100%; justify-content:center;"
          >
            Send me the checklist <span class="btn__arrow">→</span>
          </button>
        </form>
        <div
          id="checklist-success"
          hidden
          style="background:var(--bone); border:1px solid var(--rule); padding:2.5rem;"
        >
          <h3
            style="font-family:'Fraunces',serif; font-size:1.4rem; font-weight:500; margin-bottom:0.5rem;"
          >
            Thanks — it's on the way.
          </h3>
          <p style="font-size:var(--body-sm); color:var(--ink-soft);">
            We'll email the Project Recovery Checklist to the address you
            provided shortly. If it doesn't arrive within a few minutes, check
            your spam folder or get in touch.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT PACKS -->
  <section id="packs">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Product packs</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            Four packs.<br />One <em>delivery system.</em>
          </h2>
        </div>
        <p class="lead">
          Each pack is a self-contained artefact set for one decision-critical
          moment in delivery. Buy individually, or take the four-pack bundle and
          run your entire program governance from a single, coherent system.
        </p>
      </header>

      <div class="products">
        <article class="product">
          <span class="product__tag">Available now · v1.2</span>
          <h3 class="product__title">Steering Committee Pack</h3>
          <p class="product__desc">
            A complete steering committee toolkit. Decision papers, status
            dashboards, escalation logs and meeting protocols, built to make the
            boardroom 30 minutes count.
          </p>
          <ul class="product__list">
            <li>8 board-ready templates (.docx, .xlsx, .pptx)</li>
            <li>Decision-paper writing guide</li>
            <li>Pre-read protocol &amp; agenda framework</li>
            <li>RAID escalation thresholds</li>
            <li>RAG dashboard design with real definitions</li>
            <li>30-page implementation playbook</li>
          </ul>
          <div class="product__footer">
            <div>
              <div class="product__price">$147</div>
              <div class="product__price-sub">single user · AUD · GST inc.</div>
            </div>
            <a
              href={steeringUrl}
              class="lemonsqueezy-button btn btn--primary"
              data-ga-event="product_buy_click"
              data-ga-label="Steering Committee Pack"
              >Buy now <span class="btn__arrow">→</span></a
            >
          </div>
        </article>

        <article class="product">
          <span class="product__tag">Available now</span>
          <h3 class="product__title">Project Recovery Pack</h3>
          <p class="product__desc">
            The full 30-day diagnostic and stabilisation playbook for project
            managers stepping into a red program. The exact cadence Lavelle uses
            on recovery engagement.
          </p>
          <ul class="product__list">
            <li>30-day recovery roadmap</li>
            <li>Health-check diagnostic instrument</li>
            <li>Stakeholder &amp; sponsor scripts</li>
            <li>Re-baseline communication kit</li>
            <li>Vendor and team realignment protocols</li>
            <li>Recovery decision paper template</li>
          </ul>
          <div class="product__footer">
            <div>
              <div class="product__price">$297</div>
              <div class="product__price-sub">single user · AUD · GST inc.</div>
            </div>
            <a
              href={recoveryUrl}
              class="lemonsqueezy-button btn btn--primary"
              data-ga-event="product_buy_click"
              data-ga-label="Project Recovery Pack"
              >Buy now <span class="btn__arrow">→</span></a
            >
          </div>
        </article>

        <article class="product">
          <span class="product__tag">Available now</span>
          <h3 class="product__title">Business Case Pack</h3>
          <p class="product__desc">
            Treasury-grade and ICT business case templates and supporting
            models. Strategic, outline and full business case stages, with the
            benefits logic and risk articulation a board can actually
            interrogate.
          </p>
          <ul class="product__list">
            <li>Strategic, outline and full business case templates</li>
            <li>Structured for executive and delegate approval</li>
            <li>Benefits realisation model</li>
            <li>Options analysis framework</li>
            <li>Cost &amp; sensitivity workbook</li>
            <li>Executive narrative writing guide</li>
          </ul>
          <div class="product__footer">
            <div>
              <div class="product__price">$247</div>
              <div class="product__price-sub">single user · AUD · GST inc.</div>
            </div>
            <a
              href={businessCaseUrl}
              class="lemonsqueezy-button btn btn--primary"
              data-ga-event="product_buy_click"
              data-ga-label="Business Case Pack"
              >Buy now <span class="btn__arrow">→</span></a
            >
          </div>
        </article>

        <article class="product">
          <span class="product__tag">Available now</span>
          <h3 class="product__title">Procurement Pack</h3>
          <p class="product__desc">
            RFP design, evaluation governance and vendor onboarding artefacts.
            Built for procurement events where probity, capability assessment
            and speed have to coexist.
          </p>
          <ul class="product__list">
            <li>RFP &amp; EOI templates with evaluation criteria library</li>
            <li>Probity-compliant scoring workbook</li>
            <li>Vendor due diligence checklist</li>
            <li>Contract schedule design guide</li>
            <li>Vendor onboarding &amp; kickoff toolkit</li>
          </ul>
          <div class="product__footer">
            <div>
              <div class="product__price">$297</div>
              <div class="product__price-sub">single user · AUD · GST inc.</div>
            </div>
            <a
              href={procurementUrl}
              class="lemonsqueezy-button btn btn--primary"
              data-ga-event="product_buy_click"
              data-ga-label="Procurement Pack"
              >Buy now <span class="btn__arrow">→</span></a
            >
          </div>
        </article>
      </div>

      <!-- BUNDLES TEASER -->
      <div class="bundle">
        <div>
          <div
            class="eyebrow"
            style="color:var(--ochre); border-color:var(--ochre);"
          >
            Tier-based bundles
          </div>
          <h3
            style="font-family:'Fraunces',serif; font-size:2.25rem; font-weight:500; line-height:1.05; margin:1rem 0; color:var(--bone);"
          >
            The right bundle for the<br /><em
              style="color:var(--ochre); font-style:italic; font-weight:300;"
              >complexity of the work.</em
            >
          </h3>
          <p
            style="color:rgba(244,239,230,0.78); font-size:var(--body-lg); margin-bottom:1.5rem; max-width:50ch;"
          >
            Three tier-based bundles — Tier 3 Light, Tier 2 Standard and Tier
            1 Major — mirror the Project Tiering Calculator. Plus the
            consulting-led Project Recovery Bundle.
          </p>
        </div>
        <div style="text-align:right;">
          <a
            href="/bundles"
            class="btn btn--primary"
            style="background:var(--ochre); border-color:var(--ochre); color:var(--bone);"
          >
            See the bundles <span class="btn__arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ENTERPRISE LICENSING (TEASER) -->
  <section id="enterprise-licensing" style="background:var(--paper);">
    <div class="wrap">
      <header class="section__head">
        <div>
          <div class="eyebrow">Enterprise licensing</div>
          <h2 class="section__title" style="margin-top:1.25rem;">
            One artefact baseline.<br />Across the <em>whole team.</em>
          </h2>
        </div>
        <p class="lead">
          Multi-seat licensing of the Lavelle pack set for consulting firms,
          government departments and university PMOs. Three annual tiers —
          Team, Department and Agency — with co-branded versions, onboarding
          workshops and direct advisory access.
        </p>
      </header>

      <div style="text-align:center; margin-top:1.5rem;">
        <a href="/enterprise-licensing" class="btn btn--primary"
          >See enterprise tiers &amp; book a demo
          <span class="btn__arrow">→</span></a
        >
      </div>
    </div>
  </section>

  <!-- ENGAGE -->
  <section class="engage">
    <div class="wrap">
      <div class="engage__grid">
        <div>
          <div class="eyebrow">Need more than templates?</div>
          <h2 style="margin-top:1.25rem;">
            When the artefact isn't enough, <em>bring us in.</em>
          </h2>
          <p class="lead" style="margin-top:1.5rem;">
            The packs are designed to be self-serve. But sometimes a program
            needs a senior practitioner in the room — not another document. If
            that's where you are, the next conversation is the consulting
            team's.
          </p>
          <div class="hero__ctas" style="margin-top:2.5rem;">
            <a href="/consulting" class="btn btn--primary"
              >See consulting services <span class="btn__arrow">→</span></a
            >
            <a
              href="/contact"
              class="btn"
              style="background:transparent; color:var(--bone); border:1px solid var(--bone);"
            >
              Talk to Sky directly
            </a>
          </div>
        </div>

        <ul class="engage__list">
          <li>
            <a href="/contact?topic=enterprise"
              ><span>Bulk &amp; enterprise licensing</span><span>→</span></a>
          </li>
          <li>
            <a href="/contact?topic=panel"
              ><span>Government panel arrangements</span><span>→</span></a>
          </li>
          <li>
            <a href="/contact?topic=branding"
              ><span>Co-branded artefact packs</span><span>→</span></a>
          </li>
          <li>
            <a href="/contact?topic=training"
              ><span>Training &amp; onboarding workshops</span><span>→</span
              ></a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .checklist-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .bundle {
    margin-top: 3rem;
    background: var(--ink);
    color: var(--bone);
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  .enterprise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 880px) {
    .checklist-grid {
      grid-template-columns: 1.3fr 1fr;
      gap: 5rem;
    }
    .bundle {
      grid-template-columns: 1.5fr 1fr;
      gap: 4rem;
    }
    .enterprise-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
</style>

<script>
  const form = document.getElementById(
    "checklist-form",
  ) as HTMLFormElement | null;
  const success = document.getElementById("checklist-success");
  const submitBtn = document.getElementById(
    "checklist-submit",
  ) as HTMLButtonElement | null;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const botcheck =
        form.querySelector<HTMLInputElement>('[name="botcheck"]');
      if (botcheck?.checked) return;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending…";
      }
      let ok = false;
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(
            Object.fromEntries(new FormData(form).entries()),
          ),
        });
        const data = (await res.json().catch(() => ({}))) as {
          success?: boolean;
        };
        ok = data.success === true;
      } catch {
        /* silent */
      }
      if (ok) {
        form.hidden = true;
        if (success) success.hidden = false;
      } else if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML =
          'Send me the checklist <span class="btn__arrow">→</span>';
      }
    });
  }
</script>
