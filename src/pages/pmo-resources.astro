---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import ResourceCategoryCard from '../components/ResourceCategoryCard.astro';
import { products } from '../config/site';
import boardroomImage from '../assets/images/steering-committee-boardroom.jpg';

// TODO: Set PUBLIC_LS_PMO_BUNDLE_URL env var when a Lemon Squeezy bundle URL is available
const bundleUrl = import.meta.env.PUBLIC_LS_PMO_BUNDLE_URL || '';

const productList = Object.values(products);

const resourceCategories = [
  { id: 'project-recovery-resources', title: 'Project Recovery Resources' },
  { id: 'business-case-resources', title: 'Business Case Resources' },
  { id: 'procurement-rfp-resources', title: 'Procurement and RFP Resources' },
  { id: 'steering-committee-resources', title: 'Steering Committee Resources' },
  { id: 'governance-templates', title: 'Governance Templates' },
  { id: 'risk-issue-registers', title: 'Risk, Issue and Decision Registers' },
  { id: 'status-reporting', title: 'Weekly Status Reporting' },
  { id: 'initiation-planning', title: 'Project Initiation and Planning Artefacts' },
];
---

<Layout
  title="PMO Resources | Lavelle Pty Ltd"
  description="Practical PMO resources for project recovery, business cases, procurement, steering committee reporting and delivery governance. Designed for real project delivery environments."
>
  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-navy-300 uppercase tracking-wider mb-3">Lavelle Pty Ltd</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">PMO Resources</h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Practical resources for project managers, delivery leads, sponsors and organisations that need stronger project control without unnecessary complexity.
        </p>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-lg text-slate-700 leading-relaxed mb-4">
          Lavelle Pty Ltd develops practical PMO resources for project managers, delivery leads, sponsors and organisations that need stronger project control without unnecessary complexity.
        </p>
        <p class="text-lg text-slate-700 leading-relaxed">
          The resources are designed for real delivery environments where governance, funding, procurement, stakeholder management and execution need to work together.
        </p>
      </div>
    </div>
  </section>

  <!-- RESOURCE CATEGORIES -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Categories</p>
        <h2 class="text-2xl font-bold text-slate-900">What Is Covered</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {resourceCategories.map((cat) => (
          <ResourceCategoryCard title={cat.title} id={cat.id} />
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="section">
    <div class="container">
      <div class="max-w-xl mb-6">
        <p class="text-sm font-semibold text-navy-600 uppercase tracking-wider mb-3">Resource Packs</p>
        <h2 class="text-2xl text-slate-900">Featured PMO Resources</h2>
        <p class="text-slate-600 mt-3">
          Structured packs that bring together the templates, artefacts and guidance for a specific delivery challenge.
        </p>
      </div>
      <div class="flex flex-wrap items-center justify-between gap-4 mb-8 pb-6 border-b border-slate-200">
        <p class="text-sm text-slate-600">
          Practical PMO resource packs from AUD 49 to AUD 249. Available individually or as a complete library.
        </p>
        {bundleUrl && (
          <a
            href={bundleUrl}
            class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-navy-600 hover:bg-navy-700 rounded-md transition-colors shrink-0"
            data-ga-event="bundle_cta_click"
          >
            Get the complete library
            <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        )}
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {productList.map((product) => (
          <ProductCard
            name={product.name}
            description={product.description}
            whatsIncluded={[...product.whatsIncluded]}
            price={product.price || 'Pricing announced soon'}
            statusBadge={product.checkoutUrl ? 'Available' : 'Coming Soon'}
            ctaText="View Resource"
            ctaUrl={product.checkoutUrl ? product.href : undefined}
            disabled={!product.checkoutUrl}
            id={product.pmoResourcesHref.split('#')[1]}
            notifyEnabled={true}
            image={product.href === '/templates/steering-committee-pack' ? boardroomImage : undefined}
            imageAlt={product.href === '/templates/steering-committee-pack' ? 'An empty boardroom with a long meeting table - the setting where steering committee decisions are made' : undefined}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- DELIVERY FRAMEWORK ARTEFACTS -->
  <section class="section-alt">
    <div class="container">
      <div class="max-w-xl mb-10">
        <p class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-3">Delivery Framework</p>
        <h2 class="text-2xl font-bold text-slate-900">Framework Artefacts</h2>
        <p class="text-slate-600 mt-3">
          The governance and delivery artefacts used across the Lavelle Pty Ltd delivery framework, from initiation through to project closure.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Business Case',
          'Project Initiation Document',
          'Project Management Plan',
          'Project Schedule / Roadmap',
          'RAID Register',
          'Decision Log',
          'Weekly Status Report',
          'Steering Committee Pack',
          'Benefits Register',
          'Closure Report',
        ].map((artefact) => (
          <div class="flex items-center gap-3 p-4 rounded-lg border border-slate-200 bg-white">
            <div class="w-1.5 h-1.5 rounded-full bg-navy-500 shrink-0"></div>
            <span class="text-sm font-medium text-slate-800">{artefact}</span>
          </div>
        ))}
      </div>
      <div class="mt-6">
        <a href="/delivery-framework" class="inline-flex items-center text-sm font-medium text-navy-700 hover:text-navy-900 transition-colors">
          View the Delivery Framework
          <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CONSULTING CTA -->
  <section class="bg-slate-900 py-14">
    <div class="container">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold text-white mb-3">Need More Than Templates?</h2>
        <p class="text-slate-300 leading-relaxed mb-6">
          Lavelle Pty Ltd provides senior consulting and contract project management services for organisations that need hands-on delivery support.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/consulting" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-navy-700 hover:bg-navy-600 rounded-md transition-colors">
            View Consulting Services
          </a>
          <a href="/contact" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-slate-300 border border-slate-600 hover:border-slate-400 hover:text-white rounded-md transition-colors">
            Send an Enquiry
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
