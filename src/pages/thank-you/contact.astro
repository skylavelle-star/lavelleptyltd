---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Enquiry received - Lavelle Pty Ltd"
  description="Your enquiry has been received by Lavelle Pty Ltd."
  noindex
>
  <section style="padding: clamp(5rem, 10vw, 8rem) 0;">
    <div class="wrap" style="max-width: 640px; text-align: center;">
      <div class="eyebrow" style="display:inline-block;">Enquiry received</div>
      <h1
        style="font-size:var(--display-md); font-weight:400; margin:1.5rem 0 1rem;"
      >
        Thank you. <em>We will be in touch.</em>
      </h1>
      <p class="lead" style="margin: 0 auto 1rem;">
        Your enquiry has been sent to Lavelle Pty Ltd.
      </p>
      <p class="lead" style="margin: 0 auto 2.5rem;">
        You will receive a response within one business day.
      </p>
      <div class="hero__ctas" style="justify-content:center;">
        <a href="/" class="btn btn--primary"
          >Back to home <span class="btn__arrow">→</span></a
        >
        <a href="/resources" class="btn btn--ghost">Browse Resources</a>
      </div>
    </div>
  </section>
</BaseLayout>
