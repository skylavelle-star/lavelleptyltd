---
import BaseLayout from "../../layouts/BaseLayout.astro";

const gettingStarted = [
  "Start with the guidance notes before adapting any template.",
  "All documents are fully editable. Adjust sections to match your situation.",
  "If you need senior delivery support alongside the templates, consulting is available through Lavelle Pty Ltd.",
];
---

<BaseLayout
  title="Purchase confirmed - Lavelle Pty Ltd"
  description="Your purchase has been confirmed. Download links are on the way."
  noindex
>
  <section style="padding: clamp(5rem, 10vw, 8rem) 0;">
    <div class="wrap" style="max-width: 720px;">
      <div style="text-align:center; margin-bottom:3rem;">
        <div class="eyebrow" style="display:inline-block;">
          Purchase confirmed
        </div>
        <h1
          style="font-size:var(--display-md); font-weight:400; margin:1.5rem 0 1rem;"
        >
          Your <em>download link</em> is on the way.
        </h1>
        <p class="lead" style="margin: 0 auto;">
          The download link has been sent to your email. If you do not see it
          within a few minutes, check your spam folder.
        </p>
      </div>

      <div
        style="background:var(--paper); border:1px solid var(--rule); padding:2rem; margin-bottom:2.5rem;"
      >
        <h2
          style="font-family:'DM Sans',sans-serif; font-size:var(--micro); letter-spacing:0.2em; text-transform:uppercase; color:var(--sage); font-weight:500; margin-bottom:1.25rem;"
        >
          Getting started
        </h2>
        <ul class="product__list" style="margin-top:0;">
          {gettingStarted.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="thinking__grid" style="grid-template-columns: 1fr 1fr;">
        <a
          href="/consulting"
          class="think-card"
          style="background:var(--paper); border:1px solid var(--rule); border-top:none; padding:1.75rem;"
        >
          <div class="think-card__kicker" style="color:var(--ochre);">
            Senior advisory
          </div>
          <h3
            class="think-card__title"
            style="color:var(--ink); font-size:1.25rem;"
          >
            Need advisory support?
          </h3>
          <p class="think-card__desc" style="color:var(--ink-soft);">
            Senior consulting and contract project management through Lavelle
            Pty Ltd.
          </p>
          <div
            class="think-card__meta"
            style="color:var(--ochre); letter-spacing:0.18em;"
          >
            View consulting →
          </div>
        </a>
        <a
          href="/resources"
          class="think-card"
          style="background:var(--paper); border:1px solid var(--rule); border-top:none; padding:1.75rem;"
        >
          <div class="think-card__kicker" style="color:var(--ochre);">
            More resources
          </div>
          <h3
            class="think-card__title"
            style="color:var(--ink); font-size:1.25rem;"
          >
            Browse more resources
          </h3>
          <p class="think-card__desc" style="color:var(--ink-soft);">
            PMO resources, free tools and template packs from Lavelle Pty Ltd.
          </p>
          <div
            class="think-card__meta"
            style="color:var(--ochre); letter-spacing:0.18em;"
          >
            Browse resources →
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
