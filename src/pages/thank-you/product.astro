---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Purchase Confirmed | Lavelle Pty Ltd" noindex>
  <section class="section min-h-[60vh] flex items-center">
    <div class="container max-w-2xl">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-emerald-100 mb-6">
          <svg class="w-7 h-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-slate-900 mb-3">Purchase confirmed.</h1>
        <p class="text-lg text-slate-600">
          Your download link has been sent to your email. If you do not see it within a few minutes, check your spam folder.
        </p>
      </div>

      <div class="rounded-lg border border-slate-200 p-6 mb-6 bg-slate-50">
        <h2 class="text-base font-semibold text-slate-900 mb-3">Getting started</h2>
        <ul class="space-y-2 text-sm text-slate-700">
          {[
            'Start with the guidance notes before adapting any template.',
            'All documents are fully editable. Adjust sections to match your situation.',
            'If you need senior delivery support alongside the templates, consulting is available through Lavelle Pty Ltd.',
          ].map((item) => (
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <a
          href="/consulting"
          class="group flex flex-col p-5 rounded-lg border border-navy-200 bg-navy-50 hover:bg-navy-100 transition-colors"
        >
          <h2 class="text-base font-semibold text-navy-900 mb-1">Need advisory support?</h2>
          <p class="text-sm text-navy-800 leading-relaxed flex-1">
            Senior consulting and contract project management through Lavelle Pty Ltd.
          </p>
          <span class="mt-3 text-sm font-medium text-navy-700">View consulting &rarr;</span>
        </a>
        <a
          href="/pmo-resources"
          class="group flex flex-col p-5 rounded-lg border border-slate-200 bg-white hover:border-navy-300 transition-colors"
        >
          <h2 class="text-base font-semibold text-slate-900 mb-1">Browse more resources</h2>
          <p class="text-sm text-slate-600 leading-relaxed flex-1">
            PMO resources, free tools and template packs from Lavelle Pty Ltd.
          </p>
          <span class="mt-3 text-sm font-medium text-navy-700">Browse resources &rarr;</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
